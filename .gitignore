
# ============================================================
# .gitignore for Mawidy — .NET Clean Architecture + Frontend
# ============================================================

# -------------------------------------------------------
# Visual Studio / .NET
# -------------------------------------------------------
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs

# Build output
[Dd]ebug/
[Rr]elease/
[Bb]in/
[Oo]bj/
out/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Ll]og/
[Ll]ogs/

# NuGet
*.nupkg
*.snupkg
*.nuget/
packages/
!**/.nuget/packages/*.nupkg
nuget.config.local
project.lock.json
project.fragment.lock.json
artifacts/

# MSTest
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Rider / JetBrains
.idea/
*.sln.iml
*.DotSettings.user

# -------------------------------------------------------
# ASP.NET / EF Core
# -------------------------------------------------------
# Migrations are often kept in source control, but
# exclude any auto-generated snapshots from local dbs
*.mdf
*.ldf
*.ndf

# Local settings overrides
appsettings.Development.json
appsettings.Local.json
appsettings.Secrets.json
secrets.json

# -------------------------------------------------------
# Environment & Secrets
# -------------------------------------------------------
.env
.env.*
!.env.example
*.pfx
*.p12
*.key
*.pem
*.cer
*.crt

# -------------------------------------------------------
# Node / npm / Frontend
# -------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Frontend build output
dist/
build/
.next/
.nuxt/
.cache/
.parcel-cache/
.vite/

# -------------------------------------------------------
# OS-specific
# -------------------------------------------------------
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# -------------------------------------------------------
# Editor / IDE
# -------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
*.code-workspace

# -------------------------------------------------------
# Misc
# -------------------------------------------------------
*.log
*.tmp
*.temp
*.bak
*.swp
*.orig
coverage/
.coverage
TestResults/
