@model AdminBranchEditViewModel
@{ ViewData["Title"] = Model.Id == 0 ? "إضافة فرع جديد" : "تعديل الفرع"; ViewData["Page"] = "branches"; }

<div class="page-toolbar">
    <div><div class="page-title">@ViewData["Title"]</div></div>
    <a href="/admin/branches" class="btn-ghost">← العودة للقائمة</a>
</div>

<div style="max-width:680px">
    <form method="post" action="/admin/branches/save">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="dash-card">
            <div class="dc-title">📋 البيانات الأساسية</div>
            <div class="form-grid">
                <div class="form-grp full">
                    <label>اسم الفرع</label>
                    <input asp-for="NameAr" class="adm-input" placeholder="مثال: فودافون - مدينة نصر" />
                </div>
                <div class="form-grp">
                    <label>الشركة</label>
                    <select asp-for="OperatorId" asp-items="Model.Operators" class="adm-select">
                        <option value="">— اختر —</option>
                    </select>
                </div>
                <div class="form-grp">
                    <label>الحالة</label>
                    <select asp-for="Status" class="adm-select">
                        <option value="0">🟢 متاح</option>
                        <option value="1">🟡 مزدحم</option>
                        <option value="2">🔴 مغلق</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="dash-card">
            <div class="dc-title">🗺️ الموقع الجغرافي</div>
            <div class="form-grid">
                <div class="form-grp">
                    <label>المحافظة</label>
                    <select asp-for="GovernorateId" asp-items="Model.Governorates" class="adm-select"
                            onchange="loadDistricts(this.value)">
                        <option value="">— اختر المحافظة —</option>
                    </select>
                </div>
                <div class="form-grp">
                    <label>المركز / الحي</label>
                    <select asp-for="DistrictId" class="adm-select" id="districtSelect">
                        <option value="">— اختر المحافظة أولاً —</option>
                        @foreach (var d in Model.Districts)
                        {
                            if (Model.DistrictId.ToString() == d.Value)
                            {
                                <option value="@d.Value" selected>@d.Text</option>
                            }
                            else
                            {
                                <option value="@d.Value">@d.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-grp">
                    <label>المنطقة (نص حر)</label>
                    <input asp-for="Area" class="adm-input" placeholder="مثال: مدينة نصر" />
                </div>
                <div class="form-grp full">
                    <label>العنوان التفصيلي</label>
                    <input asp-for="Address" class="adm-input" placeholder="شارع رئيسي، المنطقة، المحافظة" />
                </div>
                <div class="form-grp">
                    <label>المسافة (كم)</label>
                    <input asp-for="DistanceKm" type="number" step="0.1" class="adm-input" />
                </div>
            </div>
        </div>

        <div class="dash-card">
            <div class="dc-title">📊 إحصائيات الفرع</div>
            <div class="form-grid">
                <div class="form-grp">
                    <label>عدد الطابور</label>
                    <input asp-for="QueueCount" type="number" class="adm-input" />
                </div>
                <div class="form-grp">
                    <label>وقت الانتظار</label>
                    <input asp-for="WaitTime" class="adm-input" placeholder="مثال: 12 د" />
                </div>
                <div class="form-grp">
                    <label>التقييم (1-5)</label>
                    <input asp-for="Rating" type="number" step="0.1" min="1" max="5" class="adm-input" />
                </div>
            </div>
        </div>

        <div style="display:flex;gap:10px">
            <button type="submit" class="btn-primary" style="flex:1">
                @(Model.Id == 0 ? "✅ إضافة الفرع" : "💾 حفظ التعديلات")
            </button>
            <a href="/admin/branches" class="btn-ghost" style="flex:0.4;text-align:center;padding:9px">إلغاء</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
async function loadDistricts(govId) {
    const sel = document.getElementById('districtSelect');
    sel.innerHTML = '<option>جاري التحميل…</option>';
    if (!govId) { sel.innerHTML = '<option value="">— اختر المحافظة أولاً —</option>'; return; }
    const res  = await fetch(`/admin/branches/getdistricts?governorateId=${govId}`);
    const data = await res.json();
    sel.innerHTML = '<option value="">— اختر المركز —</option>' +
        data.map(d => `<option value="${d.value}">${d.text}</option>`).join('');
}
</script>
}
