@model List<ServiceType>
@{
    ViewData["Title"] = "إدارة الخدمات";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="fas fa-list-alt me-2"></i>إدارة الخدمات
    </h4>
    <a href="/AdminDashboard/CreateService" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>خدمة جديدة
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>اسم الخدمة</th>
                    <th>الوصف</th>
                    <th>المدة</th>
                    <th>عدد المواعيد</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var service in Model)
                {
                    <tr>
                        <td class="fw-bold">@service.Name</td>
                        <td class="text-muted small">@service.Description</td>
                        <td>
                            <span class="badge bg-info">
                                <i class="fas fa-clock me-1"></i>@service.DurationMinutes دقيقة
                            </span>
                        </td>
                        <td>
                            <span class="badge bg-secondary">
                                @service.Appointments.Count موعد
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a href="/AdminDashboard/EditService/@service.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="post" action="/AdminDashboard/DeleteService"
                                      onsubmit="return confirm('متأكد إنك عاوز تحذف الخدمة دي؟')">
                                    <input type="hidden" name="id" value="@service.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            @(service.Appointments.Any() ? "disabled" : "")>
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>