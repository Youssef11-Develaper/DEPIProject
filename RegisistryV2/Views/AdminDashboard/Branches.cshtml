@model List<Branch>
@{
    ViewData["Title"] = "إدارة الفروع";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="fas fa-building me-2"></i>إدارة الفروع</h4>
    <a href="/AdminDashboard/CreateBranch" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>فرع جديد
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>اسم الفرع</th>
                    <th>المحافظة</th>
                    <th>العنوان</th>
                    <th>أيام العمل</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var branch in Model)
                {
                    <tr>
                        <td class="fw-bold">@branch.Name</td>
                        <td>@branch.Governorate.Name</td>
                        <td class="text-muted small">@branch.Address</td>
                        <td>
                            <span class="badge bg-info">
                                @branch.Schedules.Count يوم
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a href="/AdminDashboard/EditBranch/@branch.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="/AdminDashboard/BranchSchedule/@branch.Id"
                                   class="btn btn-sm btn-outline-info">
                                    <i class="fas fa-clock"></i>
                                </a>
                                <form method="post" action="/AdminDashboard/DeleteBranch"
                                      onsubmit="return confirm('متأكد إنك عاوز تحذف الفرع ده؟')">
                                    <input type="hidden" name="id" value="@branch.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>