@using RegisistryV2.ViewModel.Admin
@model ServiceTypeViewModel
@{
    ViewData["Title"] = "خدمة جديدة";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="fas fa-plus me-2"></i>إضافة خدمة جديدة
    </h4>
    <a href="/AdminDashboard/Services" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-right me-2"></i>رجوع
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">بيانات الخدمة</div>
            <div class="card-body p-4">
                <form asp-action="CreateService" method="post">
                    <div asp-validation-summary="All" class="alert alert-danger d-none" id="validationSummary"></div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">اسم الخدمة</label>
                        <input asp-for="Name" class="form-control" placeholder="مثال: بطاقة الرقم القومي" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">الوصف</label>
                        <textarea asp-for="Description" class="form-control" rows="3"
                                  placeholder="وصف مختصر للخدمة"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">
                            مدة الخدمة
                            <small class="text-muted fw-normal">(بالدقائق)</small>
                        </label>
                        <div class="input-group">
                            <input asp-for="DurationMinutes" class="form-control" type="number"
                                   min="5" max="120" placeholder="30" />
                            <span class="input-group-text">دقيقة</span>
                        </div>
                        <span asp-validation-for="DurationMinutes" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <div class="mb-4">
                            <label class="form-label fw-bold">
                                المستندات المطلوبة
                                <small class="text-muted fw-normal">(كل مستند في سطر)</small>
                            </label>
                            <textarea asp-for="RequiredDocuments" class="form-control" rows="4"
                                      placeholder="مثال:
                                        بطاقة الرقم القومي الأصلية              
                                        صورة من بطاقة الرقم القومي                                                     
                                        شهادة الميلاد"></textarea>            
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>حفظ الخدمة
                        </button>
                        <a href="/AdminDashboard/Services" class="btn btn-outline-secondary">إلغاء</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const summary = document.getElementById('validationSummary');
        if (summary && summary.querySelectorAll('li').length > 0)
            summary.classList.remove('d-none');
    </script>
}