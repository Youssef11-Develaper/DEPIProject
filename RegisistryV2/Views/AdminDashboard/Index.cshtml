@using RegisistryV2.ViewModel.Admin
@model DashboardViewModel
@{
    ViewData["Title"] = "لوحة التحكم";
}

<div class="row g-3 mb-4">
    <div class="col-md-2">
        <div class="card stat-card">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                    <i class="fas fa-users fa-lg"></i>
                </div>
                <div>
                    <div class="text-muted small">المستخدمين</div>
                    <div class="fs-3 fw-bold">@Model.TotalUsers</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card stat-card">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="fas fa-exclamation-circle fa-lg"></i>
                </div>
                <div>
                    <div class="text-muted small">شكاوى معلقة</div>
                    <div class="fs-3 fw-bold">@Model.PendingComplaints</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="fas fa-calendar-check fa-lg"></i>
                </div>
                <div>
                    <div class="text-muted small">مواعيد اليوم</div>
                    <div class="fs-3 fw-bold">@Model.TodayAppointments</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card stat-card">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-info bg-opacity-10 text-info">
                    <i class="fas fa-building fa-lg"></i>
                </div>
                <div>
                    <div class="text-muted small">الفروع</div>
                    <div class="fs-3 fw-bold">@Model.TotalBranches</div>
                </div>
            </div>
        </div>
    </div>
        <div class="col-md-2">
            <div class="card stat-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                        <i class="fas fa-percentage fa-lg"></i>
                    </div>
                    <div>
                        <div class="text-muted small">نسبة الإلغاء</div>
                        <div class="fs-3 fw-bold">@Model.CancellationRate%</div>
                    </div>
                </div>
            </div>
        </div>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-chart-bar me-2"></i>مواعيد آخر 7 أيام
            </div>
            <div class="card-body">
                <canvas id="weeklyChart" height="100"></canvas>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-trophy me-2"></i>أعلى الفروع
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @foreach (var branch in Model.TopBranches)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                            <div>
                                <p class="mb-0 fw-bold small">@branch.BranchName</p>
                                <small class="text-muted">@branch.TotalAppointments موعد</small>
                            </div>
                            <div class="text-warning">
                                <i class="fas fa-star"></i>
                                <span class="text-dark fw-bold">@branch.AverageRating</span>
                            </div>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-calendar-day me-2"></i>إحصائيات اليوم
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span>مواعيد مكتملة</span>
                    <span class="badge bg-success fs-6">@Model.TodayCompleted</span>
                </div>
                <div class="progress mb-3" style="height:10px">
                    @{
                        var completedPercent = Model.TodayAppointments > 0
                        ? (Model.TodayCompleted * 100 / Model.TodayAppointments)
                        : 0;
                    }
                    <div class="progress-bar bg-success" style="width:@completedPercent%"></div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span>مواعيد ملغية</span>
                    <span class="badge bg-danger fs-6">@Model.TodayCancelled</span>
                </div>
                <div class="progress" style="height:10px">
                    @{
                        var cancelledPercent = Model.TodayAppointments > 0
                        ? (Model.TodayCancelled * 100 / Model.TodayAppointments)
                        : 0;
                    }
                    <div class="progress-bar bg-danger" style="width:@cancelledPercent%"></div>
                </div>
                
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-exclamation-circle me-2"></i>آخر الشكاوى</span>
                <a href="/AdminComplaint" class="btn btn-light btn-sm">عرض الكل</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>المستخدم</th>
                            <th>العنوان</th>
                            <th>الحالة</th>
                            <th>التاريخ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var complaint in Model.RecentComplaints)
                        {
                            <tr>
                                <td>@complaint.User.FullName</td>
                                <td>@complaint.Title</td>
                                <td>
                                    @switch (complaint.Status)
                                    {
                                        case ComplaintStatus.Submitted:
                                            <span class="badge bg-warning text-dark">تم الإرسال</span>
                                            break;
                                        case ComplaintStatus.UnderReview:
                                            <span class="badge bg-info">قيد المراجعة</span>
                                            break;
                                        case ComplaintStatus.Resolved:
                                            <span class="badge bg-success">تم الحل</span>
                                            break;
                                        case ComplaintStatus.Closed:
                                            <span class="badge bg-secondary">مغلقة</span>
                                            break;
                                    }
                                </td>
                                <td class="text-muted small">
                                    @complaint.CreatedAt.ToString("dd/MM/yyyy")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="row g-4 mt-4">

        <!-- أكتر الخدمات طلباً -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-fire me-2"></i>أكتر الخدمات طلباً
                </div>
                <div class="card-body">
                    @if (!Model.TopServices.Any())
                    {
                        <p class="text-muted text-center mb-0">مفيش بيانات كافية</p>
                    }
                    else
                    {
                        @foreach (var service in Model.TopServices)
                        {
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="fw-bold small">@service.ServiceName</span>
                                    <span class="text-muted small">
                                        @service.TotalAppointments موعد (@service.Percentage%)
                                    </span>
                                </div>
                                <div class="progress" style="height:8px">
                                    <div class="progress-bar bg-primary"
                                         style="width:@service.Percentage%"></div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- توزيع المحافظات -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-map-marked-alt me-2"></i>توزيع المواعيد على المحافظات
                </div>
                <div class="card-body">
                    @if (!Model.GovernorateDistribution.Any())
                    {
                        <p class="text-muted text-center mb-0">مفيش بيانات كافية</p>
                    }
                    else
                    {
                        <canvas id="governorateChart" height="180"></canvas>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const labels = @Html.Raw(Json.Serialize(Model.WeeklyAppointments.Select(w => w.Date.ToString("dd/MM"))));
        const data = @Html.Raw(Json.Serialize(Model.WeeklyAppointments.Select(w => w.Count)));

        new Chart(document.getElementById('weeklyChart'), {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'عدد المواعيد',
                    data: data,
                    backgroundColor: 'rgba(41, 128, 185, 0.7)',
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
            }
        });
    </script>
    <script>
        const govLabels = @Html.Raw(Json.Serialize(Model.GovernorateDistribution.Select(g => g.GovernorateName)));
        const govData = @Html.Raw(Json.Serialize(Model.GovernorateDistribution.Select(g => g.TotalAppointments)));

        if (govLabels.length > 0) {
            new Chart(document.getElementById('governorateChart'), {
                type: 'doughnut',
                data: {
                    labels: govLabels,
                    datasets: [{
                        data: govData,
                        backgroundColor: [
                            '#2980b9', '#27ae60', '#f39c12', '#e74c3c', '#9b59b6', '#1abc9c'
                        ]
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });
        }
    </script>
}

@section Styles {
    <style>
        .stat-card {
            border-radius: 12px;
            transition: transform 0.2s;
        }

            .stat-card:hover {
                transform: translateY(-3px);
            }

        .stat-icon {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
}