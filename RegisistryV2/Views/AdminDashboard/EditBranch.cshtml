@using RegisistryV2.ViewModel.Admin
@model BranchViewModel
@{
    ViewData["Title"] = "تعديل الفرع";
    var branchId = ViewBag.BranchId;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="fas fa-edit me-2"></i>تعديل الفرع</h4>
    <a href="/AdminDashboard/Branches" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-right me-2"></i>رجوع
    </a>
</div>

<div class="row g-4">
    <div class="col-md-5">
        <div class="card">
            <div class="card-header">بيانات الفرع</div>
            <div class="card-body p-4">
                <form asp-action="EditBranch" method="post">
                    <input type="hidden" name="id" value="@branchId" />
                    <div asp-validation-summary="All" class="alert alert-danger d-none" id="validationSummary"></div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">اسم الفرع</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">المحافظة</label>
                        <select asp-for="GovernorateId" class="form-select">
                            @foreach (var gov in (List<Governorate>)ViewBag.Governorates)
                            {
                                <option value="@gov.Id">@gov.Name</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">العنوان</label>
                        <input asp-for="Address" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">الموقع على الخريطة</label>
                        <div class="row g-2">
                            <div class="col-6">
                                <input asp-for="Latitude" class="form-control" id="latInput"
                                       placeholder="خط العرض" step="any" />
                            </div>
                            <div class="col-6">
                                <input asp-for="Longitude" class="form-control" id="lngInput"
                                       placeholder="خط الطول" step="any" />
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-save me-2"></i>حفظ التعديلات
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-map-marked-alt me-2"></i>
                اضغط على الخريطة لتحديد موقع الفرع أو ابحث عن المكان
            </div>
            <div class="card-body p-0">
                <div class="p-3 border-bottom">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" id="searchBox" class="form-control"
                               placeholder="مثال: شارع الهرم، الجيزة" />
                        <button type="button" id="searchBtn" class="btn btn-primary">
                            بحث
                        </button>
                    </div>
                    <div id="searchResults" class="list-group mt-2"></div>
                </div>

                <div id="map" style="height: 400px; border-radius: 0 0 12px 12px;"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script>
        const lat = parseFloat('@Model.Latitude') || 26.8206;
        const lng = parseFloat('@Model.Longitude') || 30.8025;

        const map = L.map('map').setView([26.8206, 30.8025], 7);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap',
            maxZoom: 19
        }).addTo(map);
        let marker = L.marker([lat, lng]).addTo(map);

        map.on('click', function (e) {
            const { lat, lng } = e.latlng;
            marker.setLatLng([lat, lng]);
            document.getElementById('latInput').value = lat.toFixed(6);
            document.getElementById('lngInput').value = lng.toFixed(6);
        });
    </script>
    <script>
        const searchBox = document.getElementById('searchBox');
        const searchBtn = document.getElementById('searchBtn');
        const searchResults = document.getElementById('searchResults');

        searchBtn.addEventListener('click', searchLocation);
        searchBox.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                searchLocation();
            }
        });

        async function searchLocation() {
            const query = searchBox.value.trim();
            if (!query) return;

            searchResults.innerHTML = '<div class="text-muted small p-2">جاري البحث...</div>';

            try {
                const response = await fetch(
                    `https://photon.komoot.io/api/?q=${encodeURIComponent(query)}&lang=ar&limit=5&lat=26.8&lon=30.8&bbox=24,21,37,32`
                );
                const data = await response.json();

                if (!data.features || data.features.length === 0) {
                    searchResults.innerHTML = '<div class="text-muted small p-2">مفيش نتائج، حاول كلمات تانية</div>';
                    return;
                }

                searchResults.innerHTML = '';
                data.features.forEach(feature => {
                    const props = feature.properties;
                    const coords = feature.geometry.coordinates; // [lng, lat]

                    const name = [
                        props.name,
                        props.street,
                        props.city,
                        props.state
                    ].filter(Boolean).join('، ');

                    const item = document.createElement('button');
                    item.type = 'button';
                    item.className = 'list-group-item list-group-item-action small text-end';
                    item.textContent = name;
                    item.addEventListener('click', () => selectLocation(coords[1], coords[0], name));
                    searchResults.appendChild(item);
                });
            } catch (err) {
                searchResults.innerHTML = '<div class="text-danger small p-2">حصل خطأ في البحث</div>';
            }
        }

        function selectLocation(lat, lng, name) {
            if (marker) map.removeLayer(marker);
            marker = L.marker([lat, lng]).addTo(map);
            map.setView([lat, lng], 16);

            document.getElementById('latInput').value = lat.toFixed(6);
            document.getElementById('lngInput').value = lng.toFixed(6);

            searchResults.innerHTML = '';
            searchBox.value = name;
        }
    </script>
}