@using RegisistryV2.ViewModel
@model HomeViewModel
@{
    ViewData["Title"] = "الرئيسية";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .hero {
        background: linear-gradient(135deg, #1B4F72 0%, #2E86C1 60%, #1B4F72 100%);
        min-height: 500px;
        display: flex;
        align-items: center;
        position: relative;
        overflow: hidden;
    }

    .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: repeating-linear-gradient(
            45deg,
            rgba(255,255,255,0.03) 0px,
            rgba(255,255,255,0.03) 1px,
            transparent 1px,
            transparent 60px
        );
    }

    .hero-badge {
        display: inline-block;
        background: rgba(255,255,255,0.15);
        color: white;
        padding: 6px 20px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        margin-bottom: 20px;
        border: 1px solid rgba(255,255,255,0.2);
    }

    .service-card {
        background: white;
        border-radius: 12px;
        padding: 24px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.07);
        transition: all 0.3s;
        border: 2px solid transparent;
        text-decoration: none;
        color: #1C2833;
        display: block;
        height: 100%;
    }

    .service-card:hover {
        border-color: #2E86C1;
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(27,79,114,0.15);
        color: #1C2833;
    }

    .service-icon {
        width: 56px;
        height: 56px;
        background: linear-gradient(135deg, #EAF2FB, #D6EAF8);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: #1B4F72;
        margin-bottom: 14px;
    }

    .step-number {
        width: 56px;
        height: 56px;
        background: linear-gradient(135deg, #1B4F72, #2E86C1);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        font-weight: 900;
        margin: 0 auto 14px;
    }

    .rating-card {
        background: white;
        border-radius: 12px;
        padding: 22px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.07);
        height: 100%;
    }

    .cta-section {
        background: linear-gradient(135deg, #1B4F72, #2E86C1);
    }
</style>

<!-- Hero -->
<div class="hero">
    <div class="container text-center position-relative" style="z-index:1">
        <div class="hero-badge">
            <i class="bi bi-shield-check me-1"></i>
            رواد مصر الرقمية
        </div>
        <h1 class="display-4 fw-black text-white mb-3" style="font-weight:900">
            السجل المدني<br>في متناول يدك
        </h1>
        <p class="lead mb-4" style="color:rgba(255,255,255,0.8);max-width:580px;margin:0 auto 32px">
            احجز مواعيدك بسهولة، تابع طلباتك، وخلص مصالحك من أي مكان وفي أي وقت
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a href="/Appointment/SelectService"
                style="background:white;color:#1B4F72;padding:14px 32px;border-radius:8px;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;gap:8px;transition:all 0.2s"
                onmouseover="this.style.transform='translateY(-2px)'"
                onmouseout="this.style.transform='translateY(0)'">
                <i class="bi bi-calendar-plus"></i>
                احجز موعد الآن
            </a>
            <a href="#services"
                style="background:transparent;color:white;padding:14px 32px;border-radius:8px;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;gap:8px;border:2px solid rgba(255,255,255,0.6)">
                <i class="bi bi-grid"></i>
                استعرض الخدمات
            </a>
        </div>
    </div>
</div>

<!-- Stats Bar -->
<div style="background:white;padding:20px 0;box-shadow:0 4px 15px rgba(0,0,0,0.08)">
    <div class="container">
        <div class="row text-center g-3">
            <div class="col-3">
                <div style="font-size:1.8rem;font-weight:900;color:#1B4F72">
                    @Model.TotalCompletedAppointments+
                </div>
                <div style="font-size:0.85rem;color:#717D7E;font-weight:600">موعد منجز</div>
            </div>
            <div class="col-3">
                <div style="font-size:1.8rem;font-weight:900;color:#1B4F72">
                    @Model.TotalRatings
                </div>
                <div style="font-size:0.85rem;color:#717D7E;font-weight:600">تقييم</div>
            </div>
            <div class="col-3">
                <div style="font-size:1.8rem;font-weight:900;color:#1B4F72">
                    @Model.AverageRating
                </div>
                <div style="font-size:0.85rem;color:#717D7E;font-weight:600">متوسط التقييم</div>
            </div>
            <div class="col-3">
                <div style="font-size:1.8rem;font-weight:900;color:#1B4F72">27</div>
                <div style="font-size:0.85rem;color:#717D7E;font-weight:600">محافظة</div>
            </div>
        </div>
    </div>
</div>

<!-- Services -->
<section id="services" style="padding:60px 0">
    <div class="container">
        <h2 class="text-center fw-bold mb-2" style="color:#1B4F72;font-size:1.8rem">خدماتنا</h2>
        <p class="text-center text-muted mb-5">كل ما تحتاجه في مكان واحد</p>

        <div class="row g-4">
            @{
                var icons = new[] { "bi-credit-card", "bi-person-badge", "bi-heart", "bi-file-earmark-text", "bi-people" };
                var services = ViewBag.Services as List<dynamic> ?? new List<dynamic>();
                int idx = 0;
            }
            @* Services بتيجي من HomeController *@
        </div>
    </div>
</section>

<!-- How it works -->
<section style="background:#EAF2FB;padding:60px 0">
    <div class="container">
        <h2 class="text-center fw-bold mb-2" style="color:#1B4F72;font-size:1.8rem">كيف تعمل المنصة؟</h2>
        <p class="text-center text-muted mb-5">3 خطوات بسيطة وموعدك محجوز</p>

        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="step-number">1</div>
                <h5 class="fw-bold mb-2">اختر الخدمة</h5>
                <p class="text-muted">اختر الخدمة التي تحتاجها من قائمة الخدمات المتاحة</p>
            </div>
            <div class="col-md-4">
                <div class="step-number">2</div>
                <h5 class="fw-bold mb-2">اختر الفرع والوقت</h5>
                <p class="text-muted">اختر أقرب فرع إليك والوقت المناسب</p>
            </div>
            <div class="col-md-4">
                <div class="step-number">3</div>
                <h5 class="fw-bold mb-2">احضر في موعدك</h5>
                <p class="text-muted">ستصلك رسالة تأكيد وتذكير بموعدك</p>
            </div>
        </div>
    </div>
</section>

<!-- Ratings -->
@if (Model.RecentRatings.Any())
{
    <section style="padding:60px 0">
        <div class="container">
            <h2 class="text-center fw-bold mb-2" style="color:#1B4F72;font-size:1.8rem">آراء المواطنين</h2>
            <p class="text-center text-muted mb-4">تجارب حقيقية من مستخدمي المنصة</p>

            <div class="text-center mb-4">
                <span style="font-size:3.5rem;font-weight:900;color:#1B4F72">@Model.AverageRating</span>
                <div style="color:#D4AC0D;font-size:1.3rem">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="bi bi-star@(i <= Math.Round(Model.AverageRating) ? "-fill" : "")"></i>
                    }
                </div>
                <div class="text-muted">@Model.TotalRatings تقييم</div>
            </div>

            <div class="row g-4">
                @foreach (var rating in Model.RecentRatings)
                {
                    <div class="col-md-3">
                        <div class="rating-card">
                            <div style="color:#D4AC0D;margin-bottom:10px">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="bi bi-star@(i <= rating.Stars ? "-fill" : "")"></i>
                                }
                            </div>
                            <p style="font-size:0.9rem;font-style:italic;color:#444;margin-bottom:14px">
                                "@rating.Comment"
                            </p>
                            <div style="border-top:1px solid #eee;padding-top:10px;display:flex;justify-content:space-between;align-items:center">
                                <div>
                                    <div style="font-weight:700;font-size:0.85rem">@rating.UserName</div>
                                    <div style="font-size:0.78rem;color:#717D7E">@rating.ServiceName</div>
                                </div>
                                <div style="font-size:0.78rem;color:#717D7E">
                                    @rating.CreatedAt.ToString("dd/MM")
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- CTA -->
@if (!User.Identity.IsAuthenticated)
{
    <section class="cta-section py-5 text-center">
        <div class="container">
            <h2 class="fw-bold text-white mb-3">ابدأ دلوقتي</h2>
            <p style="color:rgba(255,255,255,0.8)" class="mb-4">
                إنشاء حساب مجاني واحجز أول موعد في دقيقتين
            </p>
            <a href="/Account/Register"
                style="background:white;color:#1B4F72;padding:14px 36px;border-radius:8px;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;gap:8px">
                <i class="bi bi-person-plus"></i>
                إنشاء حساب مجاني
            </a>
        </div>
    </section>
}

<footer style="background:#1B4F72;color:rgba(255,255,255,0.7);text-align:center;padding:20px">
    <p class="mb-0">
        جميع الحقوق محفوظة &copy; 2024
        <span style="color:white;font-weight:700">السجل المدني الرقمي</span>
        - رواد مصر الرقمية
    </p>
</footer>