@using RegisistryV2.ViewModel
@model ProfileViewModel
@{
    ViewData["Title"] = "الملف الشخصي";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-9">

        <div class="card mb-4">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-4">
                    <div class="profile-avatar">
                        <i class="fas fa-user-circle fa-4x text-primary"></i>
                    </div>
                    <div>
                        <h4 class="fw-bold mb-1">@Model.FullName</h4>
                        <p class="text-muted mb-1">
                            <i class="fas fa-envelope me-2"></i>@Model.Email
                        </p>
                        <p class="text-muted mb-0">
                            <i class="fas fa-id-card me-2"></i>@Model.NationalId
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card text-center p-3">
                    <div class="fs-2 fw-bold text-primary">@Model.TotalAppointments</div>
                    <div class="text-muted small">كل المواعيد</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center p-3">
                    <div class="fs-2 fw-bold text-success">@Model.CompletedAppointments</div>
                    <div class="text-muted small">مواعيد مكتملة</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center p-3">
                    <div class="fs-2 fw-bold text-danger">@Model.CancelledAppointments</div>
                    <div class="text-muted small">مواعيد ملغية</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center p-3">
                    <div class="fs-2 fw-bold text-warning">@Model.TotalComplaints</div>
                    <div class="text-muted small">شكاوى</div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <i class="fas fa-edit me-2"></i>تعديل البيانات
            </div>
            <div class="card-body p-4">
                <form asp-action="Index" method="post">
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="NationalId" />
                    <input type="hidden" asp-for="TotalAppointments" />
                    <input type="hidden" asp-for="CompletedAppointments" />
                    <input type="hidden" asp-for="CancelledAppointments" />
                    <input type="hidden" asp-for="TotalComplaints" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">الاسم بالكامل</label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">رقم الهاتف</label>
                            <input asp-for="PhoneNumber" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">المحافظة</label>
                            <select asp-for="GovernorateId" class="form-select">
                                <option value="">اختار المحافظة</option>
                                @foreach (var gov in (List<Governorate>)ViewBag.Governorates)
                                {
                                    <option value="@gov.Id">@gov.Name</option>
                                }
                            </select>
                            <span asp-validation-for="GovernorateId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">المنطقة</label>
                            <input asp-for="Area" class="form-control" placeholder="مثال: مصر الجديدة" />
                            <span asp-validation-for="Area" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>حفظ التعديلات
                        </button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Styles {
    <style>
        .profile-avatar {
            width: 80px;
            height: 80px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
}