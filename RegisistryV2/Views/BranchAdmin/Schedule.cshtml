@using RegisistryV2.ViewModel.BranchAdmin
@model BranchDetailsViewModel

@{
    ViewData["Title"] = "إدارة مواعيد الفرع";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="fas fa-clock me-2"></i>إدارة مواعيد @Model.Branch.Name
    </h4>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-umbrella-beach me-2"></i>الإجازات</span>
        <button class="btn btn-light btn-sm" data-bs-toggle="modal"
                data-bs-target="#addHolidayModal">
            <i class="fas fa-plus me-1"></i>إضافة إجازة
        </button>
    </div>
    <div class="card-body p-0">
        @if (!Model.Holidays.Any())
        {
            <div class="text-center text-muted py-3">مفيش إجازات قادمة</div>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>التاريخ</th>
                        <th>السبب</th>
                        <th>حذف</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var holiday in Model.Holidays)
                    {
                        <tr>
                            <td class="fw-bold">@holiday.Date.ToString("dd/MM/yyyy")</td>
                            <td class="text-muted">@holiday.Reason</td>
                            <td>
                                <form method="post" action="/AdminDashboard/DeleteHoliday"
                                      onsubmit="return confirm('متأكد؟')">
                                    <input type="hidden" name="id" value="@holiday.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-ban me-2"></i>خدمات معطلة</span>
        <button class="btn btn-light btn-sm" data-bs-toggle="modal"
                data-bs-target="#addUnavailabilityModal">
            <i class="fas fa-plus me-1"></i>تعطيل خدمة
        </button>
    </div>
    <div class="card-body p-0">
        @if (!Model.Unavailabilities.Any())
        {
            <div class="text-center text-muted py-3">مفيش خدمات معطلة</div>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>الخدمة</th>
                        <th>التاريخ</th>
                        <th>السبب</th>
                        <th>حذف</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Unavailabilities)
                    {
                        <tr>
                            <td class="fw-bold">@item.ServiceType.Name</td>
                            <td>@item.Date.ToString("dd/MM/yyyy")</td>
                            <td class="text-muted">@item.Reason</td>
                            <td>
                                <form method="post" action="/AdminDashboard/DeleteServiceUnavailability"
                                      onsubmit="return confirm('متأكد؟')">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<div class="modal fade" id="addHolidayModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">إضافة إجازة</h5>
            </div>
            <div class="modal-body">
                <form method="post" action="/BranchAdmin/AddHoliday">
                    <div class="mb-3">
                        <label class="form-label fw-bold">التاريخ</label>
                        <input type="date" class="form-control" name="date"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">السبب</label>
                        <input type="text" class="form-control" name="reason"
                               placeholder="مثال: إجازة رسمية" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>حفظ
                        </button>
                        <button type="button" class="btn btn-outline-secondary"
                                data-bs-dismiss="modal">
                            إلغاء
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addUnavailabilityModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">تعطيل خدمة</h5>
            </div>
            <div class="modal-body">
                <form method="post" action="/BranchAdmin/AddServiceUnavailability">
                    <div class="mb-3">
                        <label class="form-label fw-bold">الخدمة</label>
                        <select name="serviceTypeId" class="form-select">
                            @foreach (var service in Model.Services)
                            {
                                <option value="@service.Id">@service.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">التاريخ</label>
                        <input type="date" class="form-control" name="date"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">السبب</label>
                        <input type="text" class="form-control" name="reason"
                               placeholder="مثال: مفيش موظف" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>حفظ
                        </button>
                        <button type="button" class="btn btn-outline-secondary"
                                data-bs-dismiss="modal">
                            إلغاء
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>