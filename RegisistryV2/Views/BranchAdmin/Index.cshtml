@using RegisistryV2.ViewModel.BranchAdmin
@model BranchAdminDashboardViewModel
@{
    ViewData["Title"] = "لوحة تحكم الفرع";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="fas fa-building me-2"></i>@Model.BranchName
    </h4>
    <span class="text-muted">@DateTime.Today.ToString("dd/MM/yyyy")</span>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-center p-3">
            <div class="fs-2 fw-bold text-primary">@Model.TodayAppointments</div>
            <div class="text-muted small">مواعيد اليوم</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center p-3">
            <div class="fs-2 fw-bold text-success">@Model.TodayCompleted</div>
            <div class="text-muted small">مكتملة</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center p-3">
            <div class="fs-2 fw-bold text-danger">@Model.TodayCancelled</div>
            <div class="text-muted small">ملغية</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center p-3">
            <div class="fs-2 fw-bold text-warning">@Model.AverageRating.ToString("F1")</div>
            <div class="text-muted small">
                <i class="fas fa-star text-warning"></i> متوسط التقييم
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <i class="fas fa-calendar-day me-2"></i>مواعيد اليوم
    </div>
    <div class="card-body p-0">
        @if (!Model.TodayAppointmentsList.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-calendar-times fa-3x mb-3"></i>
                <p>مفيش مواعيد اليوم</p>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>الوقت</th>
                        <th>المواطن</th>
                        <th>الخدمة</th>
                        <th>الحالة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appointment in Model.TodayAppointmentsList)
                    {
                        <tr>
                            <td class="fw-bold">
                                @appointment.TimeSlot.ToString(@"hh\:mm")
                            </td>
                            <td>
                                <p class="mb-0 fw-bold small">@appointment.User.FullName</p>
                                <small class="text-muted">@appointment.User.PhoneNumber</small>
                            </td>
                            <td class="small">@appointment.ServiceType.Name</td>
                            <td>
                                @switch (appointment.Status)
                                {
                                    case AppointmentStatus.Pending:
                                        <span class="badge bg-warning text-dark">معلق</span>
                                        break;
                                    case AppointmentStatus.Confirmed:
                                        <span class="badge bg-success">مؤكد</span>
                                        break;
                                    case AppointmentStatus.Completed:
                                        <span class="badge bg-primary">مكتمل</span>
                                        break;
                                    case AppointmentStatus.Cancelled:
                                        <span class="badge bg-danger">ملغي</span>
                                        break;
                                }
                            </td>
                            <td>
                                @if (appointment.Status == AppointmentStatus.Confirmed)
                                {
                                    <form method="post" action="/BranchAdmin/UpdateAppointmentStatus">
                                        <input type="hidden" name="id" value="@appointment.Id" />
                                        <input type="hidden" name="status" value="2" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-check me-1"></i>مكتمل
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>