@using RegisistryV2.ViewModel.Rating
@model RatingViewModel
@{
    ViewData["Title"] = "تقييم الخدمة";
    var appointment = ViewBag.Appointment as Appointment;
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-star me-2"></i>قيم تجربتك
            </div>
            <div class="card-body p-4">

                <div class="alert alert-info mb-4">
                    <div class="row">
                        <div class="col-6">
                            <small class="text-muted">الخدمة</small>
                            <p class="mb-0 fw-bold">@appointment.ServiceType.Name</p>
                        </div>
                        <div class="col-6">
                            <small class="text-muted">الفرع</small>
                            <p class="mb-0 fw-bold">@appointment.Branch.Name</p>
                        </div>
                    </div>
                </div>

                <form asp-action="Create" method="post">
                    <input type="hidden" asp-for="AppointmentId" />

                    <div class="mb-4 text-center">
                        <label class="form-label fs-5 fw-bold d-block mb-3">تقييمك للخدمة</label>
                        <div class="star-rating">
                            @for (int i = 5; i >= 1; i--)
                            {
                                <input type="radio" asp-for="Stars" value="@i" id="star@(i)" />
                                <label for="star@(i)">
                                    <i class="fas fa-star"></i>
                                </label>
                            }
                        </div>
                        <span asp-validation-for="Stars" class="text-danger small d-block mt-2"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">تعليقك (اختياري)</label>
                        <textarea asp-for="Comment" class="form-control" rows="4"
                                  placeholder="شاركنا تجربتك..."></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-paper-plane me-2"></i>إرسال التقييم
                        </button>
                        <a href="/Appointment/MyAppointments" class="btn btn-outline-secondary">إلغاء</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .star-rating {
            display: flex;
            flex-direction: row-reverse;
            justify-content: center;
            gap: 8px;
        }

            .star-rating input {
                display: none;
            }

            .star-rating label {
                font-size: 2.5rem;
                color: #ddd;
                cursor: pointer;
                transition: color 0.2s;
            }

                .star-rating label:hover,
                .star-rating label:hover ~ label,
                .star-rating input:checked ~ label {
                    color: #f39c12;
                }
    </style>
}