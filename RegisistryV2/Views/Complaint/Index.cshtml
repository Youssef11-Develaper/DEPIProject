@model List<Complaint>
@{
    ViewData["Title"] = "شكاواي";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-9">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-exclamation-circle me-2"></i>شكاواي</span>
                <a href="/Complaint/Create" class="btn btn-light btn-sm">
                    <i class="fas fa-plus me-1"></i>شكوى جديدة
                </a>
            </div>
            <div class="card-body p-0">
                @if (!Model.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fas fa-check-circle fa-3x mb-3 text-success"></i>
                        <p class="fs-5">مفيش شكاوى حالياً</p>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var complaint in Model)
                        {
                            <a href="/Complaint/Details/@complaint.Id"
                               class="list-group-item list-group-item-action p-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="mb-1 fw-bold">@complaint.Title</h6>
                                        <p class="mb-1 text-muted small">
                                            @complaint.Description.Substring(0, Math.Min(80, complaint.Description.Length))...
                                        </p>
                                        <small class="text-muted">
                                            <i class="fas fa-clock me-1"></i>
                                            @complaint.CreatedAt.ToString("dd/MM/yyyy")
                                        </small>
                                    </div>
                                    <div class="text-end">
                                        @switch (complaint.Status)
                                        {
                                            case ComplaintStatus.Submitted:
                                                <span class="badge bg-warning text-dark">تم الإرسال</span>
                                                break;
                                            case ComplaintStatus.UnderReview:
                                                <span class="badge bg-info">قيد المراجعة</span>
                                                break;
                                            case ComplaintStatus.Resolved:
                                                <span class="badge bg-success">تم الحل</span>
                                                break;
                                            case ComplaintStatus.Closed:
                                                <span class="badge bg-secondary">مغلقة</span>
                                                break;
                                        }
                                    </div>
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>