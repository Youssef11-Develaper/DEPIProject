@using RegisistryV2.ViewModel.Complaint
@model ComplaintViewModel
@{
    ViewData["Title"] = "شكوى جديدة";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-plus-circle me-2"></i>شكوى جديدة
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="All"
                    class="alert alert-danger @(ViewData.ModelState.ErrorCount == 0 ? "d-none" : "") id="validationSummary"></div>

                    <div class="mb-3">
                        <label class="form-label">عنوان الشكوى</label>
                        <input asp-for="Title" class="form-control" placeholder="اكتب عنوان مختصر" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">تفاصيل الشكوى</label>
                        <textarea asp-for="Description" class="form-control" rows="5"
                                  placeholder="اكتب تفاصيل الشكوى هنا..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    @if (ViewBag.Appointments != null && ((List<Appointment>)ViewBag.Appointments).Any())
                    {
                        <div class="mb-3">
                            <label class="form-label">
                                هل الشكوى مرتبطة بموعد؟
                                <span class="text-muted small">(اختياري)</span>
                            </label>
                            <select asp-for="AppointmentId" class="form-select">
                                <option value="">مش مرتبطة بموعد</option>
                                @foreach (var appointment in (List<Appointment>)ViewBag.Appointments)
                                {
                                    <option value="@appointment.Id">
                                        @appointment.ServiceType.Name - @appointment.Branch.Name
                                        (@appointment.AppointmentDate.ToString("dd/MM/yyyy"))
                                    </option>
                                }
                            </select>
                        </div>
                    }

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-paper-plane me-2"></i>إرسال الشكوى
                        </button>
                        <a href="/Complaint" class="btn btn-outline-secondary">إلغاء</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
