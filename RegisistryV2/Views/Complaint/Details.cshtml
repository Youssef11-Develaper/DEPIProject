@model Complaint
@{
    ViewData["Title"] = "تفاصيل الشكوى";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-info-circle me-2"></i>تفاصيل الشكوى</span>
                @switch (Model.Status)
                {
                    case ComplaintStatus.Submitted:
                        <span class="badge bg-warning text-dark fs-6">تم الإرسال</span>
                        break;
                    case ComplaintStatus.UnderReview:
                        <span class="badge bg-info fs-6">قيد المراجعة</span>
                        break;
                    case ComplaintStatus.Resolved:
                        <span class="badge bg-success fs-6">تم الحل</span>
                        break;
                    case ComplaintStatus.Closed:
                        <span class="badge bg-secondary fs-6">مغلقة</span>
                        break;
                }
            </div>
            <div class="card-body p-4">

                <h5 class="fw-bold mb-3">@Model.Title</h5>

                <div class="bg-light rounded p-3 mb-3">
                    <p class="mb-0">@Model.Description</p>
                </div>

                @if (Model.Appointment != null)
                {
                    <div class="alert alert-info">
                        <i class="fas fa-calendar me-2"></i>
                        مرتبطة بموعد: <strong>@Model.Appointment.AppointmentDate.ToString("dd/MM/yyyy")</strong>
                    </div>
                }

                <small class="text-muted">
                    <i class="fas fa-clock me-1"></i>
                    تم الإرسال: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                </small>

                @if (!string.IsNullOrEmpty(Model.AdminResponse))
                {
                    <hr />
                    <div class="mt-3">
                        <h6 class="fw-bold text-primary">
                            <i class="fas fa-reply me-2"></i>رد الإدارة
                        </h6>
                        <div class="bg-primary bg-opacity-10 rounded p-3">
                            <p class="mb-0">@Model.AdminResponse</p>
                        </div>
                    </div>
                }

                <div class="mt-4">
                    <a href="/Complaint" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-right me-2"></i>رجوع
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>