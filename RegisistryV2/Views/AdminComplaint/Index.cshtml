@model List<Complaint>
@{
    ViewData["Title"] = "إدارة الشكاوى";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="fas fa-exclamation-circle me-2"></i>إدارة الشكاوى
    </h4>

    <div class="d-flex gap-2">
        <a href="/AdminComplaint?status=" class="btn btn-outline-secondary btn-sm">الكل</a>
        <a href="/AdminComplaint?status=0" class="btn btn-outline-warning btn-sm">تم الإرسال</a>
        <a href="/AdminComplaint?status=1" class="btn btn-outline-info btn-sm">قيد المراجعة</a>
        <a href="/AdminComplaint?status=2" class="btn btn-outline-success btn-sm">تم الحل</a>
        <a href="/AdminComplaint?status=3" class="btn btn-outline-secondary btn-sm">مغلقة</a>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-check-circle fa-3x mb-3 text-success"></i>
                <p class="fs-5">مفيش شكاوى</p>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>المستخدم</th>
                        <th>العنوان</th>
                        <th>مرتبطة بموعد</th>
                        <th>الحالة</th>
                        <th>التاريخ</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var complaint in Model)
                    {
                        <tr>
                            <td>
                                <p class="mb-0 fw-bold small">@complaint.User.FullName</p>
                                <small class="text-muted">@complaint.User.PhoneNumber</small>
                            </td>
                            <td>@complaint.Title</td>
                            <td>
                                @if (complaint.AppointmentId != null)
                                {
                                    <span class="badge bg-info">
                                        <i class="fas fa-calendar me-1"></i>موعد #@complaint.AppointmentId
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </td>
                            <td>
                                @switch (complaint.Status)
                                {
                                    case ComplaintStatus.Submitted:
                                        <span class="badge bg-warning text-dark">تم الإرسال</span>
                                        break;
                                    case ComplaintStatus.UnderReview:
                                        <span class="badge bg-info">قيد المراجعة</span>
                                        break;
                                    case ComplaintStatus.Resolved:
                                        <span class="badge bg-success">تم الحل</span>
                                        break;
                                    case ComplaintStatus.Closed:
                                        <span class="badge bg-secondary">مغلقة</span>
                                        break;
                                }
                            </td>
                            <td class="text-muted small">
                                @complaint.CreatedAt.ToString("dd/MM/yyyy")
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary"
                                        onclick="openRespond(@complaint.Id, '@complaint.Status')">
                                    <i class="fas fa-reply me-1"></i>رد
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<div class="modal fade" id="respondModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-reply me-2"></i>الرد على الشكوى
                </h5>
            </div>
            <div class="modal-body">
                <form method="post" action="/AdminComplaint/Respond">
                    <input type="hidden" id="complaintId" name="id" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">الرد</label>
                        <textarea class="form-control" name="adminResponse" rows="4"
                                  placeholder="اكتب ردك هنا..."></textarea>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">تغيير الحالة</label>
                        <select class="form-select" name="status" id="statusSelect">
                            <option value="0">تم الإرسال</option>
                            <option value="1">قيد المراجعة</option>
                            <option value="2">تم الحل</option>
                            <option value="3">مغلقة</option>
                        </select>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-paper-plane me-2"></i>إرسال الرد
                        </button>
                        <button type="button" class="btn btn-outline-secondary"
                                data-bs-dismiss="modal">
                            إلغاء
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openRespond(id, status) {
            document.getElementById('complaintId').value = id;
            document.getElementById('statusSelect').value = status;
            new bootstrap.Modal(document.getElementById('respondModal')).show();
        }
    </script>
}