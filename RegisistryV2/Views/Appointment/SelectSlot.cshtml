@using RegisistryV2.ViewModel.Appointment
@model SelectSlotViewModel
@{
    ViewData["Title"] = "اختيار الموعد";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">

        <!-- Stepper -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="text-center">
                <div class="rounded-circle bg-success text-white d-inline-flex align-items-center justify-content-center" style="width:40px;height:40px;">
                    <i class="fas fa-check"></i>
                </div>
                <div class="small mt-1 text-success">الخدمة</div>
            </div>
            <div class="flex-grow-1 border-top mx-2"></div>
            <div class="text-center">
                <div class="rounded-circle bg-success text-white d-inline-flex align-items-center justify-content-center" style="width:40px;height:40px;">
                    <i class="fas fa-check"></i>
                </div>
                <div class="small mt-1 text-success">الفرع</div>
            </div>
            <div class="flex-grow-1 border-top mx-2"></div>
            <div class="text-center">
                <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center" style="width:40px;height:40px;font-weight:700">3</div>
                <div class="small mt-1 fw-bold text-primary">الموعد</div>
            </div>
        </div>

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <i class="fas fa-calendar-alt me-2"></i>
                    @Model.BranchName - @Model.ServiceName
                </div>
                <input type="date"
                       class="form-control w-auto"
                       id="datePicker"
                       value="@Model.SelectedDate.ToString("yyyy-MM-dd")"
                       min="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>
            <div class="card-body p-4">

                @if (!Model.IsAvailable)
                {
                    <div class="alert alert-warning text-center">
                        <i class="fas fa-exclamation-triangle fa-2x mb-2 d-block"></i>
                        <p class="mb-3">@Model.UnavailabilityMessage</p>
                        <div class="d-flex gap-2 justify-content-center">
                            <button class="btn btn-primary btn-sm"
                                    onclick="document.getElementById('datePicker').showPicker()">
                                <i class="fas fa-calendar me-1"></i>اختار يوم تاني
                            </button>
                            <a href="/Appointment/SelectBranch?serviceTypeId=@Model.ServiceTypeId"
                               class="btn btn-outline-secondary btn-sm">
                                <i class="fas fa-building me-1"></i>اختار فرع تاني
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <!-- إحصائيات الازدحام -->
                    @if (Model.BusiestDayName != null || Model.BusiestPeriod != null)
                    {
                        <div class="alert alert-info mb-3">
                            <i class="fas fa-chart-line me-2"></i>
                            <strong>إحصائيات الفرع:</strong>
                            @if (Model.BusiestDayName != null)
                            {
                                <span class="me-3">
                                    أكتر يوم ازدحاماً: <strong>@Model.BusiestDayName</strong>
                                </span>
                            }
                            @if (Model.BusiestPeriod != null)
                            {
                                <span>
                                    أكتر وقت في الشهر: <strong>@Model.BusiestPeriod</strong>
                                </span>
                            }
                        </div>
                    }

                    <!-- Legend -->
                    <div class="d-flex gap-3 mb-3 flex-wrap">
                        <span><span class="badge bg-success">متاح</span></span>
                        <span><span class="badge bg-danger">محجوز</span></span>
                        <span><span class="badge bg-warning text-dark">ذروة</span></span>
                    </div>

                    <!-- Slots -->
                    <div class="row g-2">
                        @foreach (var slot in Model.Slots)
                        {
                            <div class="col-6 col-md-3">
                                @if (slot.IsBooked)
                                {
                                    <div class="slot-btn booked text-center">
                                        <div><i class="fas fa-times me-1"></i>@slot.Time.ToString(@"hh\:mm")</div>
                                        <div class="small mt-1">مكتمل</div>
                                        <div class="small">@slot.MaxCount / @slot.MaxCount</div>
                                    </div>
                                }
                                else if (slot.IsPeak)
                                {
                                    <button class="slot-btn peak w-100"
                                            onclick="confirmSlot('@slot.Time', '@Model.BranchId', '@Model.ServiceTypeId', '@Model.SelectedDate.ToString("yyyy-MM-dd")')">
                                        <div><i class="fas fa-fire me-1"></i>@slot.Time.ToString(@"hh\:mm")</div>
                                        <div class="small mt-1">ذروة</div>
                                        <div class="small">
                                            @slot.BookedCount / @slot.MaxCount
                                            @if (slot.RemainingCount <= 2)
                                            {
                                                <span class="text-danger">⚠️ فاضل @slot.RemainingCount</span>
                                            }
                                        </div>
                                    </button>
                                }
                                else
                                {
                                    <button class="slot-btn available w-100"
                                            onclick="confirmSlot('@slot.Time', '@Model.BranchId', '@Model.ServiceTypeId', '@Model.SelectedDate.ToString("yyyy-MM-dd")')">
                                        <div>@slot.Time.ToString(@"hh\:mm")</div>
                                        <div class="small mt-1">
                                            @if (slot.BookedCount == 0)
                                            {
                                                <span class="text-success">أنت الأول! 🎉</span>
                                            }
                                            else
                                            {
                                                <span>@slot.BookedCount / @slot.MaxCount</span>
                                            }
                                        </div>
                                        @if (slot.RemainingCount <= 2 && slot.BookedCount > 0)
                                        {
                                            <div class="small text-danger">فاضل @slot.RemainingCount بس!</div>
                                        }
                                    </button>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Confirm Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">تأكيد الحجز</h5>
            </div>
            <div class="modal-body text-center">
                <i class="fas fa-calendar-check fa-3x text-primary mb-3"></i>
                <p class="fs-5">هتحجز الساعة <strong id="selectedTime"></strong></p>
                <p class="text-muted" id="selectedDateDisplay"></p>

                @if (!string.IsNullOrEmpty(Model.RequiredDocuments))
                {
                    <div class="alert alert-warning text-start mt-3">
                        <p class="fw-bold mb-2">
                            <i class="fas fa-exclamation-circle me-1"></i>
                            جهز المستندات دي:
                        </p>
                        <ul class="mb-0 ps-3">
                            @foreach (var doc in Model.RequiredDocuments.Split('\n'))
                            {
                                if (!string.IsNullOrWhiteSpace(doc))
                                {
                                    <li class="small">@doc.Trim()</li>
                                }
                            }
                        </ul>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <form id="confirmForm" method="post" action="/Appointment/Confirm">
                    <input type="hidden" name="branchId" id="hiddenBranch" />
                    <input type="hidden" name="serviceTypeId" id="hiddenService" />
                    <input type="hidden" name="date" id="hiddenDate" />
                    <input type="hidden" name="timeSlot" id="hiddenTime" />
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-check me-2"></i>تأكيد
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .slot-btn {
            padding: 12px 8px;
            border-radius: 10px;
            text-align: center;
            font-weight: 600;
            font-size: 0.9rem;
            border: none;
            transition: all 0.2s;
        }

            .slot-btn.available {
                background: #e8f8f0;
                color: #27ae60;
                border: 2px solid #27ae60;
            }

                .slot-btn.available:hover {
                    background: #27ae60;
                    color: white;
                    transform: translateY(-2px);
                }

            .slot-btn.booked {
                background: #fde8e8;
                color: #e74c3c;
                border: 2px solid #e74c3c;
                cursor: not-allowed;
            }

            .slot-btn.peak {
                background: #fef9e7;
                color: #f39c12;
                border: 2px solid #f39c12;
            }

                .slot-btn.peak:hover {
                    background: #f39c12;
                    color: white;
                    transform: translateY(-2px);
                }
    </style>
}

@section Scripts {
    <script>
        document.getElementById('datePicker').addEventListener('change', function () {
            const url = new URL(window.location.href);
            url.searchParams.set('date', this.value);
            window.location.href = url.toString();
        });

        function confirmSlot(time, branchId, serviceTypeId, date) {
            document.getElementById('selectedTime').textContent = time;
            document.getElementById('selectedDateDisplay').textContent = date;
            document.getElementById('hiddenBranch').value = branchId;
            document.getElementById('hiddenService').value = serviceTypeId;
            document.getElementById('hiddenDate').value = date;
            document.getElementById('hiddenTime').value = time;
            new bootstrap.Modal(document.getElementById('confirmModal')).show();
        }
    </script>
}