@model List<Appointment>
@{
    ViewData["Title"] = "مواعيدي";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-9">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-calendar-check me-2"></i>مواعيدي</span>
                <a href="/Appointment/SelectService" class="btn btn-light btn-sm">
                    <i class="fas fa-plus me-1"></i>موعد جديد
                </a>
            </div>
            <div class="card-body p-0">
                @if (!Model.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fas fa-calendar-times fa-3x mb-3"></i>
                        <p class="fs-5">مفيش مواعيد لحد دلوقتي</p>
                        <a href="/Appointment/SelectService" class="btn btn-primary">
                            <i class="fas fa-plus me-2"></i>احجز موعد دلوقتي
                        </a>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var appointment in Model)
                        {
                            <div class="list-group-item p-3">
                                <div class="row align-items-center">

                                    <div class="col-md-6">
                                        <h6 class="fw-bold mb-1">
                                            <i class="fas fa-file-alt me-2 text-primary"></i>
                                            @appointment.ServiceType.Name
                                        </h6>
                                        <p class="mb-1 text-muted small">
                                            <i class="fas fa-building me-1"></i>@appointment.Branch.Name
                                        </p>
                                        <p class="mb-0 text-muted small">
                                            <i class="fas fa-calendar me-1"></i>
                                            @appointment.AppointmentDate.ToString("dd/MM/yyyy")
                                            <i class="fas fa-clock me-2 ms-2"></i>
                                            @appointment.TimeSlot.ToString(@"hh\:mm")
                                        </p>
                                    </div>

                                    <div class="col-md-3 text-center">
                                        @switch (appointment.Status)
                                        {
                                            case AppointmentStatus.Pending:
                                                <span class="badge bg-warning text-dark fs-6">معلق</span>
                                                break;
                                            case AppointmentStatus.Confirmed:
                                                <span class="badge bg-success fs-6">مؤكد</span>
                                                break;
                                            case AppointmentStatus.Completed:
                                                <span class="badge bg-primary fs-6">مكتمل</span>
                                                break;
                                            case AppointmentStatus.Cancelled:
                                                <span class="badge bg-danger fs-6">ملغي</span>
                                                break;
                                        }
                                    </div>

                                    <div class="col-md-3 text-end">

                                        @if (appointment.Status == AppointmentStatus.Completed)
                                        {
                                            @if (appointment.Rating == null)
                                            {
                                                <a href="/Rating/Create?appointmentId=@appointment.Id"
                                                   class="btn btn-sm btn-outline-warning">
                                                    <i class="fas fa-star me-1"></i>قيم
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="text-warning">
                                                    @for (int i = 1; i <= 5; i++)
                                                    {
                                                        if (i <= appointment.Rating.Stars)
                                                        {
                                                            <i class="fas fa-star"></i>
                                                        }
                                                        else
                                                        {
                                                            <i class="far fa-star"></i>
                                                        }
                                                    }
                                                </span>
                                            }
                                        }

                                        @if (appointment.Status == AppointmentStatus.Pending ||
                                                                        appointment.Status == AppointmentStatus.Confirmed)
                                        {
                                            
                                            @if (appointment.AppointmentDate > DateTime.Now)
                                            {
                                                <div class="countdown-timer small text-info mb-1"
                                                     data-date="@appointment.AppointmentDate.ToString("yyyy-MM-dd")"
                                                     data-time="@appointment.TimeSlot.ToString(@"hh\:mm\:ss")">
                                                </div>
                                            }
                                            <form method="post" action="/Appointment/Cancel"
                                                  onsubmit="return confirm('متأكد إنك عاوز تلغي الموعد؟')">
                                                <a href="/Appointment/Reschedule?id=@appointment.Id"
                                                   class="btn btn-sm btn-outline-warning">
                                                    <i class="fas fa-clock me-1"></i>تأجيل
                                                </a>
                                                <input type="hidden" name="id" value="@appointment.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="fas fa-times me-1"></i>إلغاء
                                                </button>
                                                @if (appointment.Status == AppointmentStatus.Confirmed)
                                                {
                                                    <a href="/Appointment/QRCode/@appointment.Id"
                                                       class="btn btn-sm btn-outline-info">
                                                        <i class="fas fa-qrcode me-1"></i>QR
                                                    </a>
                                                }
                                            </form>
                                        }
                                    </div>

                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>

        function updateCountdowns() {
            document.querySelectorAll('.countdown-timer').forEach(el => {
                const dateStr = el.dataset.date;
                const timeStr = el.dataset.time;
                const appointmentDate = new Date(`${dateStr}T${timeStr}`);
                const now = new Date();
                const diff = appointmentDate - now;

                if (diff <= 0) {
                    el.textContent = 'الموعد حالياً';
                    return;
                }

                const days = Math.floor(diff / (1000 * 60 * 60 * 24));
                const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));

                if (days > 0)
                    el.innerHTML = `<i class="fas fa-hourglass-half me-1"></i>باقي ${days} يوم و ${hours} ساعة`;
                else if (hours > 0)
                    el.innerHTML = `<i class="fas fa-hourglass-half me-1"></i>باقي ${hours} ساعة و ${minutes} دقيقة`;
                else
                    el.innerHTML = `<i class="fas fa-hourglass-end me-1"></i>باقي ${minutes} دقيقة`;
            });
        }

        updateCountdowns();
        setInterval(updateCountdowns, 60000);
    </script>
}