@using RegisistryV2.ViewModel.Appointment
@model SelectBranchViewModel
@{
    ViewData["Title"] = "اختيار الفرع";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-10">

        <!-- Stepper -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="text-center">
                <div class="rounded-circle bg-success text-white d-inline-flex align-items-center justify-content-center" style="width:40px;height:40px;">
                    <i class="fas fa-check"></i>
                </div>
                <div class="small mt-1 text-success">الخدمة</div>
            </div>
            <div class="flex-grow-1 border-top mx-2"></div>
            <div class="text-center">
                <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center" style="width:40px;height:40px;font-weight:700">2</div>
                <div class="small mt-1 fw-bold text-primary">الفرع</div>
            </div>
            <div class="flex-grow-1 border-top mx-2"></div>
            <div class="text-center">
                <div class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center" style="width:40px;height:40px;font-weight:700">3</div>
                <div class="small mt-1 text-muted">الموعد</div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.UserGovernorateName))
        {
            <div class="alert alert-info mb-4">
                <i class="fas fa-map-marker-alt me-2"></i>
                بتعرض فروع <strong>@Model.UserGovernorateName</strong>
                @if (!string.IsNullOrEmpty(Model.UserArea))
                {
                    <span> - منطقة <strong>@Model.UserArea</strong></span>
                }
                <a href="/Profile" class="float-end text-decoration-none small">
                    <i class="fas fa-edit me-1"></i>تغيير المنطقة
                </a>
            </div>
        }

        @if (!Model.Branches.Any())
        {
            <div class="alert alert-warning text-center">
                <i class="fas fa-exclamation-triangle fa-2x mb-2 d-block"></i>
                <p class="mb-2">مفيش فروع في محافظتك دلوقتي</p>
                <a href="/Profile" class="btn btn-primary btn-sm">
                    <i class="fas fa-edit me-1"></i>غير محافظتك
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                <!-- قائمة الفروع -->
                <div class="col-md-5">
                    <div class="card">
                        <div class="card-header">
                            <i class="fas fa-building me-2"></i>
                            الفروع المتاحة (@Model.Branches.Count فرع)
                        </div>
                        <div class="card-body p-0">
                            <div class="list-group list-group-flush">
                                @foreach (var branch in Model.Branches)
                                {
                                    <a href="/Appointment/SelectSlot?serviceTypeId=@Model.ServiceTypeId&branchId=@branch.Id"
                                       class="list-group-item list-group-item-action branch-item p-3"
                                       data-lat="@branch.Latitude"
                                       data-lng="@branch.Longitude"
                                       data-name="@branch.Name">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6 class="mb-1 fw-bold">@branch.Name</h6>
                                                <p class="mb-1 text-muted small">
                                                    <i class="fas fa-map-marker-alt me-1"></i>@branch.Address
                                                </p>
                                                <div class="d-flex gap-2 mt-1">
                                                    <span class="badge bg-light text-dark small">
                                                        @branch.GovernorateName
                                                    </span>
                                                    <span class="badge bg-info text-white small">
                                                        <i class="fas fa-calendar me-1"></i>
                                                        @branch.WorkingDaysCount أيام عمل
                                                    </span>
                                                </div>
                                            </div>
                                            <i class="fas fa-chevron-left text-muted mt-1"></i>
                                        </div>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- الخريطة -->
                <div class="col-md-7">
                    <div class="card">
                        <div class="card-header">
                            <i class="fas fa-map-marked-alt me-2"></i>
                            خريطة الفروع
                            @if (!string.IsNullOrEmpty(Model.UserGovernorateName))
                            {
                                <span> في @Model.UserGovernorateName</span>
                            }
                        </div>
                        <div class="card-body p-0">
                            <div id="map" style="height: 450px; border-radius: 0 0 12px 12px;"></div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <script>
        const userLat = @Model.MapCenterLat;
        const userLng = @Model.MapCenterLng;
        const serviceTypeId = @Model.ServiceTypeId;

        const map = L.map('map').setView([userLat, userLng], 11);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap',
            maxZoom: 19
        }).addTo(map);

        const userIcon = L.divIcon({
            className: '',
            html: `<div style="
                background:#e74c3c;
                width:18px;height:18px;
                border-radius:50%;
                border:3px solid white;
                box-shadow:0 2px 8px rgba(0,0,0,0.4)">
            </div>`,
            iconSize: [18, 18],
            iconAnchor: [9, 9]
        });

        L.marker([userLat, userLng], { icon: userIcon })
            .addTo(map)
            .bindPopup('<b>موقعك</b>');

        const branchIcon = L.divIcon({
            className: '',
            html: `<div style="
                background:#2980b9;
                width:22px;height:22px;
                border-radius:50%;
                border:3px solid white;
                box-shadow:0 2px 8px rgba(0,0,0,0.4);
                display:flex;align-items:center;justify-content:center">
                <i class="fas fa-building" style="color:white;font-size:10px"></i>
            </div>`,
            iconSize: [22, 22],
            iconAnchor: [11, 11]
        });

        const branches = @Html.Raw(Json.Serialize(Model.Branches.Select(b => new {
            b.Id, b.Name, b.Address, b.Latitude, b.Longitude
        })));

        branches.forEach(branch => {
            L.marker([branch.latitude, branch.longitude], { icon: branchIcon })
                .addTo(map)
                .bindPopup(`
                    <div style="text-align:right;min-width:180px">
                        <b style="font-size:14px">${branch.name}</b><br>
                        <span style="color:#666;font-size:12px">
                            <i class="fas fa-map-marker-alt"></i> ${branch.address}
                        </span><br><br>
                        <div style="display:flex;gap:6px;justify-content:center">
                            <a href="/Appointment/SelectSlot?serviceTypeId=${serviceTypeId}&branchId=${branch.id}"
                               style="padding:5px 10px;background:#2980b9;color:white;
                                      border-radius:6px;text-decoration:none;font-size:12px">
                                احجز هنا
                            </a>
                            <a href="https://www.google.com/maps/dir/?api=1&destination=${branch.latitude},${branch.longitude}"
                               target="_blank"
                               style="padding:5px 10px;background:#27ae60;color:white;
                                      border-radius:6px;text-decoration:none;font-size:12px">
                                وجهني
                            </a>
                        </div>
                    </div>
                `);
        });

        document.querySelectorAll('.branch-item').forEach(item => {
            item.addEventListener('mouseenter', function () {
                const lat = parseFloat(this.dataset.lat);
                const lng = parseFloat(this.dataset.lng);
                map.setView([lat, lng], 15);
            });
        });

        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(function (position) {
                const realLat = position.coords.latitude;
                const realLng = position.coords.longitude;

                L.marker([realLat, realLng], { icon: userIcon })
                    .addTo(map)
                    .bindPopup('<b>موقعك الفعلي</b>');

                map.setView([realLat, realLng], 12);
            });
        }
    </script>
}