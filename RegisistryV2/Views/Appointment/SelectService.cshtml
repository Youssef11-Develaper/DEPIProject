@model List<ServiceType>
@{
    ViewData["Title"] = "اختيار الخدمة";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="text-center">
                <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center" style="width:40px;height:40px;font-weight:700">1</div>
                <div class="small mt-1 fw-bold text-primary">الخدمة</div>
            </div>
            <div class="flex-grow-1 border-top mx-2"></div>
            <div class="text-center">
                <div class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center" style="width:40px;height:40px;font-weight:700">2</div>
                <div class="small mt-1 text-muted">الفرع</div>
            </div>
            <div class="flex-grow-1 border-top mx-2"></div>
            <div class="text-center">
                <div class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center" style="width:40px;height:40px;font-weight:700">3</div>
                <div class="small mt-1 text-muted">الموعد</div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <i class="fas fa-list-alt me-2"></i>اختار الخدمة اللي محتاجها
            </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    @foreach (var service in Model)
                    {
                        <div class="col-md-6">
                            <a href="/Appointment/SelectBranch?serviceTypeId=@service.Id"
                               class="text-decoration-none">
                                <div class="card h-100 service-card">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center gap-3 mb-3">
                                            <div class="service-icon">
                                                <i class="fas fa-file-alt fa-2x text-primary"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-1 fw-bold">@service.Name</h6>
                                                <p class="mb-1 text-muted small">@service.Description</p>
                                                <span class="badge bg-light text-dark">
                                                    <i class="fas fa-clock me-1"></i>@service.DurationMinutes دقيقة
                                                </span>
                                            </div>
                                        </div>

                                        @if (!string.IsNullOrEmpty(service.RequiredDocuments))
                                        {
                                            <div class="border-top pt-3">
                                                <p class="small fw-bold text-danger mb-2">
                                                    <i class="fas fa-exclamation-circle me-1"></i>
                                                    المستندات المطلوبة:
                                                </p>
                                                <ul class="small text-muted mb-0 pe-3">
                                                    @foreach (var doc in service.RequiredDocuments.Split('\n'))
                                                    {
                                                        if (!string.IsNullOrWhiteSpace(doc))
                                                        {
                                                            <li>@doc.Trim()</li>
                                                        }
                                                    }
                                                </ul>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .service-card {
            border: 2px solid #e9ecef;
            border-radius: 12px;
            transition: all 0.2s;
            cursor: pointer;
        }

            .service-card:hover {
                border-color: #2980b9;
                transform: translateY(-3px);
                box-shadow: 0 5px 20px rgba(41,128,185,0.15);
            }
    </style>
}