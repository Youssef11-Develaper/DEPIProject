@{
    ViewData["Title"] = "تأكيد التسجيل";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card">
                <div class="card-body p-5">
                    <i class="bi bi-envelope-open-heart" style="font-size:3.5rem;color:#2E86C1;display:block;margin-bottom:16px"></i>
                    <h4 class="fw-bold mb-3">اتحقق من إيميلك!</h4>
                    <p class="text-muted mb-4">
                        بعتنالك إيميل تأكيد، اضغط على الرابط اللي في الإيميل عشان تكمل التسجيل
                    </p>
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        لو مش لاقي الإيميل، اتحقق من مجلد الـ Spam
                    </div>
                    <a href="/Account/Login" class="btn btn-primary mt-2">
                        <i class="bi bi-box-arrow-in-right me-2"></i>
                        روح لتسجيل الدخول
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>