@using RegisistryV2.ViewModel
@model RegisterViewModel
@{
    ViewData["Title"] = "إنشاء حساب";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-person-plus"></i>
                    إنشاء حساب جديد
                </div>
                <div class="card-body p-4">
                    <form asp-action="Register" method="post">
                        <div asp-validation-summary="All" class="alert alert-danger d-none" id="vs"></div>

                        <div class="mb-3">
                            <label class="form-label">الاسم بالكامل</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <input asp-for="FullName" class="form-control" placeholder="الاسم رباعي" />
                            </div>
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">الرقم القومي</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-credit-card"></i></span>
                                <input asp-for="NationalId" class="form-control" placeholder="14 رقم" maxlength="14" />
                            </div>
                            <span asp-validation-for="NationalId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">البريد الإلكتروني</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input asp-for="Email" class="form-control" placeholder="example@email.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">رقم الهاتف</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-phone"></i></span>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="01xxxxxxxxx" />
                            </div>
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">المحافظة</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-map"></i></span>
                                <select asp-for="GovernorateId" class="form-select">
                                    <option value="">اختر المحافظة</option>
                                    @foreach (var gov in (List<Governorate>)ViewBag.Governorates)
                                    {
                                        <option value="@gov.Id">@gov.Name</option>
                                    }
                                </select>
                            </div>
                            <span asp-validation-for="GovernorateId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">المنطقة</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-geo-alt"></i></span>
                                <input asp-for="Area" class="form-control" placeholder="مثال: مصر الجديدة" />
                            </div>
                            <span asp-validation-for="Area" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">كلمة المرور</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                <input asp-for="Password" class="form-control" placeholder="8 أحرف على الأقل" />
                                <button class="btn btn-outline-secondary" type="button" id="togglePwd">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">تأكيد كلمة المرور</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" />
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2">
                            <i class="bi bi-person-plus me-2"></i>إنشاء الحساب
                        </button>

                        <hr />

                        <div class="text-center">
                            <span class="text-muted">عندك حساب؟</span>
                            <a href="/Account/Login" class="fw-bold" style="color:#1B4F72">تسجيل الدخول</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const vs = document.getElementById('vs');
        if (vs && vs.querySelectorAll('li').length > 0) vs.classList.remove('d-none');

        document.getElementById('togglePwd').addEventListener('click', function() {
            const input = document.querySelector('input[name="Password"]');
            const icon = this.querySelector('i');
            input.type = input.type === 'password' ? 'text' : 'password';
            icon.className = input.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
        });
    </script>
}