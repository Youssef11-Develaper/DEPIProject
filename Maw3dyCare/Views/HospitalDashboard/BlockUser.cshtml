@model Maw3dyCare.ViewModels.BlockPhoneVM
@{
    ViewData["Title"] = "Block User";
    ViewData["ActivePage"] = "BlockUser";
    Layout = "~/Views/Shared/_HospitalLayout.cshtml";
}

<style>
    .block-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }

    .block-card {
        background: white;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        padding: 24px;
    }

    .card-title {
        font-size: 16px;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 4px;
    }

    .card-sub {
        font-size: 13px;
        color: #94a3b8;
        margin-bottom: 20px;
    }

    .form-field {
        margin-bottom: 14px;
    }

    .form-label {
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        display: block;
        margin-bottom: 6px;
    }

    .form-input {
        width: 100%;
        padding: 11px 14px;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        font-size: 14px;
        color: #1e293b;
        outline: none;
        transition: border-color .2s;
    }

        .form-input:focus {
            border-color: #ef4444;
        }

    .field-error {
        font-size: 12px;
        color: #ef4444;
        margin-top: 4px;
    }

    .btn-block {
        width: 100%;
        padding: 12px;
        background: #ef4444;
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: background .2s;
    }

        .btn-block:hover {
            background: #dc2626;
        }

    .blocked-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px solid #f1f5f9;
    }

        .blocked-item:last-child {
            border-bottom: none;
        }

    .phone-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #fff1f2;
        color: #ef4444;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
    }

    .phone-num {
        font-size: 14px;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 2px;
    }

    .phone-meta {
        font-size: 12px;
        color: #94a3b8;
    }

    .btn-unblock {
        margin-left: auto;
        padding: 5px 12px;
        border: 1.5px solid #e2e8f0;
        border-radius: 8px;
        background: white;
        color: #64748b;
        font-size: 12px;
        cursor: pointer;
        transition: all .15s;
    }

        .btn-unblock:hover {
            background: #f1f5f9;
        }

    .empty-blocked {
        text-align: center;
        padding: 2rem;
        color: #94a3b8;
        font-size: 13px;
    }

        .empty-blocked i {
            font-size: 28px;
            display: block;
            margin-bottom: 8px;
        }
</style>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
    <div>
        <h1 style="font-size:22px;font-weight:700;color:#ef4444;margin:0">
            <i class="fas fa-ban" style="font-size:18px;margin-right:8px;"></i>Block User
        </h1>
        <p style="color:#94a3b8;font-size:13px;margin:3px 0 0">Block phone numbers from making reservations</p>
    </div>
</div>

@if (TempData["BlockSuccess"] != null)
{
    <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:12px 16px;color:#16a34a;font-size:13px;font-weight:600;margin-bottom:16px;display:flex;align-items:center;gap:8px;">
        <i class="fas fa-check-circle"></i> @TempData["BlockSuccess"]
    </div>
}

<div class="block-grid">

    <div class="block-card">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:4px;">
            <div style="width:36px;height:36px;border-radius:50%;background:#fff1f2;color:#ef4444;display:flex;align-items:center;justify-content:center;font-size:16px;">
                <i class="fas fa-ban"></i>
            </div>
            <div class="card-title">Block a Number</div>
        </div>
        <div class="card-sub">Blocked numbers cannot make new reservations</div>

        <form asp-action="BlockPhone" method="post">
            @Html.AntiForgeryToken()

            <div class="form-field">
                <label class="form-label">Phone Number</label>
                <input asp-for="Phone" class="form-input" placeholder="01xxxxxxxxx" maxlength="11" />
                <span asp-validation-for="Phone" class="field-error"></span>
            </div>

            <div class="form-field">
                <label class="form-label">Reason (optional)</label>
                <input asp-for="Reason" class="form-input" placeholder="e.g. No-show multiple times" />
            </div>

            <button type="submit" class="btn-block">
                <i class="fas fa-ban"></i> Block Number
            </button>
        </form>
    </div>

    <div class="block-card">
        <div class="card-title">Blocked Numbers</div>
        <div class="card-sub">
            @((ViewBag.BlockedList as List<Maw3dyCare.ViewModels.BlockedUserVM>)?.Count ?? 0) number(s) blocked
        </div>

        @{
            var blockedList = ViewBag.BlockedList as List<Maw3dyCare.ViewModels.BlockedUserVM>;
        }

        @if (blockedList == null || !blockedList.Any())
        {
            <div class="empty-blocked">
                <i class="fas fa-check-circle" style="color:#16a34a;"></i>
                No blocked numbers
            </div>
        }
        else
        {
            @foreach (var b in blockedList)
            {
                <div class="blocked-item">
                    <div class="phone-avatar"><i class="fas fa-phone-slash"></i></div>
                    <div>
                        <div class="phone-num">@b.Phone</div>
                        <div class="phone-meta">
                            @(b.Reason ?? "No reason") · @b.BlockedAt.ToString("MMM dd, yyyy")
                        </div>
                    </div>
                    <form asp-action="UnblockPhone" method="post" style="margin:0;margin-left:auto;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@b.Id" />
                        <button type="submit" class="btn-unblock">
                            <i class="fas fa-unlock"></i> Unblock
                        </button>
                    </form>
                </div>
            }
        }
    </div>

</div>