<!-- Top Bar -->
<div class="dash-header">
    <div>
        <h1 style="font-size:22px; font-weight:700; color:#1e293b; margin:0">Dashboard</h1>
        <p style="color:#94a3b8; font-size:13px; margin:3px 0 0">
            <span id="liveTime"></span>
        </p>
    </div>
    <div class="topbar-right">
        <span class="system-badge">● System Active</span>
        <button class="bell-btn"><i class="fas fa-bell"></i></button>
    </div>
</div>

@* ===== Welcome Card ===== *@
<div class="welcome-card">
    <div class="welcome-label">Welcome Back</div>
    <div class="welcome-name">@Model.HospitalName</div>
    <div class="welcome-sub">
        <i class="fas fa-map-marker-alt" style="color:#3b82f6; margin-right:4px;"></i>
        @Model.City
        &nbsp;|&nbsp;
        @if (Model.IsActive)
        {
            <span style="color:#16a34a; font-weight:600;">● Active</span>
        }
        else
        {
            <span style="color:#94a3b8;">● Offline</span>
        }
    </div>
</div>

@* ===== Available + Occupied Big Cards ===== *@
<div class="beds-row">

    @* ===== Available Beds ===== *@
    <div class="big-card">
        <div class="big-card-header">
            <div>
                <div class="big-card-label">Available Beds</div>
                <div class="big-card-count">@Model.AvailableBeds</div>
            </div>
            <div class="big-card-icon icon-green">
                <i class="fas fa-bed"></i>
            </div>
        </div>

        @* Small cards per type *@
        <div class="type-cards-row">
            @if (!Model.AvailableByType.Any())
            {
                <div style="font-size:13px; color:#94a3b8;">No available beds</div>
            }
            @foreach (var t in Model.AvailableByType)
            {
                <div class="type-card type-card-avail">
                    <div class="type-name">@t.TypeName</div>
                    <div class="type-count">@t.Count</div>
                </div>
            }
        </div>
    </div>

    @* ===== Occupied Beds ===== *@
    <div class="big-card">
        <div class="big-card-header">
            <div>
                <div class="big-card-label">Occupied Beds</div>
                <div class="big-card-count">@Model.OccupiedBeds</div>
            </div>
            <div class="big-card-icon icon-red">
                <i class="fas fa-heart-pulse"></i>
            </div>
        </div>

        @* Small cards per type *@
        <div class="type-cards-row">
            @if (!Model.OccupiedByType.Any())
            {
                <div style="font-size:13px; color:#94a3b8;">No occupied beds</div>
            }
            @foreach (var t in Model.OccupiedByType)
            {
                <div class="type-card type-card-occ">
                    <div class="type-name">@t.TypeName</div>
                    <div class="type-count">@t.Count</div>
                </div>
            }
        </div>
    </div>

</div>

<script>
    // Live Time
    function updateTime() {
        const now = new Date();
        const days   = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
        const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        let h = now.getHours(), m = now.getMinutes().toString().padStart(2,'0');
        const ap = h >= 12 ? 'PM' : 'AM'; h = h % 12 || 12;
        document.getElementById('liveTime').textContent =
            `${days[now.getDay()]}, ${months[now.getMonth()]} ${now.getDate()} · ${h}:${m} ${ap}`;
    }
    updateTime(); setInterval(updateTime, 1000);
</script>