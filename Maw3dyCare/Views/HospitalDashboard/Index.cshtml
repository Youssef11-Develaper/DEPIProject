@model Maw3dyCare.ViewModels.HospitalDashboardVM
@{
    // Dashboard الرئيسي للمستشفى
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Home";
    Layout = "~/Views/Shared/_HospitalLayout.cshtml";
}

<style>
    /* ===== Page Header ===== */
    .dash-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 24px;
    }

    .welcome-card {
        background: linear-gradient(135deg, #eff6ff, #dbeafe);
        border: 1px solid #bfdbfe;
        border-radius: 16px;
        padding: 22px 26px;
        margin-bottom: 24px;
    }

    .welcome-label {
        font-size: 12px;
        font-weight: 600;
        color: #3b82f6;
        text-transform: uppercase;
        letter-spacing: .05em;
        margin-bottom: 4px;
    }

    .welcome-name {
        font-size: 24px;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 4px;
    }

    .welcome-sub {
        font-size: 14px;
        color: #64748b;
    }

    /* ===== Big Cards ===== */
    .beds-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }

    .big-card {
        background: white;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        padding: 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
    }

    .big-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 16px;
    }

    .big-card-label {
        font-size: 13px;
        color: #64748b;
        font-weight: 500;
        margin-bottom: 4px;
    }

    .big-card-count {
        font-size: 40px;
        font-weight: 800;
        color: #1e293b;
        line-height: 1;
    }

    .big-card-icon {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
    }

    .icon-green {
        background: #f0fdf4;
        color: #22c55e;
    }

    .icon-red {
        background: #fff1f2;
        color: #ef4444;
    }

    /* ===== Small Type Cards inside Big Card ===== */
    .type-cards-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .type-card {
        flex: 1;
        min-width: 70px;
        border-radius: 10px;
        padding: 10px 12px;
        text-align: center;
    }

    .type-card-avail {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
    }

    .type-card-occ {
        background: #fff1f2;
        border: 1px solid #fecaca;
    }

    .type-name {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-bottom: 4px;
    }

    .type-count {
        font-size: 22px;
        font-weight: 800;
    }

    .type-card-avail .type-name {
        color: #16a34a;
    }

    .type-card-avail .type-count {
        color: #16a34a;
    }

    .type-card-occ .type-name {
        color: #ef4444;
    }

    .type-card-occ .type-count {
        color: #ef4444;
    }

    /* Top Bar */
    .topbar-right {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .live-time {
        font-size: 14px;
        font-weight: 600;
        color: #1e293b;
    }

    .bell-btn {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #f1f5f9;
        border: none;
        cursor: pointer;
        color: #64748b;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .system-badge {
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #bbf7d0;
        font-size: 12px;
        padding: 5px 12px;
        border-radius: 20px;
        font-weight: 600;
    }
</style>


