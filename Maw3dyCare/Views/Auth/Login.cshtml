@model Maw3dyCare.ViewModels.AdminLoginVM
@{
    
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Maw3dyCare</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .login-box {
            background: white;
            border-radius: 20px;
            padding: 40px;
            width: 400px;
            max-width: 90vw;
            box-shadow: 0 20px 60px rgba(0,0,0,.3);
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 28px;
        }

        .brand-icon {
            width: 42px;
            height: 42px;
            background: #3b82f6;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 18px;
        }

        .brand-name {
            font-size: 18px;
            font-weight: 700;
            color: #1e293b;
        }

        .brand-sub {
            font-size: 11px;
            color: #94a3b8;
        }

        .page-title {
            font-size: 22px;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 6px;
        }

        .page-sub {
            font-size: 14px;
            color: #64748b;
            margin-bottom: 24px;
        }

        .form-field {
            margin-bottom: 16px;
        }

        .form-label {
            font-size: 13px;
            font-weight: 600;
            color: #374151;
            display: block;
            margin-bottom: 6px;
        }

        .input-wrap {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 14px;
        }

        .form-input {
            width: 100%;
            padding: 11px 14px 11px 40px;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            font-size: 14px;
            color: #1e293b;
            outline: none;
            transition: border-color .2s;
        }

            .form-input:focus {
                border-color: #3b82f6;
            }

        .field-error {
            font-size: 12px;
            color: #ef4444;
            margin-top: 4px;
        }

        .alert-error {
            background: #fff1f2;
            border: 1px solid #fecaca;
            border-radius: 10px;
            padding: 12px 16px;
            color: #ef4444;
            font-size: 13px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .remember-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 20px;
            font-size: 13px;
            color: #64748b;
        }

        .btn-login {
            width: 100%;
            padding: 12px;
            background: #3b82f6;
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: background .2s;
            margin-bottom: 16px;
        }

            .btn-login:hover {
                background: #2563eb;
            }

        .register-link {
            text-align: center;
            font-size: 13px;
            color: #64748b;
        }

            .register-link a {
                color: #3b82f6;
                font-weight: 600;
                text-decoration: none;
            }

                .register-link a:hover {
                    text-decoration: underline;
                }
    </style>
</head>
<body>

    <div class="login-box">

        <div class="brand">
            <div class="brand-icon"><i class="fas fa-heart-pulse"></i></div>
            <div>
                <div class="brand-name">Maw3dyCare</div>
                <div class="brand-sub">ADMIN CONSOLE</div>
            </div>
        </div>

        <div class="page-title">Welcome back</div>
        <div class="page-sub">Sign in to your admin account</div>

        @if (!ViewData.ModelState.IsValid &&
                ViewData.ModelState.ContainsKey("") &&
                ViewData.ModelState[""]?.Errors.Count > 0)
        {
            <div class="alert-error">
                <i class="fas fa-exclamation-circle"></i>
                @ViewData.ModelState[""]?.Errors[0].ErrorMessage
            </div>
        }

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <div class="form-field">
                <label class="form-label">Email Address</label>
                <div class="input-wrap">
                    <i class="fas fa-envelope input-icon"></i>
                    <input asp-for="Email" class="form-input"
                           placeholder="admin@maw3dycare.com" />
                </div>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="form-field">
                <label class="form-label">Password</label>
                <div class="input-wrap">
                    <i class="fas fa-lock input-icon"></i>
                    <input asp-for="Password" type="password"
                           class="form-input" placeholder="••••••••" />
                </div>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="remember-row">
                <input asp-for="RememberMe" type="checkbox" id="rememberMe" />
                <label for="rememberMe">Remember me</label>
            </div>

            <button type="submit" class="btn-login">
                <i class="fas fa-sign-in-alt"></i> Sign In
            </button>
        </form>

        <div class="register-link">
            Don't have an account?
            <a href="/Auth/Register">Create account</a>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>