@model Maw3dyCare.ViewModels.CreateHospitalAccountVM
@{
    // صفحة إنشاء حساب للمستشفى بعد ما اتضافت
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 50;
    }

    .modal-box {
        background: white;
        border-radius: 20px;
        padding: 32px;
        width: 420px;
        max-width: 90vw;
        box-shadow: 0 20px 60px rgba(0,0,0,.15);
        position: relative;
    }

    .modal-icon {
        width: 56px;
        height: 56px;
        background: #eff6ff;
        border-radius: 50%;
        margin: 0 auto 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #3b82f6;
        font-size: 24px;
    }

    .modal-title {
        font-size: 18px;
        font-weight: 700;
        color: #1e293b;
        text-align: center;
        margin-bottom: 6px;
    }

    .modal-sub {
        font-size: 13px;
        color: #64748b;
        text-align: center;
        margin-bottom: 24px;
    }

        .modal-sub span {
            font-weight: 700;
            color: #1e293b;
        }

    /* First Modal (Ask) */
    .ask-btns {
        display: flex;
        gap: 12px;
        margin-top: 4px;
    }

    .btn-skip {
        flex: 1;
        padding: 11px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
    }

        .btn-skip:hover {
            background: #f8fafc;
        }

    .btn-add-account {
        flex: 1;
        padding: 11px;
        border-radius: 10px;
        background: #3b82f6;
        color: white;
        border: none;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
    }

        .btn-add-account:hover {
            background: #2563eb;
        }

    /* Form Modal */
    .account-form {
        display: none;
    }

    .form-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 14px;
    }

    .form-label {
        font-size: 13px;
        font-weight: 600;
        color: #374151;
    }

    .form-input {
        padding: 10px 14px;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        font-size: 14px;
        color: #1e293b;
        outline: none;
        transition: border-color .2s;
    }

        .form-input:focus {
            border-color: #3b82f6;
        }

    .role-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #eff6ff;
        color: #3b82f6;
        padding: 6px 14px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
    }

    .validation-error {
        font-size: 12px;
        color: #ef4444;
    }

    /* Success Toast */
    .success-toast {
        display: none;
        position: fixed;
        top: 20px;
        right: 20px;
        background: white;
        border: 1px solid #bbf7d0;
        border-radius: 12px;
        padding: 14px 20px;
        display: flex;
        align-items: center;
        gap: 10px;
        box-shadow: 0 4px 20px rgba(0,0,0,.1);
        z-index: 200;
        font-size: 14px;
        font-weight: 600;
        color: #16a34a;
    }

        .success-toast i {
            font-size: 18px;
        }
</style>

@* Success Toast *@
@if (TempData["AccountSuccess"] != null)
{
    <div id="successToast" class="success-toast" style="display:flex">
        <i class="fas fa-check-circle"></i>
        @TempData["AccountSuccess"]
    </div>
}

@* ===== Modal الأول: اسأل الأدمن ===== *@
<div class="modal-overlay" id="askModal">
    <div class="modal-box">
        <div class="modal-icon"><i class="fas fa-user-plus"></i></div>
        <div class="modal-title">Do you want to create a hospital account?</div>
        <div class="modal-sub">
            You can link a login account to <span>@Model.HospitalName</span> now or skip it.
        </div>
        <div class="ask-btns">
            @* زرار Cancel - بيعمل Skip *@
            <form asp-action="SkipAccount" method="post" style="flex:1; margin:0">
                <button type="submit" class="btn-skip" style="width:100%">Cancel</button>
            </form>
            @* زرار Add Account - بيفتح فورم الحساب *@
            <button class="btn-add-account" onclick="showAccountForm()">
                Add Account
            </button>
        </div>
    </div>
</div>

@* ===== Modal التاني: فورم إنشاء الحساب ===== *@
<div class="modal-overlay account-form" id="accountModal">
    <div class="modal-box">
        <div class="modal-title" style="text-align:left; margin-bottom:4px">
            Create Hospital Account
        </div>
        <div class="modal-sub" style="text-align:left; margin-bottom:20px">
            Role will be assigned as
            <span class="role-badge"><i class="fas fa-hospital-alt"></i> Hospital</span>
        </div>

        <form asp-action="CreateHospitalAccount" method="post">
            @* Hidden Fields *@
            <input type="hidden" asp-for="HospitalId" />
            <input type="hidden" asp-for="HospitalName" />

            <!-- Full Name -->
            <div class="form-field">
                <label class="form-label">Full Name</label>
                <input asp-for="FullName" class="form-input"
                       placeholder="Receptionist name" />
                <span asp-validation-for="FullName" class="validation-error"></span>
            </div>

            <!-- Email (بيتملى تلقائي من إيميل المستشفى) -->
            <div class="form-field">
                <label class="form-label">Login Email</label>
                <input asp-for="Email" class="form-input"
                       placeholder="hospital@example.com" />
                <span asp-validation-for="Email" class="validation-error"></span>
            </div>

            <!-- Password -->
            <div class="form-field">
                <label class="form-label">Password</label>
                <input asp-for="Password" type="password" class="form-input"
                       placeholder="••••••••" />
                <span asp-validation-for="Password" class="validation-error"></span>
            </div>

            <!-- Confirm Password -->
            <div class="form-field">
                <label class="form-label">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-input"
                       placeholder="••••••••" />
                <span asp-validation-for="ConfirmPassword" class="validation-error"></span>
            </div>

            <!-- Role Badge -->
            <div style="margin-bottom:20px">
                <span class="role-badge"><i class="fas fa-shield-alt"></i> Role: Hospital</span>
            </div>

            <div style="display:flex; gap:12px;">
                <button type="button" class="btn-skip"
                        onclick="hideAccountForm()" style="flex:1">
                    Cancel
                </button>
                <button type="submit" class="btn-add-account" style="flex:1">
                    Create Account
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    // بيظهر فورم إنشاء الحساب ويخبي الـ Modal الأول
    function showAccountForm() {
        document.getElementById('askModal').style.display    = 'none';
        document.getElementById('accountModal').style.display = 'flex';
    }

    // بيرجع للـ Modal الأول
    function hideAccountForm() {
        document.getElementById('accountModal').style.display = 'none';
        document.getElementById('askModal').style.display    = 'flex';
    }

    // بيخبي الـ Success Toast بعد 3 ثواني
    window.onload = function() {
        const toast = document.getElementById('successToast');
        if (toast) setTimeout(() => toast.style.display = 'none', 3000);
    }
</script>