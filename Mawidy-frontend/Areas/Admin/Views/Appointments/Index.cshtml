@model AdminAppointmentListViewModel
@{ ViewData["Title"] = "الحجوزات"; ViewData["Page"] = "appointments"; }

<div class="page-toolbar">
    <div>
        <div class="page-title">📅 إدارة الحجوزات</div>
        <div class="page-sub">@Model.TotalCount حجز</div>
    </div>
</div>

<div class="dash-card" style="margin-bottom:16px">
    <form method="get" style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end">
        <div class="form-grp">
            <label>الحالة</label>
            <select name="FilterStatus" class="adm-select">
                <option value="">الكل</option>
                @if (Model.FilterStatus == "confirmed") {<option value="confirmed" selected>مؤكد</option>} else {<option value="confirmed">مؤكد</option>}
                @if (Model.FilterStatus == "pending")   {<option value="pending"   selected>انتظار</option>} else {<option value="pending">انتظار</option>}
                @if (Model.FilterStatus == "cancelled") {<option value="cancelled" selected>ملغي</option>} else {<option value="cancelled">ملغي</option>}
                @if (Model.FilterStatus == "completed") {<option value="completed" selected>مكتمل</option>} else {<option value="completed">مكتمل</option>}
            </select>
        </div>
        <div class="form-grp">
            <label>الشركة</label>
            <select name="FilterOp" class="adm-select">
                <option value="">الكل</option>
                @foreach (var op in Model.Operators)
                {
                    if (Model.FilterOp == op.Value) {<option value="@op.Value" selected>@op.Text</option>}
                    else {<option value="@op.Value">@op.Text</option>}
                }
            </select>
        </div>
        <div class="form-grp">
            <label>التاريخ</label>
            <input type="date" name="FilterDate" value="@Model.FilterDate" class="adm-input" />
        </div>
        <button type="submit" class="btn-primary">بحث</button>
        <a href="/admin/appointments" class="btn-ghost">مسح</a>
    </form>
</div>

<div class="dash-card">
    @if (!Model.Appointments.Any())
    {
        <div class="no-data">لا توجد حجوزات مطابقة</div>
    }
    else
    {
        <div class="table-wrap">
            <table class="admin-table">
                <thead>
                    <tr><th>#</th><th>العميل</th><th>الفرع</th><th>الخدمة</th><th>التاريخ</th><th>الوقت</th><th>الحالة</th><th>تغيير</th></tr>
                </thead>
                <tbody>
                    @foreach (var a in Model.Appointments)
                    {
                        <tr>
                            <td style="color:var(--muted);font-size:11px">#@a.Id</td>
                            <td>
                                <div style="font-weight:700;font-size:12px">@a.CustomerName</div>
                                <div style="font-size:10px;color:var(--muted)">@a.CustomerPhone</div>
                            </td>
                            <td>
                                <div style="display:flex;align-items:center;gap:5px">
                                    <div class="op-dot op-logo-@a.OperatorKey" style="background:@a.OperatorBg"></div>
                                    <span style="font-size:11px">@a.BranchName</span>
                                </div>
                            </td>
                            <td>@a.ServiceIcon <span style="font-size:11px">@a.ServiceName</span></td>
                            <td style="font-size:11px">@a.Date.ToString("dd/MM/yyyy")</td>
                            <td style="font-size:11px;font-weight:700">@a.Time</td>
                            <td><span class="status-badge @a.StatusClass">@a.StatusLabel</span></td>
                            <td>
                                <select class="adm-select-sm" onchange="updateStatus(@a.Id, this.value)">
                                    @if (a.StatusClass == "confirmed") {<option value="confirmed" selected>مؤكد</option>} else {<option value="confirmed">مؤكد</option>}
                                    @if (a.StatusClass == "pending")   {<option value="pending"   selected>انتظار</option>} else {<option value="pending">انتظار</option>}
                                    @if (a.StatusClass == "cancelled") {<option value="cancelled" selected>ملغي</option>} else {<option value="cancelled">ملغي</option>}
                                    @if (a.StatusClass == "completed") {<option value="completed" selected>مكتمل</option>} else {<option value="completed">مكتمل</option>}
                                </select>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model.TotalPages > 1)
        {
            <div class="pagination">
                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    <a href="?Page=@p&FilterStatus=@Model.FilterStatus&FilterOp=@Model.FilterOp&FilterDate=@Model.FilterDate"
                       class="pg-btn @(p == Model.Page ? "active" : "")">@p</a>
                }
            </div>
        }
    }
</div>

@section Scripts {
<script>
async function updateStatus(id, status) {
    await fetch(`/admin/appointments/updatestatus?id=${id}&status=${status}`, { method: 'POST' });
    showAdminToast('تم تحديث الحالة');
}
</script>
}
