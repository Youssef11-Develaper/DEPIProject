<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — لوحة الإدارة</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;900&family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>

<aside class="sidebar" id="sidebar">
    <div class="sb-logo">
        <div class="sb-logo-icon">📡</div>
        <div>
            <div class="sb-logo-title">مـوعـدي</div>
            <div class="sb-logo-sub">لوحة الإدارة</div>
        </div>
    </div>
    <nav class="sb-nav">
        <div class="sb-section">الرئيسية</div>
        <a class="sb-link @(ViewData["Page"]?.ToString() == "dashboard" ? "active" : "")" href="/admin">
            <span class="sb-icon">📊</span> الداشبورد
        </a>
        <div class="sb-section">إدارة البيانات</div>
        <a class="sb-link @(ViewData["Page"]?.ToString() == "branches" ? "active" : "")" href="/admin/branches">
            <span class="sb-icon">🏢</span> الفروع
        </a>
        <a class="sb-link @(ViewData["Page"]?.ToString() == "appointments" ? "active" : "")" href="/admin/appointments">
            <span class="sb-icon">📅</span> الحجوزات
        </a>
        <div class="sb-section">التحليلات</div>
        <a class="sb-link @(ViewData["Page"]?.ToString() == "reports" ? "active" : "")" href="/admin/reports">
            <span class="sb-icon">📈</span> التقارير
        </a>
        <div class="sb-section">أخرى</div>
        <a class="sb-link" href="/"><span class="sb-icon">🌐</span> الموقع العام</a>
    </nav>
    <div class="sb-footer">
        <div style="font-size:11px;color:rgba(255,255,255,.4)">Mawidy v3</div>
    </div>
</aside>

<div class="admin-main" id="adminMain">
    <header class="topbar">
        <button class="topbar-toggle" onclick="toggleSidebar()">☰</button>
        <div class="topbar-title">@ViewData["Title"]</div>
        <div class="topbar-right">
            <div class="topbar-date" id="topbarDate"></div>
            <a href="/" class="topbar-btn">🌐 الموقع العام</a>
        </div>
    </header>

    @if (TempData["Success"] != null)
    {
        <div class="admin-toast show" id="adminToast">
            @TempData["Success"]
            <button onclick="document.getElementById('adminToast').classList.remove('show')">✕</button>
        </div>
    }

    <main class="admin-content">
        @RenderBody()
    </main>
</div>

<script src="~/js/admin.js" asp-append-version="true"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
