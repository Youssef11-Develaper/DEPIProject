@model List<OperatorViewModel>
@{
    ViewData["Title"] = "مـوعـدي — أفرع الاتصالات";
    Layout = "_Layout";
}

<!-- HERO -->
<div class="home-hero">
    <div class="hc"></div><div class="hc"></div><div class="hc"></div>
    <div class="home-hero-inner">
        <div class="home-badge"><div class="hdot"></div> نظام حجز مواعيد الاتصالات</div>
        <h1 class="home-title">مـوعـدي</h1>
        <p class="home-sub">ابحث عن فرع، تحقق من الطابور واحجز موعدك في ثوانٍ</p>

        <!-- Stats -->
        <div class="home-stats">
            <div class="home-stat"><span class="home-stat-num">@Model.Count</span><span class="home-stat-lbl">شركات اتصالات</span></div>
            <div class="home-stat-div"></div>
            <div class="home-stat"><span class="home-stat-num">27</span><span class="home-stat-lbl">محافظة</span></div>
            <div class="home-stat-div"></div>
            <div class="home-stat"><span class="home-stat-num">105</span><span class="home-stat-lbl">مركز وحي</span></div>
            <div class="home-stat-div"></div>
            <div class="home-stat"><span class="home-stat-num">24/7</span><span class="home-stat-lbl">حجز إلكتروني</span></div>
        </div>
    </div>
</div>

<!-- OPERATOR SELECTION -->
<div class="home-main">
    <div class="home-section-title">اختر شركة الاتصالات</div>
    <div class="home-section-sub">اختر الشركة لعرض فروعها وحجز موعدك</div>

    <div class="op-cards-grid">
        @foreach (var op in Model)
        {
            <a href="@Url.Action("Index","Branch", new { OperatorKey = op.Key })"
               class="op-card">
                <!-- Logo -->
                <div class="op-card-logo op-logo-@op.Key" style="background:@op.BgColor"></div>

                <!-- Info -->
                <div class="op-card-name" style="color:@op.Color">@op.NameAr</div>
                <div class="op-card-hotline">خدمة عملاء الشركه: @op.Hotline</div>

                <!-- Arrow -->
                <div class="op-card-arrow" style="background:@op.Color">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
                        <path d="M15 18l-6-6 6-6"/>
                    </svg>
                </div>
            </a>
        }
    </div>

    <!-- All Branches Link -->
    <div style="text-align:center;margin-top:32px">
        <a href="@Url.Action("Index","Branch")" class="home-all-btn">
            🏢 عرض كل الفروع
        </a>
        <a href="/admin" class="home-admin-btn">
            📊 لوحة الإدارة
        </a>
    </div>

    <!-- Features -->
    <div class="home-features">
        <div class="home-feature">
            <div class="hf-icon">📍</div>
            <div class="hf-title">أقرب فرع إليك</div>
            <div class="hf-sub">ابحث بالمحافظة أو المركز</div>
        </div>
        <div class="home-feature">
            <div class="hf-icon">🔢</div>
            <div class="hf-title">حالة الطابور مباشرة</div>
            <div class="hf-sub">تعرف وقت الانتظار قبل ما تروح</div>
        </div>
        <div class="home-feature">
            <div class="hf-icon">📅</div>
            <div class="hf-title">احجز موعدك</div>
            <div class="hf-sub">اختار اليوم والوقت المناسب ليك</div>
        </div>
        <div class="home-feature">
            <div class="hf-icon">📋</div>
            <div class="hf-title">الأوراق المطلوبة</div>
            <div class="hf-sub">اعرف كل المستندات قبل ما تيجي</div>
        </div>
    </div>
</div>
