@inject Mawidy.Application.Banks.Services.LocalizationService Localizer
@inject Mawidy.Infrastructure.Persistence.AppDbContext DbContext
@{
    var culture = Localizer.GetCurrentCulture();
    var isRtl = culture == "ar";
    
    // Retrieve authenticated user info from ViewBag (set by BaseController)
    var currentUser = ViewBag.CurrentUser as Mawidy.Domain.Entities.ApplicationUser;
    var isEmployee = (ViewBag.IsBankEmployee as bool? ?? false) || (currentUser != null && currentUser.IsBankEmployee);
    var currentUserId = currentUser?.Id ?? "1";
}
<!DOCTYPE html>
<html lang="@culture" dir="@(isRtl ? "rtl" : "ltr")" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @Localizer.T("common.appName")</title>
    
    <!-- Tailwind compiled stylesheet -->
    <link rel="stylesheet" href="~/banks/css/style.css" asp-append-version="true" />
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="min-h-screen flex flex-col bg-background text-foreground antialiased font-sans">
    <header class="sticky top-0 z-40 w-full border-b border-border/60 glass">
        <div class="container mx-auto px-4 md:px-8 flex h-16 items-center justify-between gap-4">
            <!-- Logo -->
            <a asp-area="Banks" asp-controller="Home" asp-action="Index" class="flex items-center gap-2.5 group" aria-label="@Localizer.T("common.appName")">
                <span class="relative inline-flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-accent shadow-glow">
                    <span class="absolute inset-0 rounded-xl bg-gradient-accent opacity-0 group-hover:opacity-100 blur-md transition-opacity"></span>
                    <svg viewBox="0 0 24 24" class="relative h-5 w-5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 21h18"></path>
                        <path d="M5 21V10l7-5 7 5v11"></path>
                        <path d="M9 21v-7h6v7"></path>
                    </svg>
                </span>
                <span class="font-semibold tracking-tight text-base text-foreground">@Localizer.T("common.appName")</span>
            </a>

            <!-- Desktop Nav elements (hidden on mobile, visible on larger screens) -->
            <nav class="desktop-nav">
                <!-- Language Switcher -->
                <a asp-area="Banks" asp-controller="Home" asp-action="SetLanguage" asp-route-culture="@(isRtl ? "en" : "ar")" 
                   class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-sm font-medium transition-colors hover:bg-muted text-muted-foreground hover:text-foreground"
                   title="@(isRtl ? "English" : "العربية")">
                    <i data-lucide="languages" class="h-4 w-4 shrink-0"></i>
                    <span>@(isRtl ? "English" : "العربية")</span>
                </a>

                @if (currentUser != null)
                {
                    <!-- Logged-in User Badge (links to profile) -->
                    <a asp-area="Banks" asp-controller="Dashboard" asp-action="Profile" 
                       class="inline-flex items-center gap-2 px-3 py-1.5 rounded-xl bg-card border border-border/60 hover:border-accent/40 shadow-soft hover:shadow-md transition-all"
                       title="@Localizer.T("common.profile")">
                        <div class="h-6 w-6 rounded-full bg-gradient-accent flex items-center justify-center text-white text-2xs font-bold shadow-soft shrink-0">
                            @(!string.IsNullOrEmpty(currentUser.FirstName) ? currentUser.FirstName.Substring(0, 1).ToUpper() : "U")
                        </div>
                        <div class="text-start">
                            <div class="text-xs font-bold text-foreground max-w-[120px] truncate">@currentUser.FirstName</div>
                        </div>
                    </a>
                }
                else
                {
                    <!-- Sign In Button → opens shared Mawidy modal -->
                    <button onclick="showMawidyAuthModal()"
                       class="inline-flex items-center gap-2 px-3 py-1.5 rounded-xl text-sm font-medium transition-colors bg-muted hover:bg-muted/80 text-muted-foreground hover:text-foreground">
                        <i data-lucide="log-in" class="h-4 w-4 shrink-0"></i>
                        <span>@Localizer.T("common.signIn")</span>
                    </button>
                }

                @if (currentUser != null)
                {
                    @if (isEmployee)
                    {
                        <!-- Employee Portal link (Employee only) -->
                        <a asp-area="Banks" asp-controller="Employee" asp-action="Index" 
                           class="inline-flex items-center gap-2 px-3 py-1.5 rounded-xl text-sm font-medium transition-colors hover:bg-muted text-muted-foreground hover:text-foreground">
                            <i data-lucide="shield" class="h-4 w-4 shrink-0"></i>
                            <span>@Localizer.T("employee.portal")</span>
                        </a>
                    }
                    else
                    {
                        <!-- Appointments link (Customer only) -->
                        <a asp-area="Banks" asp-controller="Dashboard" asp-action="Index" 
                           class="inline-flex items-center gap-2 px-3 py-1.5 rounded-xl text-sm font-medium transition-colors hover:bg-muted text-muted-foreground hover:text-foreground">
                            <i data-lucide="calendar" class="h-4 w-4 shrink-0"></i>
                            <span>@Localizer.T("common.appointments")</span>
                        </a>
                    }

                    <!-- Sign Out link (Shared) -->
                    <a href="javascript:void(0)" onclick="handleMawidyLogout()" 
                       class="inline-flex items-center gap-2 px-3 py-1.5 rounded-xl text-sm font-medium transition-colors hover:bg-muted text-muted-foreground hover:text-foreground">
                        <i data-lucide="log-out" class="h-4 w-4 shrink-0"></i>
                        <span>@Localizer.T("common.signOut")</span>
                    </a>

                    @if (!isEmployee)
                    {
                        <!-- Book link (Customer only) -->
                        <a asp-area="Banks" asp-controller="Booking" asp-action="Index" 
                           class="inline-flex items-center gap-2.5 px-4 py-1.5 bg-gradient-accent hover:opacity-95 text-white rounded-xl text-sm font-medium transition-all shadow-soft">
                            <i data-lucide="plus" class="h-4 w-4 shrink-0"></i>
                            <span>@Localizer.T("common.bookAppointment")</span>
                        </a>
                    }
                }
            </nav>

            <!-- Mobile menu controls (visible only on mobile) -->
            <div class="mobile-nav-controls">
                <!-- Language Switcher -->
                <a asp-area="Banks" asp-controller="Home" asp-action="SetLanguage" asp-route-culture="@(isRtl ? "en" : "ar")" 
                   class="inline-flex items-center gap-1 px-2 py-1.5 rounded-xl text-sm font-medium transition-colors hover:bg-muted text-muted-foreground hover:text-foreground"
                   title="@(isRtl ? "English" : "العربية")">
                    <i data-lucide="languages" class="h-4 w-4 shrink-0"></i>
                    <span class="text-xs font-bold">@(isRtl ? "EN" : "AR")</span>
                </a>

                <!-- Hamburger button -->
                <button id="mobile-menu-toggle" type="button" class="inline-flex items-center justify-center p-2 rounded-xl text-muted-foreground hover:text-foreground hover:bg-muted transition-colors focus:outline-none" aria-label="Toggle menu">
                    <svg id="menu-icon-open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                    <svg id="menu-icon-close" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>

        <!-- Mobile Menu panel (hidden by default) -->
        <div id="mobile-menu-panel" class="hidden absolute top-16 left-0 right-0 w-full bg-card border-b border-border/80 p-4 shadow-elegant z-50 animate-scale-in flex flex-col gap-3">
            @if (currentUser != null)
            {
                <!-- User Profile Link Card -->
                <a asp-area="Banks" asp-controller="Dashboard" asp-action="Profile" class="flex items-center gap-3 p-3 rounded-2xl bg-muted/50 border border-border/40 hover:border-accent/40 transition-all">
                    <div class="h-9 w-9 rounded-full bg-gradient-accent flex items-center justify-center text-white font-bold shadow-soft">
                        @(!string.IsNullOrEmpty(currentUser.FirstName) ? currentUser.FirstName.Substring(0, 1).ToUpper() : "U")
                    </div>
                    <div class="text-start">
                        <div class="text-sm font-bold text-foreground">@currentUser.FirstName</div>
                        <div class="text-2xs text-muted-foreground">@Localizer.T("common.profile")</div>
                    </div>
                </a>
            }
            else
            {
                <!-- Sign In Button → opens shared Mawidy modal -->
                <button onclick="showMawidyAuthModal()"
                   class="flex items-center gap-3 p-3 rounded-2xl bg-muted/50 border border-border/40 hover:bg-muted transition-all text-sm font-medium text-foreground w-full text-start">
                    <i data-lucide="log-in" class="h-5 w-5 text-accent"></i>
                    <span>@Localizer.T("common.signIn")</span>
                </button>
            }

            <nav class="flex flex-col gap-1">
                @if (currentUser != null)
                {
                    @if (isEmployee)
                    {
                        <!-- Employee Portal link -->
                        <a asp-area="Banks" asp-controller="Employee" asp-action="Index" 
                           class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-muted text-sm font-medium text-muted-foreground hover:text-foreground transition-all">
                            <i data-lucide="shield" class="h-5 w-5"></i>
                            <span>@Localizer.T("employee.portal")</span>
                        </a>
                    }
                    else
                    {
                        <!-- Appointments link -->
                        <a asp-area="Banks" asp-controller="Dashboard" asp-action="Index" 
                           class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-muted text-sm font-medium text-muted-foreground hover:text-foreground transition-all">
                            <i data-lucide="calendar" class="h-5 w-5"></i>
                            <span>@Localizer.T("common.appointments")</span>
                        </a>
                    }

                    @if (!isEmployee)
                    {
                        <!-- Book link -->
                        <a asp-area="Banks" asp-controller="Booking" asp-action="Index" 
                           class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-muted text-sm font-medium text-muted-foreground hover:text-foreground transition-all">
                            <i data-lucide="plus" class="h-5 w-5"></i>
                            <span>@Localizer.T("common.bookAppointment")</span>
                        </a>
                    }

                    <!-- Sign Out link -->
                    <a href="javascript:void(0)" onclick="handleMawidyLogout()" 
                       class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-rose-500/10 text-sm font-medium text-muted-foreground hover:text-rose-600 transition-all border-t border-border/40 mt-2 pt-3">
                        <i data-lucide="log-out" class="h-5 w-5"></i>
                        <span>@Localizer.T("common.signOut")</span>
                    </a>
                }
            </nav>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const toggleBtn = document.getElementById('mobile-menu-toggle');
                const menuPanel = document.getElementById('mobile-menu-panel');
                const openIcon = document.getElementById('menu-icon-open');
                const closeIcon = document.getElementById('menu-icon-close');

                if (toggleBtn && menuPanel) {
                    toggleBtn.addEventListener('click', function () {
                        const isHidden = menuPanel.classList.contains('hidden');
                        if (isHidden) {
                            menuPanel.classList.remove('hidden');
                            openIcon.classList.add('hidden');
                            closeIcon.classList.remove('hidden');
                        } else {
                            menuPanel.classList.add('hidden');
                            openIcon.classList.remove('hidden');
                            closeIcon.classList.add('hidden');
                        }
                    });
                }
            });
        </script>
    </header>

    <div class="flex-1 flex flex-col">
        @RenderBody()
    </div>

    <footer class="border-t border-border/60 py-8 bg-card">
        <div class="container mx-auto px-4 md:px-8 text-center text-xs text-muted-foreground">
            © @DateTime.Now.Year @Localizer.T("common.appName") · @Localizer.T("common.tagline")
        </div>
    </footer>

    <!-- Initialize Lucide Icons -->
    <script>
        lucide.createIcons();
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- ══ SHARED MAWIDY AUTH MODAL ══════════════════════════════════════ -->
    <div id="mawidyAuthOverlay" style="display:none;position:fixed;inset:0;background:rgba(11,31,58,.72);backdrop-filter:blur(6px);z-index:99000;align-items:center;justify-content:center">
        <div style="background:white;border-radius:20px;width:100%;max-width:460px;max-height:92vh;overflow-y:auto;box-shadow:0 40px 100px rgba(0,0,0,.35);animation:mawidyPop .35s cubic-bezier(.34,1.56,.64,1)">
            <div style="background:linear-gradient(135deg,#0B1F3A 0%,#3b1078 60%,#7B1FA2 100%);padding:24px;border-radius:20px 20px 0 0;display:flex;align-items:center;justify-content:space-between">
                <div style="font-family:'Cairo',sans-serif;font-size:18px;font-weight:800;color:white">🔐 منصة موعدي — تسجيل الدخول</div>
                <button onclick="closeMawidyAuthModal()" style="width:32px;height:32px;border-radius:8px;border:none;background:rgba(255,255,255,.15);color:white;font-size:16px;cursor:pointer">✕</button>
            </div>
            <div style="padding:24px">
                <div style="display:flex;border-radius:10px;overflow:hidden;border:2px solid #E2E8F0;margin-bottom:22px">
                    <button id="mwTabLogin" onclick="switchMwTab('login')" style="flex:1;padding:11px;font-weight:700;cursor:pointer;background:#7B1FA2;color:white;border:none;font-family:'Tajawal',sans-serif;font-size:14px">تسجيل الدخول</button>
                    <button id="mwTabReg" onclick="switchMwTab('register')" style="flex:1;padding:11px;font-weight:700;cursor:pointer;background:white;color:#6B7A99;border:none;font-family:'Tajawal',sans-serif;font-size:14px">إنشاء حساب</button>
                </div>
                <div id="mwLoginForm">
                    <div style="margin-bottom:14px"><label style="display:block;font-size:12px;font-weight:700;color:#0B1F3A;margin-bottom:5px">البريد الإلكتروني</label><input type="email" id="mwEmail" placeholder="example@email.com" style="width:100%;padding:11px 14px;border-radius:10px;border:2px solid #E2E8F0;font-family:'Tajawal',sans-serif;font-size:14px;outline:none;direction:rtl" /></div>
                    <div style="margin-bottom:14px"><label style="display:block;font-size:12px;font-weight:700;color:#0B1F3A;margin-bottom:5px">كلمة المرور</label><input type="password" id="mwPass" placeholder="كلمة المرور" style="width:100%;padding:11px 14px;border-radius:10px;border:2px solid #E2E8F0;font-family:'Tajawal',sans-serif;font-size:14px;outline:none;direction:rtl" /></div>
                    <button onclick="doMwLogin(this)" style="width:100%;padding:13px;border-radius:11px;border:none;cursor:pointer;background:linear-gradient(135deg,#7B1FA2,#1565C0);color:white;font-family:'Tajawal',sans-serif;font-size:15px;font-weight:700">🔑 تسجيل الدخول</button>
                </div>
                <div id="mwRegForm" style="display:none">
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">
                        <div><label style="display:block;font-size:12px;font-weight:700;color:#0B1F3A;margin-bottom:5px">الاسم الأول</label><input type="text" id="mwFirst" placeholder="الاسم الأول" style="width:100%;padding:11px 14px;border-radius:10px;border:2px solid #E2E8F0;font-family:'Tajawal',sans-serif;font-size:14px;outline:none;direction:rtl" /></div>
                        <div><label style="display:block;font-size:12px;font-weight:700;color:#0B1F3A;margin-bottom:5px">اسم العائلة</label><input type="text" id="mwLast" placeholder="اسم العائلة" style="width:100%;padding:11px 14px;border-radius:10px;border:2px solid #E2E8F0;font-family:'Tajawal',sans-serif;font-size:14px;outline:none;direction:rtl" /></div>
                    </div>
                    <div style="margin-bottom:14px"><label style="display:block;font-size:12px;font-weight:700;color:#0B1F3A;margin-bottom:5px">البريد الإلكتروني</label><input type="email" id="mwRegEmail" placeholder="example@email.com" style="width:100%;padding:11px 14px;border-radius:10px;border:2px solid #E2E8F0;font-family:'Tajawal',sans-serif;font-size:14px;outline:none;direction:rtl" /></div>
                    <div style="margin-bottom:14px"><label style="display:block;font-size:12px;font-weight:700;color:#0B1F3A;margin-bottom:5px">رقم الهاتف</label><input type="tel" id="mwPhone" placeholder="01xxxxxxxxx" style="width:100%;padding:11px 14px;border-radius:10px;border:2px solid #E2E8F0;font-family:'Tajawal',sans-serif;font-size:14px;outline:none;direction:rtl" /></div>
                    <div style="margin-bottom:14px"><label style="display:block;font-size:12px;font-weight:700;color:#0B1F3A;margin-bottom:5px">الرقم القومي</label><input type="text" id="mwNid" placeholder="14 رقم" maxlength="14" style="width:100%;padding:11px 14px;border-radius:10px;border:2px solid #E2E8F0;font-family:'Tajawal',sans-serif;font-size:14px;outline:none;direction:rtl" /></div>
                    <div style="margin-bottom:14px"><label style="display:block;font-size:12px;font-weight:700;color:#0B1F3A;margin-bottom:5px">تاريخ الميلاد</label><input type="date" id="mwDob" style="width:100%;padding:11px 14px;border-radius:10px;border:2px solid #E2E8F0;font-family:'Tajawal',sans-serif;font-size:14px;outline:none" /></div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">
                        <div><label style="display:block;font-size:12px;font-weight:700;color:#0B1F3A;margin-bottom:5px">كلمة المرور</label><input type="password" id="mwRegPass" placeholder="8 أحرف" style="width:100%;padding:11px 14px;border-radius:10px;border:2px solid #E2E8F0;font-family:'Tajawal',sans-serif;font-size:14px;outline:none;direction:rtl" /></div>
                        <div><label style="display:block;font-size:12px;font-weight:700;color:#0B1F3A;margin-bottom:5px">تأكيد</label><input type="password" id="mwRegPassC" placeholder="أعد الكتابة" style="width:100%;padding:11px 14px;border-radius:10px;border:2px solid #E2E8F0;font-family:'Tajawal',sans-serif;font-size:14px;outline:none;direction:rtl" /></div>
                    </div>
                    <button onclick="doMwRegister(this)" style="width:100%;padding:13px;border-radius:11px;border:none;cursor:pointer;background:linear-gradient(135deg,#7B1FA2,#1565C0);color:white;font-family:'Tajawal',sans-serif;font-size:15px;font-weight:700">👤 إنشاء الحساب</button>
                </div>
            </div>
        </div>
    </div>
    <style>@@keyframes mawidyPop{from{opacity:0;transform:translateY(30px) scale(.96)}to{opacity:1;transform:translateY(0) scale(1)}}</style>
    <script>
    const _MW_API = 'http://localhost:5154/api';
    function showMawidyAuthModal(){document.getElementById('mawidyAuthOverlay').style.display='flex';}
    function closeMawidyAuthModal(){document.getElementById('mawidyAuthOverlay').style.display='none';}
    function switchMwTab(t){
        document.getElementById('mwTabLogin').style.background=t==='login'?'#7B1FA2':'white';
        document.getElementById('mwTabLogin').style.color=t==='login'?'white':'#6B7A99';
        document.getElementById('mwTabReg').style.background=t==='register'?'#7B1FA2':'white';
        document.getElementById('mwTabReg').style.color=t==='register'?'white':'#6B7A99';
        document.getElementById('mwLoginForm').style.display=t==='login'?'block':'none';
        document.getElementById('mwRegForm').style.display=t==='register'?'block':'none';
    }
    async function doMwLogin(btn){
        const email=document.getElementById('mwEmail').value.trim();
        const password=document.getElementById('mwPass').value;
        if(!email||!password){alert('ادخل البيانات المطلوبة');return;}
        const orig=btn.innerHTML;btn.disabled=true;btn.innerHTML='⏳ جاري الدخول...';
        try{
            const res=await fetch(`${_MW_API}/auth/login`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email,password})});
            const data=await res.json();
            if(!res.ok)throw new Error(data.message||'خطأ في تسجيل الدخول');
            localStorage.setItem('token',data.data.token);
            localStorage.setItem('user',JSON.stringify(data.data));
            closeMawidyAuthModal();
            location.reload();
        }catch(err){alert(err.message);}
        finally{btn.disabled=false;btn.innerHTML=orig;}
    }
    async function doMwRegister(btn){
        const pass=document.getElementById('mwRegPass').value;
        const passC=document.getElementById('mwRegPassC').value;
        if(pass!==passC){alert('كلمة المرور غير متطابقة');return;}
        const orig=btn.innerHTML;btn.disabled=true;btn.innerHTML='⏳ جاري الإنشاء...';
        try{
            const res=await fetch(`${_MW_API}/auth/register`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({firstName:document.getElementById('mwFirst').value,lastName:document.getElementById('mwLast').value,email:document.getElementById('mwRegEmail').value,phoneNumber:document.getElementById('mwPhone').value,nationalId:document.getElementById('mwNid').value,dateOfBirth:document.getElementById('mwDob').value,password:pass,confirmPassword:passC})});
            const data=await res.json();
            if(!res.ok)throw new Error(data.message||'خطأ في إنشاء الحساب');
            alert('تم إنشاء الحساب ✅ — تحقق من إيميلك');
            switchMwTab('login');
        }catch(err){alert(err.message);}
        finally{btn.disabled=false;btn.innerHTML=orig;}
    }
    function handleMawidyLogout() {
        localStorage.removeItem('token');
        localStorage.removeItem('user');
        window.location.href = '@Url.Action("Logout", "Home", new { area = "Banks" })';
    }
    document.getElementById('mawidyAuthOverlay').addEventListener('click',function(e){if(e.target===this)closeMawidyAuthModal();});
    </script>
</body>
</html>










