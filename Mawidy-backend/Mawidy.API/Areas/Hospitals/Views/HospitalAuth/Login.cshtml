@model Mawidy.Application.Hospitals.ViewModels.HospitalLoginVM
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hospital Login — Maw3dyCare</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #0c1a2e 0%, #1a3a5c 100%);
            display: flex; align-items: center; justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }
        .login-box {
            background: white; border-radius: 20px;
            padding: 40px; width: 400px; max-width: 90vw;
            box-shadow: 0 24px 64px rgba(0,0,0,.3);
        }
        .brand { display:flex; align-items:center; gap:12px; margin-bottom:28px; }
        .brand-icon {
            width: 44px; height: 44px;
            background: linear-gradient(135deg, #3b82f6, #1d4ed8);
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 20px;
        }
        .brand-name { font-size: 18px; font-weight: 700; color: #1e293b; }
        .brand-sub  { font-size: 11px; color: #94a3b8; letter-spacing: .05em; }
        .page-title { font-size: 22px; font-weight: 700; color: #1e293b; margin-bottom: 6px; }
        .page-sub   { font-size: 14px; color: #64748b; margin-bottom: 24px; }
        .form-field { margin-bottom: 16px; }
        .form-label { font-size: 13px; font-weight: 600; color: #374151; display: block; margin-bottom: 6px; }
        .input-wrap { position: relative; }
        .input-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 14px; }
        .form-input {
            width: 100%; padding: 11px 14px 11px 42px;
            border: 1.5px solid #e2e8f0; border-radius: 10px;
            font-size: 14px; color: #1e293b; outline: none;
            transition: border-color .2s, box-shadow .2s;
        }
        .form-input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,.1);
        }
        .field-error { font-size: 12px; color: #ef4444; margin-top: 4px; display: block; }
        .alert-error {
            background: #fff1f2; border: 1px solid #fecaca;
            border-radius: 10px; padding: 12px 16px;
            color: #ef4444; font-size: 13px;
            display: flex; align-items: center; gap: 8px;
            margin-bottom: 16px;
        }
        .btn-login {
            width: 100%; padding: 13px;
            background: linear-gradient(135deg, #3b82f6, #1d4ed8);
            color: white; border: none; border-radius: 10px;
            font-size: 15px; font-weight: 600;
            cursor: pointer; transition: opacity .2s;
            margin-top: 4px;
        }
        .btn-login:hover { opacity: .9; }
        .divider {
            text-align: center; margin: 20px 0;
            font-size: 12px; color: #94a3b8;
        }
        .hospital-note {
            background: #f8fafc; border: 1px solid #e2e8f0;
            border-radius: 10px; padding: 12px 14px;
            font-size: 12px; color: #64748b;
            display: flex; align-items: flex-start; gap: 8px;
        }
        .hospital-note i { color: #3b82f6; margin-top: 1px; }
    </style>
</head>
<body>

<div class="login-box">

    <div class="brand">
        <div class="brand-icon"><i class="fas fa-heart-pulse"></i></div>
        <div>
            <div class="brand-name">Maw3dyCare</div>
            <div class="brand-sub">HOSPITAL PORTAL</div>
        </div>
    </div>

    <div class="page-title">Hospital Sign In</div>
    <div class="page-sub">Use your hospital account credentials</div>

    @if (ViewData.ModelState[""]?.Errors.Count > 0)
    {
        <div class="alert-error">
            <i class="fas fa-exclamation-circle"></i>
            @ViewData.ModelState[""]?.Errors[0].ErrorMessage
        </div>
    }

    <form asp-area="Hospitals" asp-controller="HospitalAuth" asp-action="Login" method="post">
        @Html.AntiForgeryToken()

        <div class="form-field">
            <label class="form-label">Email Address</label>
            <div class="input-wrap">
                <i class="fas fa-envelope input-icon"></i>
                <input asp-for="Email" class="form-input"
                       placeholder="hospital@example.com" autocomplete="email" />
            </div>
            <span asp-validation-for="Email" class="field-error"></span>
        </div>

        <div class="form-field">
            <label class="form-label">Password</label>
            <div class="input-wrap">
                <i class="fas fa-lock input-icon"></i>
                <input asp-for="Password" type="password"
                       class="form-input" placeholder="••••••••" />
            </div>
            <span asp-validation-for="Password" class="field-error"></span>
        </div>

        <button type="submit" class="btn-login">
            <i class="fas fa-sign-in-alt"></i> Sign In
        </button>
    </form>

    <div class="divider">-----------------</div>

    <div class="hospital-note">
        <i class="fas fa-info-circle"></i>
        <span>
            Hospital accounts are created by the system administrator.
            Contact your admin if you don't have access.
        </span>
    </div>

</div>

</body>
</html>



