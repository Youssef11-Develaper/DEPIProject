<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Maw3dyCare Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f0f4f8;
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 240px;
            background: #0f172a;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            z-index: 100;
        }

        .sidebar-brand {
            padding: 24px 20px;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

            .sidebar-brand .brand-icon {
                width: 38px;
                height: 38px;
                background: #3b82f6;
                border-radius: 10px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-weight: bold;
                font-size: 16px;
                margin-right: 10px;
            }

            .sidebar-brand .brand-name {
                color: white;
                font-weight: 700;
                font-size: 15px;
            }

            .sidebar-brand .brand-sub {
                color: rgba(255,255,255,0.4);
                font-size: 11px;
                display: block;
                margin-left: 48px;
            }

        .sidebar-nav {
            padding: 20px 12px;
            flex: 1;
        }

        .nav-item {
            list-style: none;
            margin-bottom: 4px;
        }

        .nav-link-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 14px;
            border-radius: 10px;
            color: rgba(255,255,255,0.55);
            text-decoration: none;
            font-size: 14px;
            transition: all 0.2s;
        }

            .nav-link-item:hover {
                background: rgba(59,130,246,0.15);
                color: #fff;
            }

            .nav-link-item.active {
                background: #3b82f6;
                color: #fff;
            }

            .nav-link-item i {
                width: 18px;
                text-align: center;
            }

        .nav-badge {
            margin-left: auto;
            font-size: 11px;
            font-weight: 700;
            padding: 2px 7px;
            border-radius: 10px;
            min-width: 20px;
            text-align: center;
        }

        .sidebar-footer {
            padding: 16px 12px;
            border-top: 1px solid rgba(255,255,255,0.08);
        }

        .main-content {
            margin-left: 240px;
            flex: 1;
            padding: 32px;
        }
    </style>
</head>
<body>

    <aside class="sidebar">

        <div class="sidebar-brand">
            <span class="brand-icon">M</span>
            <span class="brand-name">Maw3dyCare</span>
            <span class="brand-sub">ADMIN CONSOLE</span>
        </div>

        <nav class="sidebar-nav">
            <ul style="padding:0; margin:0;">

                <li class="nav-item">
                    <a href="/Hospitals/Maw3dyCare/Index"
                       class="nav-link-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" && ViewContext.RouteData.Values["controller"]?.ToString() == "Maw3dyCare" ? "active" : "")">
                        <i class="fas fa-th-large"></i> Home
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Hospitals/Maw3dyCare/HospitalsList"
                       class="nav-link-item @(ViewContext.RouteData.Values["action"]?.ToString() == "HospitalsList" ? "active" : "")">
                        <i class="fas fa-hospital"></i> Hospitals
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Hospitals/Maw3dyCare/AddHospital"
                       class="nav-link-item @(ViewContext.RouteData.Values["action"]?.ToString() == "AddHospital" ? "active" : "")">
                        <i class="fas fa-plus-circle"></i> Add Hospital
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Hospitals/Maw3dyCare/Accounts"
                       class="nav-link-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Accounts" ? "active" : "")">
                        <i class="fas fa-user-circle"></i> Accounts
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Hospitals/Maw3dyCare/Settings"
                       class="nav-link-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Settings" ? "active" : "")">
                        <i class="fas fa-cog"></i> Settings
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Hospitals/Maw3dyCare/Reports"
                       class="nav-link-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Reports" ? "active" : "")"
                       style="color:#ef4444;">
                        <i class="fas fa-flag"></i> Reports
                        <span id="reportsBadge" class="nav-badge"
                              style="background:#ef4444; color:white; display:none;">0</span>
                    </a>
                </li>

            </ul>
        </nav>

        <div class="sidebar-footer">
            <form asp-controller="Auth" asp-action="Logout" method="post" style="margin:0">
                @Html.AntiForgeryToken()
                <button type="submit" class="nav-link-item"
                        style="width:100%; border:none; background:none; cursor:pointer; color:#ef4444;">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </button>
            </form>
        </div>

    </aside>

    <main class="main-content">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ===== Load Reports Badge =====
        function loadReportCount() {
            fetch('/Hospitals/Maw3dyCare/GetUnreadReports')
                .then(r => r.json())
                .then(data => {
                    var sidebarBadge = document.getElementById('reportsBadge');
                    if (sidebarBadge) {
                        if (data.count > 0) {
                            sidebarBadge.textContent   = data.count;
                            sidebarBadge.style.display = 'inline-block';
                        } else {
                            sidebarBadge.style.display = 'none';
                        }
                    }
                }).catch(() => {});
        }

        loadReportCount();
        setInterval(loadReportCount, 30000);
    </script>

    @* ? ?? ????? ????? ???? ??? ???? *@
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>



