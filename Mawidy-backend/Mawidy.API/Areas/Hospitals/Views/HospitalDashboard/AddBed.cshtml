@model Mawidy.Application.Hospitals.ViewModels.AddBedVM
@{
    ViewData["Title"] = "Add Bed";
    ViewData["ActivePage"] = "AddBed";
    Layout = "~/Areas/Hospitals/Views/Shared/_HospitalLayout.cshtml";
}

<style>
    .add-bed-card {
        background: white;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        padding: 32px;
        max-width: 600px;
        margin: 0 auto;
    }

    .card-icon {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #eff6ff;
        color: #3b82f6;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        margin-bottom: 12px;
    }

    .form-field {
        margin-bottom: 20px;
    }

    .form-label {
        font-size: 14px;
        font-weight: 600;
        color: #374151;
        display: block;
        margin-bottom: 8px;
    }

    .form-input {
        width: 100%;
        padding: 12px 16px;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        font-size: 14px;
        color: #1e293b;
        outline: none;
        transition: border-color .2s;
    }

        .form-input:focus {
            border-color: #3b82f6;
        }

    .field-error {
        font-size: 12px;
        color: #ef4444;
        margin-top: 4px;
    }

    .type-buttons {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .type-btn {
        flex: 1;
        min-width: 80px;
        padding: 12px;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        background: white;
        text-align: center;
        font-size: 14px;
        font-weight: 600;
        color: #64748b;
        cursor: pointer;
        transition: all .15s;
    }

        .type-btn:hover {
            border-color: #3b82f6;
            color: #3b82f6;
            background: #eff6ff;
        }

        .type-btn.active {
            border-color: #3b82f6;
            color: #3b82f6;
            background: #eff6ff;
        }

    .btn-add {
        width: 100%;
        padding: 13px;
        background: #3b82f6;
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: background .2s;
        margin-top: 8px;
    }

        .btn-add:hover {
            background: #2563eb;
        }
</style>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;">
    <div>
        <h1 style="font-size:22px;font-weight:700;color:#1e293b;margin:0">Add Bed</h1>
        <p style="color:#94a3b8;font-size:13px;margin:3px 0 0"><span id="liveTime"></span></p>
    </div>
    <span style="background:#f0fdf4;color:#16a34a;border:1px solid #bbf7d0;font-size:12px;padding:5px 12px;border-radius:20px;font-weight:600;">? System Active</span>
</div>

<div class="add-bed-card">
    <div class="card-icon"><i class="fas fa-plus-circle"></i></div>
    <div style="font-size:18px;font-weight:700;color:#1e293b;margin-bottom:4px;">Add a new bed</div>
    <div style="font-size:13px;color:#94a3b8;margin-bottom:24px;">
        Register a bed in your unit so it appears in the dashboard.
    </div>

    @if (TempData["BedSuccess"] != null)
    {
        <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:12px 16px;color:#16a34a;font-size:13px;font-weight:600;margin-bottom:16px;display:flex;align-items:center;gap:8px;">
            <i class="fas fa-check-circle"></i> @TempData["BedSuccess"]
        </div>
    }

    <form asp-action="AddBed" method="post">
        @Html.AntiForgeryToken()

        <div class="form-field">
            <label class="form-label">Bed Number</label>
            <input asp-for="BedNumber" class="form-input" placeholder="e.g. ICU-07" />
            <span asp-validation-for="BedNumber" class="field-error"></span>
        </div>

        <div class="form-field">
            <label class="form-label">Bed Type</label>
            <input type="hidden" asp-for="BedTypeId" id="selectedTypeId" />
            <div class="type-buttons">
                @foreach (var bt in (List<Mawidy.Domain.Entities.Hospitals.BedTypes>)ViewBag.BedTypes)
                {
                    <button type="button" class="type-btn"
                            onclick="selectType(@bt.BedTypeId, this)">
                        @bt.Name
                    </button>
                }
            </div>
            <span asp-validation-for="BedTypeId" class="field-error"></span>
        </div>

        <button type="submit" class="btn-add">
            <i class="fas fa-plus"></i> Add Bed
        </button>
    </form>
</div>

<script>
    function selectType(id, btn) {
        document.getElementById('selectedTypeId').value = id;
        document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
    }
    function updateTime() {
        const now=new Date();
        const days=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
        const months=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        let h=now.getHours(), m=now.getMinutes().toString().padStart(2,'0');
        const ap=h>=12?'PM':'AM'; h=h%12||12;
        document.getElementById('liveTime').textContent=
            `${days[now.getDay()]}, ${months[now.getMonth()]} ${now.getDate()} · ${h}:${m} ${ap}`;
    }
    updateTime(); setInterval(updateTime,1000);
</script>



