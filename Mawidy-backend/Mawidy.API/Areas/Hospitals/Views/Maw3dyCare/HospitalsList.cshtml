@model Mawidy.Application.Hospitals.ViewModels.HospitalsPageVM
@{
    Layout = "~/Areas/Hospitals/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .page-topbar {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 28px;
    }

    .search-box {
        position: relative;
        width: 380px;
    }

        .search-box input {
            width: 100%;
            padding: 11px 16px 11px 42px;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            font-size: 14px;
            background: white;
            color: #1e293b;
            outline: none;
            transition: border-color .2s;
        }

            .search-box input:focus {
                border-color: #3b82f6;
            }

        .search-box i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
        }

    .hosp-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    .hosp-card {
        background: white;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        padding: 20px;
        transition: transform .2s, box-shadow .2s;
    }

        .hosp-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 24px rgba(0,0,0,.08);
        }

    .hosp-card-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 14px;
    }

    .hosp-icon {
        width: 42px;
        height: 42px;
        background: #eff6ff;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #3b82f6;
        font-size: 18px;
        margin-bottom: 10px;
    }

    .hosp-name {
        font-size: 15px;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 4px;
    }

    .hosp-city {
        font-size: 12px;
        color: #94a3b8;
    }

        .hosp-city i {
            color: #3b82f6;
            margin-right: 3px;
        }

    .badge-active {
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #bbf7d0;
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 600;
    }

    .badge-offline {
        background: #f8fafc;
        color: #94a3b8;
        border: 1px solid #e2e8f0;
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 600;
    }

    .hosp-divider {
        border: none;
        border-top: 1px solid #f1f5f9;
        margin: 12px 0;
    }

    .hosp-info {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 14px;
    }

    .hosp-info-row {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: #475569;
    }

        .hosp-info-row i {
            color: #94a3b8;
            width: 14px;
            text-align: center;
        }

    .hosp-actions {
        display: flex;
        gap: 8px;
    }

    .btn-view {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border-radius: 8px;
        background: #f8fafc;
        color: #475569;
        border: 1px solid #e2e8f0;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: all .2s;
    }

        .btn-view:hover {
            background: #3b82f6;
            color: white;
            border-color: #3b82f6;
        }

    .btn-disable {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 8px 14px;
        border-radius: 8px;
        background: #fff1f2;
        color: #ef4444;
        border: 1px solid #fecaca;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        transition: all .2s;
    }

        .btn-disable:hover {
            background: #ef4444;
            color: white;
        }

    .btn-enable {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 8px 14px;
        border-radius: 8px;
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #bbf7d0;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        transition: all .2s;
    }

        .btn-enable:hover {
            background: #16a34a;
            color: white;
        }

    .topbar-right {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .live-time {
        font-size: 14px;
        font-weight: 600;
        color: #1e293b;
    }

    .bell-btn {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: #f1f5f9;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #64748b;
    }

    .no-results {
        text-align: center;
        padding: 3rem;
        color: #94a3b8;
        font-size: 15px;
    }
</style>

<!-- Top Bar -->
<div class="page-topbar">
    <div>
        <h1 style="font-size:24px; font-weight:700; color:#1e293b; margin:0">Hospitals</h1>
        <p style="color:#64748b; font-size:14px; margin:4px 0 0">Manage all registered facilities</p>
    </div>
    <div class="topbar-right">
        <span id="liveTime" class="live-time"></span>
        <button class="bell-btn"><i class="fas fa-bell"></i></button>
    </div>
</div>

<!-- Search + Add -->
<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
    <form method="get" asp-action="HospitalsList" style="margin:0">
        <div class="search-box">
            <i class="fas fa-search"></i>
            <input type="text" name="search"
                   value="@Model.SearchTerm"
                   placeholder="Search hospitals by name or city..." />
        </div>
    </form>
    <a href="/Hospitals/Maw3dyCare/AddHospital"
       style="display:flex; align-items:center; gap:8px; background:#3b82f6; color:white;
              padding:10px 20px; border-radius:10px; text-decoration:none; font-size:14px; font-weight:600;">
        <i class="fas fa-plus"></i> Add Hospital
    </a>
</div>

<!-- Cards Grid -->
@if (!Model.Hospitals.Any())
{
    <div class="no-results">
        <i class="fas fa-search" style="font-size:32px; display:block; margin-bottom:12px;"></i>
        No hospitals found
    </div>
}
else
{
    <div class="hosp-grid">
        @foreach (var h in Model.Hospitals)
        {
            <div class="hosp-card">
                <div class="hosp-card-top">
                    <div>
                        <div class="hosp-icon"><i class="fas fa-hospital-alt"></i></div>
                        <div class="hosp-name">@h.Name</div>
                        <div class="hosp-city">
                            <i class="fas fa-map-marker-alt"></i> @h.City
                        </div>
                    </div>
                    @if (h.IsActive)
                    {
                        <span class="badge-active">? Active</span>
                    }
                    else
                    {
                        <span class="badge-offline">? Offline</span>
                    }
                </div>

                <hr class="hosp-divider" />

                <div class="hosp-info">
                    <div class="hosp-info-row">
                        <i class="fas fa-phone-alt"></i>
                        <span>@h.Phone</span>
                    </div>
                    <div class="hosp-info-row">
                        <i class="fas fa-envelope"></i>
                        <span>@h.Email</span>
                    </div>
                </div>

                <hr class="hosp-divider" />

                <div class="hosp-actions">
                    <a href="/Hospitals/Maw3dyCare/HospitalDetail/@h.HospitalId" class="btn-view">
                        <i class="fas fa-eye"></i> View
                    </a>
                    <form asp-action="ToggleHospital" method="post" style="margin:0">
                        <input type="hidden" name="id" value="@h.HospitalId" />
                        @if (h.IsActive)
                        {
                            <button type="submit" class="btn-disable">
                                <i class="fas fa-ban"></i> Disable
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="btn-enable">
                                <i class="fas fa-check-circle"></i> Enable
                            </button>
                        }
                    </form>
                </div>
            </div>
        }
    </div>
}

<script>
    function updateTime() {
        const now = new Date();
        const days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
        const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        let hours = now.getHours();
        const minutes = now.getMinutes().toString().padStart(2,'0');
        const ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12 || 12;
        document.getElementById('liveTime').textContent =
            `${days[now.getDay()]}, ${months[now.getMonth()]} ${now.getDate()}  ${hours}:${minutes} ${ampm}`;
    }
    updateTime();
    setInterval(updateTime, 1000);
</script>




