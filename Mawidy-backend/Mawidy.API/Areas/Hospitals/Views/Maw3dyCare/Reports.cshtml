@model List<Mawidy.Application.Hospitals.ViewModels.ReportListVM>
@{
    ViewData["Title"] = "Reports";
    ViewData["ActivePage"] = "Reports";
    Layout = "~/Areas/Hospitals/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .report-card {
        background: white;
        border-radius: 14px;
        border: 1px solid #e2e8f0;
        padding: 18px 22px;
        margin-bottom: 10px;
        transition: box-shadow .2s;
    }

        .report-card:hover {
            box-shadow: 0 4px 16px rgba(0,0,0,.07);
        }

        .report-card.unread {
            border-left: 4px solid #ef4444;
        }

        .report-card.read {
            border-left: 4px solid #e2e8f0;
            opacity: .8;
        }

    .r-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 10px;
    }

    .r-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: #fff1f2;
        color: #ef4444;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
    }

    .r-name {
        font-size: 15px;
        font-weight: 700;
        color: #1e293b;
    }

    .r-meta {
        font-size: 12px;
        color: #94a3b8;
    }

    .r-hosp {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        color: #3b82f6;
        font-weight: 600;
    }

    .r-phone {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        color: #64748b;
    }

    .r-complaint {
        font-size: 14px;
        color: #475569;
        background: #f8fafc;
        border-radius: 8px;
        padding: 10px 14px;
        margin: 10px 0;
    }

    .badge-unread {
        background: #fff1f2;
        color: #ef4444;
        border: 1px solid #fecaca;
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 600;
        margin-left: auto;
    }

    .badge-read {
        background: #f8fafc;
        color: #94a3b8;
        border: 1px solid #e2e8f0;
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 600;
        margin-left: auto;
    }

    .btn-mark {
        font-size: 12px;
        padding: 5px 12px;
        border-radius: 8px;
        border: 1.5px solid #e2e8f0;
        background: white;
        color: #64748b;
        cursor: pointer;
        transition: all .15s;
    }

        .btn-mark:hover {
            background: #f0fdf4;
            color: #16a34a;
            border-color: #bbf7d0;
        }

    .empty-state {
        text-align: center;
        padding: 3rem;
        color: #94a3b8;
    }

        .empty-state i {
            font-size: 36px;
            display: block;
            margin-bottom: 12px;
        }
</style>

<!-- Header -->
<div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:28px;">
    <div>
        <h1 style="font-size:22px; font-weight:700; color:#1e293b; margin:0;">
            <i class="fas fa-flag" style="color:#ef4444; margin-right:8px;"></i> Reports
        </h1>
        <p style="color:#64748b; font-size:13px; margin:4px 0 0;">
            @Model.Count(r => !r.IsRead) unread report(s)
        </p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="fas fa-flag" style="color:#bbf7d0;"></i>
        No reports submitted yet
    </div>
}
else
{
    @foreach (var r in Model)
    {
        <div class="report-card @(r.IsRead ? "read" : "unread")"
             id="report-@r.ReportId">

            <div class="r-header">
                <div class="r-avatar"><i class="fas fa-flag"></i></div>
                <div style="flex:1;">
                    <div class="r-name">@r.PatientName</div>
                    <div class="r-meta">@r.CreatedAt.ToString("ddd, MMM dd · hh:mm tt")</div>
                </div>
                @if (r.IsRead)
                {
                    <span class="badge-read">Read</span>
                }
                else
                {
                    <span class="badge-unread">? New</span>
                }
            </div>

            <div style="display:flex; gap:14px; margin-bottom:8px; flex-wrap:wrap;">
                <span class="r-hosp"><i class="fas fa-hospital"></i> @r.HospitalName</span>
                <span class="r-phone"><i class="fas fa-phone"></i> @r.PatientPhone</span>
            </div>

            <div class="r-complaint">@r.Complaint</div>

            @if (!r.IsRead)
            {
                <form asp-action="MarkReportRead" method="post" style="margin:0;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@r.ReportId" />
                    <button type="submit" class="btn-mark">
                        <i class="fas fa-check"></i> Mark as Read
                    </button>
                </form>
            }
        </div>
    }
}

@section Scripts {
    <script>
        // Highlight ???????? ???? ????? ???? ?? ??? Notification
        window.addEventListener('load', function() {
            var hash = window.location.hash;
            if (hash) {
                var el = document.querySelector(hash);
                if (el) {
                    el.scrollIntoView({ behavior:'smooth', block:'center' });
                    el.style.boxShadow = '0 0 0 3px #ef4444';
                    setTimeout(() => { el.style.boxShadow = ''; }, 3000);
                }
            }
        });
    </script>
}



