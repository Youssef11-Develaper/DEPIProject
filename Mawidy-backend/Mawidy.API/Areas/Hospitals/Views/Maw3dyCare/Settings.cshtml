@model Mawidy.Application.Hospitals.ViewModels.SettingsVM
@{
    // ???? Settings - ?????? ?????? ??????
    Layout = "~/Areas/Hospitals/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .settings-card {
        background: white;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        padding: 32px;
        max-width: 600px;
    }

    .settings-top {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 28px;
        padding-bottom: 24px;
        border-bottom: 1px solid #f1f5f9;
    }
    /* ???????? ?????? */
    .settings-avatar {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: #3b82f6;
        color: white;
        font-size: 26px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .settings-name {
        font-size: 20px;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 4px;
    }

    .settings-role {
        font-size: 13px;
        color: #94a3b8;
    }

    .badge-active {
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #bbf7d0;
        font-size: 12px;
        padding: 4px 12px;
        border-radius: 20px;
        font-weight: 600;
        margin-left: 8px;
    }

    .badge-inactive {
        background: #f8fafc;
        color: #94a3b8;
        border: 1px solid #e2e8f0;
        font-size: 12px;
        padding: 4px 12px;
        border-radius: 20px;
        font-weight: 600;
        margin-left: 8px;
    }

    /* Info Fields */
    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .info-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .info-label {
        font-size: 11px;
        font-weight: 600;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: .05em;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .info-label i {
            font-size: 12px;
        }

    .info-value {
        font-size: 15px;
        color: #1e293b;
        font-weight: 500;
    }

        .info-value.password {
            letter-spacing: 3px;
            color: #64748b;
        }

    /* Logout Button */
    .btn-logout {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 22px;
        border-radius: 10px;
        background: #fff1f2;
        color: #ef4444;
        border: 1px solid #fecaca;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        margin-top: 24px;
    }

        .btn-logout:hover {
            background: #ef4444;
            color: white;
            border-color: #ef4444;
        }
</style>

<!-- Header -->
<div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:28px;">
    <div>
        <h1 style="font-size:24px; font-weight:700; color:#1e293b; margin:0">Settings</h1>
        <p style="color:#64748b; font-size:14px; margin:4px 0 0">Your admin account details</p>
    </div>
    <div style="display:flex; align-items:center; gap:16px;">
        <span id="liveTime" style="font-size:14px; font-weight:600; color:#1e293b;"></span>
        <button style="width:38px;height:38px;border-radius:50%;background:#f1f5f9;border:none;cursor:pointer;color:#64748b;">
            <i class="fas fa-bell"></i>
        </button>
    </div>
</div>

<div class="settings-card">

    @* ===== Top: Avatar + Name + Badge ===== *@
    <div class="settings-top">
        <div class="settings-avatar">@Model.Initials</div>
        <div>
            <div style="display:flex; align-items:center;">
                <span class="settings-name">@Model.FullName</span>
                @if (Model.IsActive)
                {
                    <span class="badge-active">? Active</span>
                }
                else
                {
                    <span class="badge-inactive">? Inactive</span>
                }
            </div>
            <div class="settings-role">
                <i class="fas fa-shield-alt" style="color:#3b82f6; margin-right:4px;"></i>
                System Administrator
            </div>
        </div>
    </div>

    @* ===== Info Grid ===== *@
    <div class="info-grid">

        <!-- Email -->
        <div class="info-field">
            <div class="info-label">
                <i class="fas fa-envelope"></i> Email Address
            </div>
            <div class="info-value">@Model.Email</div>
        </div>

        <!-- Password -->
        <div class="info-field">
            <div class="info-label">
                <i class="fas fa-lock"></i> Password
            </div>
            <div class="info-value password">••••••••</div>
        </div>

        <!-- Last Login -->
        <div class="info-field">
            <div class="info-label">
                <i class="fas fa-clock"></i> Last Login
            </div>
            <div class="info-value">
                @(Model.LastLoginAt.HasValue
                                ? Model.LastLoginAt.Value.ToString("ddd, MMM dd yyyy — hh:mm tt")
                                : "First login")
            </div>
        </div>

        <!-- Created At -->
        <div class="info-field">
            <div class="info-label">
                <i class="fas fa-calendar-plus"></i> Account Created
            </div>
            <div class="info-value">
                @Model.CreatedAt.ToString("ddd, MMM dd yyyy — hh:mm tt")
            </div>
        </div>

    </div>

    @* ===== Logout Button ===== *@
    <form asp-controller="Auth" asp-action="Logout" method="post" style="margin:0">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn-logout">
            <i class="fas fa-sign-out-alt"></i> Logout
        </button>
    </form>

</div>

<script>
    function updateTime() {
        const now = new Date();
        const days   = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
        const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        let h = now.getHours(), m = now.getMinutes().toString().padStart(2,'0');
        const ap = h >= 12 ? 'PM' : 'AM'; h = h % 12 || 12;
        document.getElementById('liveTime').textContent =
            `${days[now.getDay()]}, ${months[now.getMonth()]} ${now.getDate()}  ${h}:${m} ${ap}`;
    }
    updateTime(); setInterval(updateTime, 1000);
</script>




