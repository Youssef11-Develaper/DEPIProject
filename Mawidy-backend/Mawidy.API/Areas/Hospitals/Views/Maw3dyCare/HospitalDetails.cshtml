@* ======= Model & Variables ======= *@
@model Mawidy.Domain.Entities.Hospitals.Hospitals
@{
    ViewData["Title"] = Model.Name;

    @* ???? ??? ??????? ??????? ??? ??? *@
    var icuAvailable = Model.Beds.Count(b => b.BedTypes.Name == "ICU" && b.Status == "Available");
    var cicuAvailable = Model.Beds.Count(b => b.BedTypes.Name == "CICU" && b.Status == "Available");
    var nicuAvailable = Model.Beds.Count(b => b.BedTypes.Name == "NICU" && b.Status == "Available");
    var ventAvailable = Model.Beds.Count(b => b.BedTypes.Name == "VENT" && b.Status == "Available");
}

@* ======= Page Styling ======= *@
<style>
    /* ??? ????? ?????? ???? ???? ??? */
    body {
        background-color: #f0f4ff;
    }
    /* ????? ?????? ??????? */

    .page-wrapper {
        max-width: 650px;
        margin: 0 auto;
    }

    /* ??? ???? ?????? */
    .resource-card {
        background-color: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 16px;
        text-align: center;
        box-shadow: 0 2px 12px rgba(13, 110, 253, 0.08);
    }

    /* ??? ???????? */
    .resource-icon {
        background-color: var(--badge-bg);
        border-radius: 12px;
        width: 52px;
        height: 52px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 8px;
    }
</style>

@* ======= Page Content ======= *@
<div class="container mt-5">
    <div class="page-wrapper">

    @* --- ??????? ???????? --- *@
        <div class="mb-4">
            <h4 class="fw-bold">@Model.Name</h4>
            <p class="text-muted mb-1 small">
                <i class="bi bi-geo-alt" style="color:#6c757d;"></i> @Model.Address, @Model.City
            </p>
            <p class="text-muted mb-0 small">
                <i class="bi bi-telephone" style="color:#6c757d;"></i> @Model.Phone
            </p>
        </div>

    @* --- ??????? ??????? --- *@
        <h6 class="fw-bold mb-3">Available Resources</h6>
        <div class="row g-2 mb-4">

        @* ???? ICU *@
            @if (icuAvailable > 0)
            {
                <div class="col-6 col-md-3">
                    <div class="resource-card">
                        <div class="resource-icon">
                            <i class="bi bi-hospital" style="color:#6b9ef5; font-size:1.5rem;"></i>
                        </div>
                        <p class="text-muted mb-1 small">ICU Beds</p>
                        <h5 class="fw-bold text-dark mb-0">@icuAvailable</h5>
                        <span class="text-success" style="font-size:0.75rem;">Available</span>
                    </div>
                </div>
            }

        @* ???? Cardiac ICU *@
            @if (cicuAvailable > 0)
            {
                <div class="col-6 col-md-3">
                    <div class="resource-card">
                        <div class="resource-icon">
                            <i class="bi bi-heart-pulse" style="color:#6b9ef5; font-size:1.5rem;"></i>
                        </div>
                        <p class="text-muted mb-1 small">Cardiac ICU</p>
                        <h5 class="fw-bold text-dark mb-0">@cicuAvailable</h5>
                        <span class="text-success" style="font-size:0.75rem;">Available</span>
                    </div>
                </div>
            }
        @* ???? Neonatal Incubators *@
            @if (nicuAvailable > 0)
            {
                <div class="col-6 col-md-3">
                    <div class="resource-card">
                        <div class="resource-icon">
                            <i class="bi bi-person-hearts" style="color:#6b9ef5; font-size:1.5rem;"></i>
                        </div>
                        <p class="text-muted mb-1 small">Neonatal</p>
                        <h5 class="fw-bold text-dark mb-0">@nicuAvailable</h5>
                        <span class="text-success" style="font-size:0.75rem;">Available</span>
                    </div>
                </div>
            }

        @* ???? Ventilators *@
            @if (ventAvailable > 0)
            {
                <div class="col-6 col-md-3">
                    <div class="resource-card">
                        <div class="resource-icon">
                            <i class="bi bi-wind" style="color:#6b9ef5; font-size:1.5rem;"></i>
                        </div> 
                        <p class="text-muted mb-1 small">Ventilators</p>
                        <h5 class="fw-bold text-dark mb-0">@ventAvailable</h5>
                        <span class="text-success" style="font-size:0.75rem;">Available</span>
                    </div>
                </div>
            }
        @* ????? ?? ???? ????? ???? *@
            @if (icuAvailable == 0 && cicuAvailable == 0 && nicuAvailable == 0 && ventAvailable == 0)
            {
                <div class="col-12">
                    <div class="alert alert-danger">
                        ? No beds available at this time.
                    </div>
                </div>
            }

        </div>

    @* --- ???? ????? --- *@
        <div class="d-grid">
            <a href="/Hospitals/Maw3dyCare/Reserve/@Model.HospitalId"
               class="btn btn-primary rounded-3">
                Reserve a Bed
            </a>
        </div>

    </div>
</div>



