@model Mawidy.Application.Hospitals.ViewModels.ResetPasswordVM
@{
    // ???? ????? ????? ???? ????
    Layout = "~/Areas/Hospitals/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15,23,42,.45);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 50;
    }

    .modal-box {
        background: white;
        border-radius: 20px;
        padding: 32px;
        width: 420px;
        max-width: 90vw;
        box-shadow: 0 20px 60px rgba(0,0,0,.15);
    }

    .modal-title {
        font-size: 18px;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 4px;
    }

    .modal-sub {
        font-size: 13px;
        color: #64748b;
        margin-bottom: 22px;
    }
    /* ???????? ?????? */
    .mini-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: #3b82f6;
        color: white;
        font-size: 15px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-left: 10px;
    }

    .form-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 16px;
    }

    .form-label {
        font-size: 13px;
        font-weight: 600;
        color: #374151;
    }

    .form-input {
        padding: 11px 14px;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        font-size: 14px;
        color: #1e293b;
        outline: none;
        transition: border-color .2s;
    }

        .form-input:focus {
            border-color: #3b82f6;
        }

    .validation-error {
        font-size: 12px;
        color: #ef4444;
    }

    .modal-actions {
        display: flex;
        gap: 12px;
        margin-top: 6px;
    }

    .btn-cancel {
        flex: 1;
        padding: 11px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        text-align: center;
    }

        .btn-cancel:hover {
            background: #f8fafc;
        }

    .btn-update {
        flex: 1;
        padding: 11px;
        border-radius: 10px;
        background: #3b82f6;
        color: white;
        border: none;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: background .2s;
    }

        .btn-update:hover {
            background: #2563eb;
        }
</style>

<!-- Blurred background page -->
<div style="filter:blur(2px); opacity:.4; padding:40px;">
    <h1 style="font-size:24px; font-weight:700; color:#1e293b;">Accounts</h1>
</div>

<!-- Modal -->
<div class="modal-overlay">
    <div class="modal-box">

        <!-- Header -->
        <div style="display:flex; align-items:center; margin-bottom:18px;">
            <span class="mini-avatar">@Model.FullName?.Substring(0, 2).ToUpper()</span>
            <div>
                <div class="modal-title">Reset Password</div>
                <div class="modal-sub">@Model.Email</div>
            </div>
        </div>

        <form asp-action="ResetPassword" method="post">
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="FullName" />
            <input type="hidden" asp-for="Email" />

            <!-- New Password -->
            <div class="form-field">
                <label class="form-label">New Password</label>
                <input asp-for="NewPassword" type="password"
                       class="form-input" placeholder="Min 8 characters" />
                <span asp-validation-for="NewPassword" class="validation-error"></span>
            </div>

            <!-- Confirm Password -->
            <div class="form-field">
                <label class="form-label">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password"
                       class="form-input" placeholder="••••••••" />
                <span asp-validation-for="ConfirmPassword" class="validation-error"></span>
            </div>

            <!-- Buttons -->
            <div class="modal-actions">
                <a href="/Hospitals/Maw3dyCare/Accounts" class="btn-cancel">Cancel</a>
                <button type="submit" class="btn-update">
                    <i class="fas fa-key"></i> Update
                </button>
            </div>
        </form>

    </div>
</div>



