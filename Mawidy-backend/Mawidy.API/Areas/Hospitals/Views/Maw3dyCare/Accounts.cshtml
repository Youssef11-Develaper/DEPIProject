@model List<Mawidy.Application.Hospitals.ViewModels.AccountCardVM>
@{
    // ???? ??? ??????? ?????????? ?? Disable/Enable
    Layout = "~/Areas/Hospitals/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .acc-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    .acc-card {
        background: white;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        padding: 20px 22px;
        transition: transform .2s, box-shadow .2s;
    }

        .acc-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 24px rgba(0,0,0,.08);
        }

    /* ????? ?????? - Avatar + Name + Badge */
    .acc-card-top {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 10px;
    }

    /* ??????? ?????? ??????? */
    .acc-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #3b82f6;
        color: white;
        font-size: 16px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .acc-name-wrap {
        flex: 1;
    }

    .acc-name {
        font-size: 15px;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 3px;
    }

    /* Email Row */
    .acc-email {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 13px;
        color: #64748b;
        margin-bottom: 16px;
        padding-left: 2px;
    }

        .acc-email i {
            color: #94a3b8;
            font-size: 12px;
        }

    /* Badges */
    .badge-active {
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #bbf7d0;
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 600;
        white-space: nowrap;
    }

    .badge-disabled {
        background: #f8fafc;
        color: #94a3b8;
        border: 1px solid #e2e8f0;
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 600;
        white-space: nowrap;
    }

    .acc-divider {
        border: none;
        border-top: 1px solid #f1f5f9;
        margin: 0 0 14px;
    }

    /* Action Buttons Row */
    .acc-actions {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    /* ???? Reset Password */
    .btn-reset-pass {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        font-weight: 500;
        color: #475569;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        text-decoration: none;
        transition: color .2s;
    }

        .btn-reset-pass:hover {
            color: #3b82f6;
        }

        .btn-reset-pass i {
            font-size: 14px;
        }

    /* ???? Disable */
    .btn-disable {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 13px;
        font-weight: 500;
        color: #ef4444;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        transition: color .2s;
    }

        .btn-disable:hover {
            color: #b91c1c;
        }

    /* ???? Enable */
    .btn-enable {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 13px;
        font-weight: 500;
        color: #16a34a;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        transition: color .2s;
    }

        .btn-enable:hover {
            color: #15803d;
        }

    /* Success Alert */
    .alert-success {
        display: flex;
        align-items: center;
        gap: 10px;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 12px;
        padding: 14px 18px;
        margin-bottom: 20px;
        color: #16a34a;
        font-size: 14px;
        font-weight: 600;
    }

    .empty-state {
        text-align: center;
        padding: 4rem;
        color: #94a3b8;
        font-size: 15px;
    }

        .empty-state i {
            font-size: 40px;
            display: block;
            margin-bottom: 12px;
        }
</style>

<!-- Page Header -->
<div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:28px;">
    <div>
        <h1 style="font-size:24px; font-weight:700; color:#1e293b; margin:0">Accounts</h1>
        <p style="color:#64748b; font-size:14px; margin:4px 0 0">
            Manage hospital login accounts
        </p>
    </div>
    <div style="display:flex; align-items:center; gap:16px;">
        <span id="liveTime" style="font-size:14px; font-weight:600; color:#1e293b;"></span>
        <button style="width:38px;height:38px;border-radius:50%;background:#f1f5f9;border:none;cursor:pointer;color:#64748b;">
            <i class="fas fa-bell"></i>
        </button>
    </div>
</div>

@* Success Alert *@
@if (TempData["Success"] != null)
{
    <div class="alert-success">
        <i class="fas fa-check-circle"></i>
        @TempData["Success"]
    </div>
}

@* Cards Grid *@
@if (!Model.Any())
{
    <div class="empty-state">
        <i class="fas fa-users"></i>
        No accounts found. Add a hospital to create accounts.
    </div>
}
else
{
    <div class="acc-grid">
        @foreach (var u in Model)
        {
            <div class="acc-card">

                @* ===== Top: Avatar + Name + Badge ===== *@
                <div class="acc-card-top">

                    @* ??????? ???????? ??????? *@
                    <div class="acc-avatar">@u.Initials</div>

                    <div class="acc-name-wrap">
                        <div class="acc-name">@u.FullName</div>
                    </div>

                    @* Badge Active / Disabled *@
                    @if (u.IsActive)
                    {
                        <span class="badge-active">? Active</span>
                    }
                    else
                    {
                        <span class="badge-disabled">? Disabled</span>
                    }
                </div>

                @* ===== Email ===== *@
                <div class="acc-email">
                    <i class="fas fa-envelope"></i>
                    @u.Email
                </div>

                <hr class="acc-divider" />

                @* ===== Action Buttons ===== *@
                <div class="acc-actions">

                    @* ???? Reset Password *@
                    <a href="/Hospitals/Maw3dyCare/ResetPassword/@u.UserId"
                       class="btn-reset-pass">
                        <i class="fas fa-key"></i> Reset Password
                    </a>

                    @* ???? Disable / Enable *@
                    <form asp-action="ToggleUserActive" method="post" style="margin:0">
                        <input type="hidden" name="id" value="@u.UserId" />
                        @if (u.IsActive)
                        {
                            <button type="submit" class="btn-disable">
                                <i class="fas fa-ban"></i> Disable
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="btn-enable">
                                <i class="fas fa-check-circle"></i> Enable
                            </button>
                        }
                    </form>

                </div>
            </div>
        }
    </div>
}

<script>
    function updateTime() {
        const now = new Date();
        const days   = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
        const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        let h = now.getHours(), m = now.getMinutes().toString().padStart(2,'0');
        const ap = h >= 12 ? 'PM' : 'AM';
        h = h % 12 || 12;
        document.getElementById('liveTime').textContent =
            `${days[now.getDay()]}, ${months[now.getMonth()]} ${now.getDate()}  ${h}:${m} ${ap}`;
    }
    updateTime();
    setInterval(updateTime, 1000);
</script>



