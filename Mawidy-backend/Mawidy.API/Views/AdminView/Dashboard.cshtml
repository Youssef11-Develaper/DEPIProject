<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة التحكم - السجل المدني</title>
    <link rel="stylesheet" href="~/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .progress-bar-container {
            background: var(--border);
            border-radius: 10px;
            height: 8px;
            overflow: hidden;
            margin-top: 6px;
        }

        .progress-bar {
            height: 100%;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
        }
    </style>
</head>
<body>

<nav class="navbar">
    <a href="/" class="navbar-brand">
        <i class="bi bi-building-fill"></i>
        السجل المدني - لوحة التحكم
    </a>
    <ul class="navbar-nav">
        <li><a href="/Admin/Dashboard" class="nav-link active">الرئيسية</a></li>
        <li><a href="/Home/Appointments" class="nav-link">المواعيد</a></li>
        <li><a href="/Admin/Branches" class="nav-link">الفروع</a></li>
        <li><a href="/Admin/Services" class="nav-link">الخدمات</a></li>
        <li><a href="/Admin/Complaints" class="nav-link">الشكاوى</a></li>
        <li><a href="/Admin/Users" class="nav-link">المستخدمين</a></li>
        <li>
            <button class="btn btn-outline" onclick="logout()"
                style="color:white;border-color:rgba(255,255,255,0.6)">
                <i class="bi bi-box-arrow-right"></i>
                خروج
            </button>
        </li>
    </ul>
</nav>

<div class="sidebar">
    <a href="/Admin/Dashboard" class="sidebar-link active">
        <i class="bi bi-speedometer2"></i> الرئيسية
    </a>
    <a href="/Home/Appointments" class="sidebar-link">
        <i class="bi bi-calendar-check"></i> المواعيد
    </a>
    <a href="/Admin/Branches" class="sidebar-link">
        <i class="bi bi-building"></i> الفروع
    </a>
    <a href="/Admin/Services" class="sidebar-link">
        <i class="bi bi-list-check"></i> الخدمات
    </a>
    <a href="/Admin/Complaints" class="sidebar-link">
        <i class="bi bi-exclamation-circle"></i> الشكاوى
    </a>
    <a href="/Admin/Users" class="sidebar-link">
        <i class="bi bi-people"></i> المستخدمين
    </a>
</div>

<div class="main-content">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">
        <div>
            <h2 style="font-size:1.4rem;font-weight:900;color:var(--primary)">لوحة التحكم</h2>
            <p style="color:var(--text-muted);font-size:0.85rem" id="todayDate"></p>
        </div>
        <a href="/Home/Appointments" class="btn btn-primary" id="reportBtn">
            <i class="bi bi-file-pdf"></i>
            تقرير اليوم PDF
        </a>
    </div>

    <!-- Stats -->
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px">
        <div class="stat-card">
            <div class="stat-icon" style="background:#EAF2FB;color:var(--primary)">
                <i class="bi bi-people"></i>
            </div>
            <div>
                <div class="stat-value" id="statUsers">0</div>
                <div class="stat-label">المستخدمين</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:#EAFAF1;color:var(--success)">
                <i class="bi bi-calendar-check"></i>
            </div>
            <div>
                <div class="stat-value" id="statTodayAppointments">0</div>
                <div class="stat-label">مواعيد اليوم</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:#FEF9E7;color:#7D6608">
                <i class="bi bi-exclamation-circle"></i>
            </div>
            <div>
                <div class="stat-value" id="statPendingComplaints">0</div>
                <div class="stat-label">شكاوى معلقة</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:#FDEDEC;color:var(--danger)">
                <i class="bi bi-percent"></i>
            </div>
            <div>
                <div class="stat-value" id="statCancellationRate">0%</div>
                <div class="stat-label">نسبة الإلغاء</div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Weekly Chart -->
        <div class="col-8">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-bar-chart"></i>
                    مواعيد آخر 7 أيام
                </div>
                <div class="card-body">
                    <canvas id="weeklyChart" height="120"></canvas>
                </div>
            </div>
        </div>

        <!-- Today Stats -->
        <div class="col-4">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-calendar-day"></i>
                    إحصائيات اليوم
                </div>
                <div class="card-body">
                    <div style="margin-bottom:16px">
                        <div style="display:flex;justify-content:space-between;margin-bottom:4px">
                            <span style="font-size:0.85rem">مكتملة</span>
                            <span style="font-weight:700;color:var(--success)" id="statTodayCompleted">0</span>
                        </div>
                        <div class="progress-bar-container">
                            <div class="progress-bar" id="completedBar" style="width:0%;background:var(--success)"></div>
                        </div>
                    </div>
                    <div>
                        <div style="display:flex;justify-content:space-between;margin-bottom:4px">
                            <span style="font-size:0.85rem">ملغية</span>
                            <span style="font-weight:700;color:var(--danger)" id="statTodayCancelled">0</span>
                        </div>
                        <div class="progress-bar-container">
                            <div class="progress-bar" id="cancelledBar" style="width:0%;background:var(--danger)"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Top Services -->
        <div class="col-6">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-fire"></i>
                    أكثر الخدمات طلباً
                </div>
                <div class="card-body" id="topServicesContainer"></div>
            </div>
        </div>

        <!-- Governorate Distribution -->
        <div class="col-6">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-map"></i>
                    توزيع المواعيد على المحافظات
                </div>
                <div class="card-body">
                    <canvas id="governorateChart" height="160"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/js/api.js"></script>
<script>
    async function init() {
        UI.redirectIfNotAdmin();

        const today = new Date();
        document.getElementById('todayDate').textContent =
            today.toLocaleDateString('ar-EG', { weekday:'long', year:'numeric', month:'long', day:'numeric' });

        document.getElementById('reportBtn').href =
            API.admin.getDailyReport(today.toISOString().split('T')[0]);

        await loadDashboard();
    }

    async function loadDashboard() {
        try {
            const res = await API.admin.getDashboard();
            const data = res.data;

            document.getElementById('statUsers').textContent = data.totalUsers;
            document.getElementById('statTodayAppointments').textContent = data.todayAppointments;
            document.getElementById('statPendingComplaints').textContent = data.pendingComplaints;
            document.getElementById('statCancellationRate').textContent = `${data.cancellationRate}%`;
            document.getElementById('statTodayCompleted').textContent = data.todayCompleted;
            document.getElementById('statTodayCancelled').textContent = data.todayCancelled;

            const total = data.todayAppointments || 1;
            document.getElementById('completedBar').style.width =
                `${(data.todayCompleted / total * 100)}%`;
            document.getElementById('cancelledBar').style.width =
                `${(data.todayCancelled / total * 100)}%`;

            // Weekly Chart
            if (data.weeklyAppointments?.length) {
                new Chart(document.getElementById('weeklyChart'), {
                    type: 'bar',
                    data: {
                        labels: data.weeklyAppointments.map(w => w.date),
                        datasets: [{
                            label: 'عدد المواعيد',
                            data: data.weeklyAppointments.map(w => w.count),
                            backgroundColor: 'rgba(27,79,114,0.7)',
                            borderRadius: 8
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
                    }
                });
            }

            // Top Services
            if (data.topServices?.length) {
                document.getElementById('topServicesContainer').innerHTML =
                    data.topServices.map(s => `
                        <div style="margin-bottom:14px">
                            <div style="display:flex;justify-content:space-between;margin-bottom:4px">
                                <span style="font-size:0.85rem;font-weight:600">${s.serviceName}</span>
                                <span style="font-size:0.85rem;color:var(--text-muted)">
                                    ${s.totalAppointments} (${s.percentage}%)
                                </span>
                            </div>
                            <div class="progress-bar-container">
                                <div class="progress-bar" style="width:${s.percentage}%"></div>
                            </div>
                        </div>
                    `).join('');
            }

            // Governorate Chart
            if (data.governorateDistribution?.length) {
                new Chart(document.getElementById('governorateChart'), {
                    type: 'doughnut',
                    data: {
                        labels: data.governorateDistribution.map(g => g.governorateName),
                        datasets: [{
                            data: data.governorateDistribution.map(g => g.totalAppointments),
                            backgroundColor: [
                                '#1B4F72', '#2E86C1', '#1E8449', '#D4AC0D',
                                '#E74C3C', '#8E44AD', '#16A085', '#E67E22'
                            ]
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { position: 'bottom', labels: { font: { family: 'Cairo' } } } }
                    }
                });
            }

        } catch (err) {
            UI.showToast('حدث خطأ في تحميل البيانات', 'error');
        }
    }

    function logout() {
        Auth.clearSession();
        window.location.href = '/';
    }

    init();
</script>
</body>
</html>