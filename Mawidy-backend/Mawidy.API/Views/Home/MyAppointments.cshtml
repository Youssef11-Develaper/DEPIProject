<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مواعيدي - السجل المدني</title>
    <link rel="stylesheet" href="~/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        .page-header {
            background: linear-gradient(135deg, #1B4F72, #2E86C1);
            padding: 30px 0;
            color: white;
            margin-bottom: 30px;
        }

        .appointment-card {
            background: white;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            margin-bottom: 16px;
            overflow: hidden;
            transition: all 0.2s;
        }

        .appointment-card:hover {
            box-shadow: var(--shadow-hover);
        }

        .appointment-header {
            padding: 16px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid var(--border);
        }

        .appointment-body {
            padding: 16px 20px;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
        }

        .appointment-info-label {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-bottom: 4px;
        }

        .appointment-info-value {
            font-size: 0.9rem;
            font-weight: 700;
        }

        .appointment-footer {
            padding: 12px 20px;
            background: #F8F9FA;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }

        .countdown {
            font-size: 0.85rem;
            color: var(--primary);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .stars-display {
            color: #D4AC0D;
        }

        .filter-tabs {
            display: flex;
            gap: 8px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .filter-tab {
            padding: 8px 20px;
            border-radius: 20px;
            border: 2px solid var(--border);
            background: white;
            cursor: pointer;
            font-family: 'Cairo', sans-serif;
            font-weight: 600;
            font-size: 0.85rem;
            transition: all 0.2s;
        }

        .filter-tab.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        /* QR Modal */
        .qr-container {
            text-align: center;
            padding: 20px 0;
        }

        .qr-container img {
            width: 200px;
            height: 200px;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
        }

        .queue-numbers {
            display: flex;
            gap: 16px;
            justify-content: center;
            margin-top: 20px;
        }

        .queue-number-box {
            text-align: center;
            padding: 16px 24px;
            border-radius: var(--radius);
            background: #F0F3F4;
        }

        .queue-number-value {
            font-size: 2rem;
            font-weight: 900;
            color: var(--primary);
        }

        .queue-number-label {
            font-size: 0.8rem;
            color: var(--text-muted);
        }

        /* Rating Modal Stars */
        .star-rating {
            display: flex;
            flex-direction: row-reverse;
            justify-content: center;
            gap: 8px;
            margin: 16px 0;
        }

        .star-rating input { display: none; }

        .star-rating label {
            font-size: 2.5rem;
            color: #ddd;
            cursor: pointer;
            transition: color 0.2s;
        }

        .star-rating label:hover,
        .star-rating label:hover ~ label,
        .star-rating input:checked ~ label {
            color: #D4AC0D;
        }
    </style>
</head>
<body>

<!-- Navbar -->
<nav class="navbar">
    <a href="/" class="navbar-brand">
        <i class="bi bi-building-fill"></i>
        السجل المدني الرقمي
    </a>
    <ul class="navbar-nav">
        <li><a href="/" class="nav-link">الرئيسية</a></li>
        <li><a href="/Home/Appointments" class="nav-link">حجز موعد</a></li>
        <li><a href="/Home/Complaints" class="nav-link">الشكاوى</a></li>
        <li><a href="/Home/Profile" class="nav-link">حسابي</a></li>
    </ul>
</nav>

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <div style="display:flex;align-items:center;justify-content:space-between">
            <div>
                <h1 style="font-size:1.6rem;font-weight:900">مواعيدي</h1>
                <p style="opacity:0.8;font-size:0.9rem;margin-top:4px">تابع وأدر جميع مواعيدك</p>
            </div>
            <a href="/Home/Appointments" class="btn" style="background:white;color:var(--primary)">
                <i class="bi bi-plus-lg"></i>
                موعد جديد
            </a>
        </div>
    </div>
</div>

<div class="container" style="padding-bottom:40px">

    <!-- Filters -->
    <div class="filter-tabs">
        <button class="filter-tab active" onclick="filterAppointments('all', this)">الكل</button>
        <button class="filter-tab" onclick="filterAppointments('Confirmed', this)">مؤكدة</button>
        <button class="filter-tab" onclick="filterAppointments('Completed', this)">مكتملة</button>
        <button class="filter-tab" onclick="filterAppointments('Cancelled', this)">ملغية</button>
    </div>

    <!-- Appointments -->
    <div id="appointmentsContainer">
        <div class="empty-state">
            <div class="spinner" style="border-color:var(--border);border-top-color:var(--primary);width:30px;height:30px;margin:0 auto"></div>
        </div>
    </div>
</div>

<!-- QR Modal -->
<div class="modal-overlay" id="qrModal">
    <div class="modal">
        <h3 class="modal-title text-center">
            <i class="bi bi-qr-code"></i>
            QR Code الموعد
        </h3>
        <div class="qr-container">
            <img id="qrImage" src="" alt="QR Code">
        </div>
        <div class="queue-numbers">
            <div class="queue-number-box">
                <div class="queue-number-value" id="qrAppointmentId"></div>
                <div class="queue-number-label">رقم الحجز</div>
            </div>
            <div class="queue-number-box" style="background:#EAF2FB">
                <div class="queue-number-value" id="qrQueueNumber"></div>
                <div class="queue-number-label">رقم الطابور</div>
            </div>
        </div>
        <div class="text-center mt-2">
            <button class="btn btn-primary" onclick="printQR()">
                <i class="bi bi-printer"></i>
                طباعة
            </button>
            <button class="btn btn-outline mt-1" onclick="closeQRModal()" style="margin-right:8px">إغلاق</button>
        </div>
    </div>
</div>

<!-- Reschedule Modal -->
<div class="modal-overlay" id="rescheduleModal">
    <div class="modal">
        <h3 class="modal-title">
            <i class="bi bi-calendar-event"></i>
            تأجيل الموعد
        </h3>
        <div class="form-group">
            <label class="form-label">التاريخ الجديد</label>
            <input type="date" class="form-control" id="rescheduleDate">
        </div>
        <div id="rescheduleSlotsContainer" style="margin-top:16px"></div>
        <div class="text-center mt-2">
            <button class="btn btn-outline" onclick="closeRescheduleModal()">إغلاق</button>
        </div>
    </div>
</div>

<!-- Rating Modal -->
<div class="modal-overlay" id="ratingModal">
    <div class="modal">
        <h3 class="modal-title text-center">
            <i class="bi bi-star-fill" style="color:#D4AC0D"></i>
            قيم تجربتك
        </h3>
        <div id="ratingAppointmentInfo" class="alert alert-info"></div>

        <div class="star-rating">
            <input type="radio" name="stars" id="star5" value="5">
            <label for="star5"><i class="bi bi-star-fill"></i></label>
            <input type="radio" name="stars" id="star4" value="4">
            <label for="star4"><i class="bi bi-star-fill"></i></label>
            <input type="radio" name="stars" id="star3" value="3">
            <label for="star3"><i class="bi bi-star-fill"></i></label>
            <input type="radio" name="stars" id="star2" value="2">
            <label for="star2"><i class="bi bi-star-fill"></i></label>
            <input type="radio" name="stars" id="star1" value="1">
            <label for="star1"><i class="bi bi-star-fill"></i></label>
        </div>

        <div class="form-group">
            <label class="form-label">تعليقك (اختياري)</label>
            <textarea class="form-control" id="ratingComment" rows="3" placeholder="شاركنا تجربتك..."></textarea>
        </div>

        <div class="row mt-2">
            <div class="col-6">
                <button class="btn btn-outline btn-block" onclick="closeRatingModal()">إلغاء</button>
            </div>
            <div class="col-6">
                <button class="btn btn-primary btn-block" onclick="submitRating(this)">
                    <i class="bi bi-send"></i>
                    إرسال التقييم
                </button>
            </div>
        </div>
    </div>
</div>

<script src="~/js/api.js"></script>
<script>
    let allAppointments = [];
    let currentFilter = 'all';
    let selectedAppointmentId = null;
    let rescheduleAppointmentId = null;

    async function init() {
        UI.redirectIfNotLoggedIn();
        await loadAppointments();
    }

    async function loadAppointments() {
        try {
            const res = await API.appointments.getAll();
            allAppointments = res.data || [];
            renderAppointments(allAppointments);
        } catch (err) {
            UI.showToast('حدث خطأ في تحميل المواعيد', 'error');
        }
    }

    function filterAppointments(filter, btn) {
        currentFilter = filter;
        document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');

        const filtered = filter === 'all'
            ? allAppointments
            : allAppointments.filter(a => a.status === filter);

        renderAppointments(filtered);
    }

    function renderAppointments(appointments) {
        const container = document.getElementById('appointmentsContainer');

        if (!appointments.length) {
            container.innerHTML = `
                <div class="empty-state">
                    <i class="bi bi-calendar-x" style="font-size:3rem;color:var(--text-muted)"></i>
                    <p>لا توجد مواعيد</p>
                    <a href="/Home/Appointments" class="btn btn-primary">
                        <i class="bi bi-plus-lg"></i>
                        احجز موعد جديد
                    </a>
                </div>
            `;
            return;
        }

        container.innerHTML = appointments.map(a => `
            <div class="appointment-card">
                <div class="appointment-header">
                    <div style="display:flex;align-items:center;gap:12px">
                        <span style="font-size:1.3rem;color:var(--primary)">
                            <i class="bi bi-calendar-check"></i>
                        </span>
                        <div>
                            <div style="font-weight:700">${a.serviceName}</div>
                            <div style="font-size:0.8rem;color:var(--text-muted)">#${a.id}</div>
                        </div>
                    </div>
                    ${UI.getStatusBadge(a.status)}
                </div>

                <div class="appointment-body">
                    <div>
                        <div class="appointment-info-label">الفرع</div>
                        <div class="appointment-info-value">${a.branchName}</div>
                    </div>
                    <div>
                        <div class="appointment-info-label">التاريخ</div>
                        <div class="appointment-info-value">${UI.formatDate(a.appointmentDate)}</div>
                    </div>
                    <div>
                        <div class="appointment-info-label">الوقت</div>
                        <div class="appointment-info-value">${UI.formatTime(a.timeSlot)}</div>
                    </div>
                    <div>
                        <div class="appointment-info-label">رقم الطابور</div>
                        <div class="appointment-info-value" style="color:var(--primary)">#${a.queueNumber}</div>
                    </div>
                </div>

                <div class="appointment-footer">
                    <div class="countdown" id="countdown-${a.id}"></div>

                    <div style="display:flex;gap:8px;flex-wrap:wrap">
                        ${a.status === 'Confirmed' || a.status === 'Pending' ? `
                            <button class="btn btn-sm" style="background:#EAF2FB;color:var(--primary)"
                                onclick="showQR(${a.id})">
                                <i class="bi bi-qr-code"></i> QR
                            </button>
                            <button class="btn btn-sm" style="background:#FEF9E7;color:#7D6608"
                                onclick="openReschedule(${a.id}, ${a.branchId}, ${a.serviceTypeId})">
                                <i class="bi bi-calendar-event"></i> تأجيل
                            </button>
                            <button class="btn btn-sm btn-danger"
                                onclick="cancelAppointment(${a.id}, this)">
                                <i class="bi bi-x-lg"></i> إلغاء
                            </button>
                        ` : ''}
                        ${a.status === 'Completed' && !a.hasRating ? `
                            <button class="btn btn-sm" style="background:#FEF9E7;color:#7D6608"
                                onclick="openRating(${a.id}, '${a.serviceName}', '${a.branchName}')">
                                <i class="bi bi-star"></i> قيم
                            </button>
                        ` : ''}
                        ${a.status === 'Completed' && a.hasRating ? `
                            <span class="stars-display">
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                            </span>
                        ` : ''}
                    </div>
                </div>
            </div>
        `).join('');

        // Countdown timers
        appointments.forEach(a => {
            if (a.status === 'Confirmed' || a.status === 'Pending') {
                updateCountdown(a);
            }
        });
    }

    function updateCountdown(appointment) {
        const el = document.getElementById(`countdown-${appointment.id}`);
        if (!el) return;

        const dateStr = appointment.appointmentDate.split('T')[0];
        const timeStr = appointment.timeSlot;
        const appointmentDate = new Date(`${dateStr}T${timeStr}`);
        const now = new Date();
        const diff = appointmentDate - now;

        if (diff <= 0) {
            el.innerHTML = '<i class="bi bi-clock"></i> الموعد الآن';
            return;
        }

        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));

        let text = '';
        if (days > 0) text = `باقي ${days} يوم و ${hours} ساعة`;
        else if (hours > 0) text = `باقي ${hours} ساعة و ${minutes} دقيقة`;
        else text = `باقي ${minutes} دقيقة`;

        el.innerHTML = `<i class="bi bi-hourglass-split"></i> ${text}`;
    }

    async function cancelAppointment(id, btn) {
        if (!confirm('متأكد إنك عاوز تلغي الموعد؟')) return;

        UI.showLoading(btn);
        try {
            await API.appointments.cancel(id);
            UI.showToast('تم إلغاء الموعد');
            await loadAppointments();
        } catch (err) {
            UI.showToast(err.message, 'error');
        } finally {
            UI.hideLoading(btn);
        }
    }

    async function showQR(id) {
        try {
            const res = await API.appointments.getQR(id);
            document.getElementById('qrImage').src = `data:image/png;base64,${res.data}`;

            const appointment = allAppointments.find(a => a.id === id);
            document.getElementById('qrAppointmentId').textContent = `#${id}`;
            document.getElementById('qrQueueNumber').textContent = `#${appointment?.queueNumber || '-'}`;

            document.getElementById('qrModal').classList.add('show');
        } catch (err) {
            UI.showToast('حدث خطأ في تحميل QR', 'error');
        }
    }

    function closeQRModal() {
        document.getElementById('qrModal').classList.remove('show');
    }

    function printQR() {
        window.print();
    }

    async function openReschedule(appointmentId, branchId, serviceTypeId) {
        rescheduleAppointmentId = appointmentId;
        window._rescheduleData = { branchId, serviceTypeId };

        const today = new Date().toISOString().split('T')[0];
        document.getElementById('rescheduleDate').value = today;
        document.getElementById('rescheduleDate').min = today;
        document.getElementById('rescheduleDate').onchange = loadRescheduleSlots;

        document.getElementById('rescheduleModal').classList.add('show');
        await loadRescheduleSlots();
    }

    async function loadRescheduleSlots() {
        const date = document.getElementById('rescheduleDate').value;
        const { branchId, serviceTypeId } = window._rescheduleData;
        const container = document.getElementById('rescheduleSlotsContainer');

        container.innerHTML = '<div style="text-align:center"><div class="spinner" style="border-color:var(--border);border-top-color:var(--primary);width:24px;height:24px;margin:0 auto"></div></div>';

        try {
            const res = await API.appointments.getSlots(branchId, serviceTypeId, date);
            const data = res.data;

            if (!data.isAvailable) {
                container.innerHTML = `<div class="alert alert-warning">${data.unavailabilityMessage}</div>`;
                return;
            }

            container.innerHTML = `
                <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px">
                    ${data.slots.map(slot => {
                        const time = UI.formatTime(slot.time);
                        if (slot.isBooked) {
                            return `<div class="slot-btn slot-booked" style="font-size:0.8rem">${time}</div>`;
                        }
                        return `
                            <button class="slot-btn ${slot.isPeak ? 'slot-peak' : 'slot-available'}"
                                style="font-size:0.8rem"
                                onclick="confirmReschedule('${slot.time}', '${time}')">
                                ${time}
                                <span style="font-size:0.7rem;display:block">${slot.bookedCount}/${slot.maxCount}</span>
                            </button>
                        `;
                    }).join('')}
                </div>
            `;
        } catch (err) {
            UI.showToast('حدث خطأ', 'error');
        }
    }

    async function confirmReschedule(timeSpan, displayTime) {
        if (!confirm(`هتأجل موعدك للساعة ${displayTime}؟`)) return;

        try {
            const date = document.getElementById('rescheduleDate').value;
            await API.appointments.reschedule(rescheduleAppointmentId, {
                newDate: new Date(date).toISOString(),
                newTimeSlot: timeSpan
            });

            UI.showToast('تم تأجيل موعدك بنجاح');
            closeRescheduleModal();
            await loadAppointments();
        } catch (err) {
            UI.showToast(err.message, 'error');
        }
    }

    function closeRescheduleModal() {
        document.getElementById('rescheduleModal').classList.remove('show');
    }

    function openRating(id, serviceName, branchName) {
        selectedAppointmentId = id;
        document.getElementById('ratingAppointmentInfo').innerHTML = `
            <strong>${serviceName}</strong> - ${branchName}
        `;
        document.getElementById('ratingModal').classList.add('show');
    }

    async function submitRating(btn) {
        const stars = document.querySelector('input[name="stars"]:checked')?.value;
        if (!stars) {
            UI.showToast('اختر عدد النجوم', 'error');
            return;
        }

        UI.showLoading(btn);
        try {
            await API.ratings.create({
                appointmentId: selectedAppointmentId,
                stars: parseInt(stars),
                comment: document.getElementById('ratingComment').value
            });

            UI.showToast('شكراً على تقييمك!');
            closeRatingModal();
            await loadAppointments();
        } catch (err) {
            UI.showToast(err.message, 'error');
        } finally {
            UI.hideLoading(btn);
        }
    }

    function closeRatingModal() {
        document.getElementById('ratingModal').classList.remove('show');
        document.querySelectorAll('input[name="stars"]').forEach(r => r.checked = false);
        document.getElementById('ratingComment').value = '';
    }

    // Close modals on overlay click
    ['qrModal', 'rescheduleModal', 'ratingModal'].forEach(id => {
        document.getElementById(id).addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('show');
        });
    });

    // Update countdowns every minute
    setInterval(() => {
        allAppointments.forEach(a => {
            if (a.status === 'Confirmed' || a.status === 'Pending') {
                updateCountdown(a);
            }
        });
    }, 60000);

    init();
</script>
</body>
</html>