@model AppointmentConfirmViewModel
@{ ViewData["Title"] = "تم الحجز بنجاح"; }

<div class="ph" style="padding-bottom:60px">
    <div class="hc"></div><div class="hc"></div>
    <div class="hi">
        <div style="display:flex;justify-content:flex-end;margin-bottom:16px;gap:8px">
            <span class="user-greeting-badge" id="hdrGreeting" style="display:none"></span>
            <button class="signin-header-btn"  id="hdrSignInBtn"  onclick="showAuthModal()">🔐 تسجيل الدخول</button>
            <button class="signout-header-btn" id="hdrSignOutBtn" onclick="doLogout()" style="display:none">🚪 خروج</button>
        </div>
        <div style="text-align:center">
            <div style="font-size:64px;margin-bottom:12px">✅</div>
            <div class="htitle" style="font-size:28px">تم تأكيد موعدك!</div>
            <div class="hsub">سنرسل لك تذكيراً قبل الموعد بساعة</div>
        </div>
    </div>
</div>


<div class="main" style="transform:translateY(-32px)">
    <div style="max-width:560px;margin:0 auto">
        <div class="form-card" style="text-align:center;padding:32px 24px">
            <div style="font-family:'Cairo',sans-serif;font-size:48px;font-weight:900;color:var(--purple);line-height:1;margin-bottom:4px">#@Model.AppointmentId</div>
            <div style="font-size:12px;color:var(--muted);margin-bottom:24px">رقم الحجز</div>
            <div style="display:grid;gap:12px;text-align:right">
                <div class="confirm-row"><span class="confirm-label">🏢 الفرع</span><span class="confirm-val">@Model.BranchName</span></div>
                <div class="confirm-row"><span class="confirm-label">📱 الشركة</span><span class="confirm-val">@Model.OperatorName</span></div>
                <div class="confirm-row"><span class="confirm-label">🛠️ الخدمة</span><span class="confirm-val">@Model.ServiceName</span></div>
                <div class="confirm-row"><span class="confirm-label">👤 الاسم</span><span class="confirm-val">@Model.CustomerName</span></div>
                <div class="confirm-row"><span class="confirm-label">📆 التاريخ</span><span class="confirm-val">@Model.AppointmentDate.ToString("dd/MM/yyyy")</span></div>
                <div class="confirm-row"><span class="confirm-label">🕐 الوقت</span><span class="confirm-val">@Model.AppointmentTime</span></div>
            </div>
            <div style="margin-top:24px;padding:14px;background:rgba(0,137,123,.07);border-radius:10px;font-size:12px;color:var(--teal);text-align:right">
                💡 يرجى الحضور قبل موعدك بـ 5 دقائق وإحضار بطاقة الرقم القومي
            </div>
            <div style="display:flex;gap:10px;margin-top:20px">
                <a href="@Url.Action("Index","Branch")" class="bkfull" style="flex:1;text-decoration:none;text-align:center">🏠 الرئيسية</a>
                <button onclick="window.print()" class="bkfull" style="flex:1;background:white;color:var(--purple);border:2px solid var(--purple)">🖨️ طباعة</button>
            </div>
        </div>
    </div>
</div>
