@model AdminBranchListViewModel
@{ ViewData["Title"] = "إدارة الفروع"; ViewData["Page"] = "branches"; }

<div class="page-toolbar">
    <div>
        <div class="page-title">🏢 إدارة الفروع</div>
        <div class="page-sub">@Model.TotalCount فرع — الصفحة @Model.Page من @Model.TotalPages</div>
    </div>
    <a href="/admin/branches/create" class="btn-primary">+ إضافة فرع</a>
</div>

<div class="dash-card" style="margin-bottom:16px">
    <form method="get" style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end">

        <div class="form-grp">
            <label>بحث</label>
            <input name="SearchQuery" value="@Model.SearchQuery" class="adm-input"
                   placeholder="اسم الفرع أو العنوان..." style="min-width:180px">
        </div>

        <div class="form-grp">
            <label>الشركة</label>
            <select name="FilterOp" class="adm-select">
                <option value="">الكل</option>
                @foreach (var op in Model.Operators)
                {
                    if (Model.FilterOp == op.Value)
                    {
                        <option value="@op.Value" selected>@op.Text</option>
                    }
                    else
                    {
                        <option value="@op.Value">@op.Text</option>
                    }
                }
            </select>
        </div>

        <div class="form-grp">
            <label>المحافظة</label>
            <select name="FilterGov" class="adm-select">
                <option value="">الكل</option>
                @foreach (var g in Model.Governorates)
                {
                    if (Model.FilterGov.ToString() == g.Value)
                    {
                        <option value="@g.Value" selected>@g.Text</option>
                    }
                    else
                    {
                        <option value="@g.Value">@g.Text</option>
                    }
                }
            </select>
        </div>

        <div class="form-grp">
            <label>الحالة</label>
            <select name="FilterStatus" class="adm-select">
                <option value="">الكل</option>
                @if (Model.FilterStatus == "open")   { <option value="open"   selected>متاح</option>   } else { <option value="open">متاح</option>   }
                @if (Model.FilterStatus == "busy")   { <option value="busy"   selected>مزدحم</option>  } else { <option value="busy">مزدحم</option>  }
                @if (Model.FilterStatus == "closed") { <option value="closed" selected>مغلق</option>   } else { <option value="closed">مغلق</option> }
            </select>
        </div>

        <button type="submit" class="btn-primary">بحث</button>
        <a href="/admin/branches" class="btn-ghost">مسح</a>
    </form>
</div>

<div class="dash-card">
    <div class="table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>الفرع</th>
                    <th>المحافظة / المركز</th>
                    <th>الحالة</th>
                    <th>الطابور</th>
                    <th>التقييم</th>
                    <th>الحجوزات</th>
                    <th>إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model.Branches)
                {
                    <tr>
                        <td style="color:var(--muted);font-size:11px">@b.Id</td>
                        <td>
                            <div style="display:flex;align-items:center;gap:8px">
                                <div class="op-dot op-logo-@b.OperatorKey" style="background:@b.OperatorBg"></div>
                                <div>
                                    <div style="font-size:12px;font-weight:700;color:var(--navy)">@b.NameAr</div>
                                    <div style="font-size:10px;color:var(--muted)">@b.OperatorName</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div style="font-size:11px;font-weight:600">@b.GovName</div>
                            <div style="font-size:10px;color:var(--muted)">@b.DistName</div>
                        </td>
                        <td><span class="status-badge @b.Status">@b.StatusLabel</span></td>
                        <td><span class="queue-badge">@b.QueueCount</span></td>
                        <td>
                            <span style="color:#F9A825">&#9733;</span>
                            <span style="font-size:12px;font-weight:700">@b.Rating</span>
                        </td>
                        <td><span class="kpi-badge today">@b.AppointmentCount</span></td>
                        <td>
                            <div style="display:flex;gap:5px">
                                <a href="/admin/branches/edit/@b.Id" class="tbl-btn edit">&#9998;</a>
                                <form method="post" action="/admin/branches/delete"
                                      onsubmit="return confirm('حذف هذا الفرع؟')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@b.Id">
                                    <button type="submit" class="tbl-btn del">&#128465;</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="pagination">
            @for (int p = 1; p <= Model.TotalPages; p++)
            {
                <a href="?Page=@p&SearchQuery=@Model.SearchQuery&FilterOp=@Model.FilterOp&FilterGov=@Model.FilterGov&FilterStatus=@Model.FilterStatus"
                   class="pg-btn @(p == Model.Page ? "active" : "")">@p</a>
            }
        </div>
    }
</div>
