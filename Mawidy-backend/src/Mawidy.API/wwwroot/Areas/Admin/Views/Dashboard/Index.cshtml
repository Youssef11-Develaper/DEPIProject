@model AdminDashboardViewModel
@{ ViewData["Title"] = "الداشبورد"; ViewData["Page"] = "dashboard"; }

<div class="kpi-grid">
    <div class="kpi-card" style="--ac:#7B1FA2">
        <div class="kpi-icon">🏢</div>
        <div class="kpi-body">
            <div class="kpi-num">@Model.TotalBranches</div>
            <div class="kpi-lbl">إجمالي الفروع</div>
        </div>
        <div class="kpi-sub">
            <span class="kpi-badge open">@Model.OpenBranches متاح</span>
            <span class="kpi-badge busy">@Model.BusyBranches مزدحم</span>
            <span class="kpi-badge closed">@Model.ClosedBranches مغلق</span>
        </div>
    </div>
    <div class="kpi-card" style="--ac:#1565C0">
        <div class="kpi-icon">📅</div>
        <div class="kpi-body">
            <div class="kpi-num">@Model.TotalAppointments</div>
            <div class="kpi-lbl">إجمالي الحجوزات</div>
        </div>
        <div class="kpi-sub">
            <span class="kpi-badge today">@Model.TodayAppointments اليوم</span>
            <span class="kpi-badge pending">@Model.PendingAppointments انتظار</span>
        </div>
    </div>
    <div class="kpi-card" style="--ac:#00897B">
        <div class="kpi-icon">🗺️</div>
        <div class="kpi-body">
            <div class="kpi-num">@Model.TotalGovernorates</div>
            <div class="kpi-lbl">محافظة مُغطاة</div>
        </div>
        <div class="kpi-sub">
            <span class="kpi-badge today">@Model.TotalDistricts مركز وحي</span>
        </div>
    </div>
    <div class="kpi-card" style="--ac:#E65100">
        <div class="kpi-icon">🎫</div>
        <div class="kpi-body">
            <div class="kpi-num">@Model.ActiveQueueEntries</div>
            <div class="kpi-lbl">في الطوابير الآن</div>
        </div>
        <div class="kpi-sub"><span class="kpi-badge open">مباشر</span></div>
    </div>
</div>

<div class="dash-row">
    <!-- إحصائيات الشركات -->
    <div class="dash-card" style="flex:1.4">
        <div class="dc-title">📱 إحصائيات الشركات</div>
        <div class="op-stats-grid">
            @foreach (var op in Model.OperatorStats)
            {
                var pct = Model.TotalBranches > 0 ? op.BranchCount * 100 / Model.TotalBranches : 0;
                <div class="op-stat-card">
                    <div class="op-stat-head" style="background:@op.BgColor">
                        <div class="op-stat-emoji op-logo-@op.OperatorKey" style="width:36px;height:36px;border-radius:8px;background-size:contain;background-repeat:no-repeat;background-position:center;font-size:0"></div>
                        <div>
                            <div class="op-stat-name" style="color:@op.Color">@op.NameAr</div>
                            <div class="op-stat-sub">@op.BranchCount فرع</div>
                        </div>
                        <div class="op-stat-rating">⭐ @op.AvgRating</div>
                    </div>
                    <div class="op-stat-body">
                        <div class="op-stat-row"><span>متاح</span><span class="green">@op.OpenCount</span></div>
                        <div class="op-stat-row"><span>الحجوزات</span><span class="blue">@op.AppointmentCount</span></div>
                        <div class="op-bar-wrap">
                            <div class="op-bar" style="width:@pct%;background:@op.Color"></div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- مخطط الأيام -->
    <div class="dash-card" style="flex:1">
        <div class="dc-title">📆 الحجوزات حسب اليوم (آخر 30 يوم)</div>
        <div class="bar-chart">
            @foreach (var d in Model.WeeklyStats)
            {
                var h = d.MaxCount > 0 ? (int)(d.Count * 100.0 / d.MaxCount) : 0;
                <div class="bar-col">
                    <div class="bar-val">@d.Count</div>
                    <div class="bar-wrap"><div class="bar-fill" style="height:@h%"></div></div>
                    <div class="bar-lbl">@(d.DayAr.Length >= 3 ? d.DayAr.Substring(0, 3) : d.DayAr)</div>
                </div>
            }
        </div>
    </div>
</div>

<div class="dash-row">
    <!-- توزيع الخدمات -->
    <div class="dash-card" style="flex:1">
        <div class="dc-title">🛠️ توزيع الخدمات</div>
        @if (!Model.ServiceStats.Any())
        {
            <div class="no-data">لا توجد حجوزات بعد</div>
        }
        else
        {
            @foreach (var s in Model.ServiceStats)
            {
                <div class="svc-row">
                    <div class="svc-icon">@s.Icon</div>
                    <div class="svc-body">
                        <div class="svc-name">@s.NameAr</div>
                        <div class="svc-bar-wrap"><div class="svc-bar" style="width:@s.Percentage%"></div></div>
                    </div>
                    <div class="svc-pct">@s.Percentage%</div>
                    <div class="svc-cnt">@s.Count</div>
                </div>
            }
        }
    </div>

    <!-- أكثر الفروع ازدحاماً -->
    <div class="dash-card" style="flex:1.2">
        <div class="dc-title">🔥 أكثر الفروع ازدحاماً</div>
        <table class="admin-table">
            <thead><tr><th>الفرع</th><th>المنطقة</th><th>الطابور</th><th>الانتظار</th></tr></thead>
            <tbody>
                @foreach (var b in Model.BusiestBranches)
                {
                    <tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:7px">
                                <div class="op-dot op-logo-@b.OperatorKey" style="background:@b.OperatorBg"></div>
                                <span style="font-size:12px;font-weight:700;color:var(--navy)">@b.NameAr</span>
                            </div>
                        </td>
                        <td><span style="font-size:11px;color:var(--muted)">@b.GovName / @b.DistName</span></td>
                        <td><span class="queue-badge">@b.QueueCount</span></td>
                        <td><span class="wait-badge">@b.WaitTime</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- أحدث الحجوزات -->
<div class="dash-card">
    <div class="dc-header">
        <div class="dc-title">📋 أحدث الحجوزات</div>
        <a href="/admin/appointments" class="dc-link">عرض الكل ←</a>
    </div>
    @if (!Model.RecentAppointments.Any())
    {
        <div class="no-data">لا توجد حجوزات بعد — <a href="/Branch">ابدأ بحجز موعد</a></div>
    }
    else
    {
        <div class="table-wrap">
            <table class="admin-table">
                <thead>
                    <tr><th>#</th><th>العميل</th><th>الفرع</th><th>الخدمة</th><th>التاريخ</th><th>الوقت</th><th>الحالة</th></tr>
                </thead>
                <tbody>
                    @foreach (var a in Model.RecentAppointments)
                    {
                        <tr>
                            <td style="color:var(--muted);font-size:11px">#@a.Id</td>
                            <td>
                                <div style="font-weight:700;font-size:12px">@a.CustomerName</div>
                                <div style="font-size:10px;color:var(--muted)">@a.CustomerPhone</div>
                            </td>
                            <td>
                                <div style="display:flex;align-items:center;gap:5px">
                                    <div class="op-dot op-logo-@a.OperatorKey" style="background:@a.OperatorBg;font-size:0"></div>
                                    <span style="font-size:11px">@a.BranchName</span>
                                </div>
                            </td>
                            <td><span style="font-size:13px">@a.ServiceIcon</span> <span style="font-size:11px">@a.ServiceName</span></td>
                            <td style="font-size:11px">@a.Date.ToString("dd/MM/yyyy")</td>
                            <td style="font-size:11px;font-weight:700">@a.Time</td>
                            <td><span class="status-badge @a.StatusClass">@a.StatusLabel</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- أعلى المحافظات -->
<div class="dash-card">
    <div class="dc-header">
        <div class="dc-title">🗺️ توزيع الفروع على المحافظات (أعلى 10)</div>
        <a href="/admin/reports" class="dc-link">التقرير الكامل ←</a>
    </div>
    <div class="gov-stats-grid">
        @foreach (var g in Model.TopGovernorates)
        {
            var pct = Model.TotalBranches > 0 ? g.BranchCount * 100 / Model.TotalBranches : 0;
            <div class="gov-stat-card">
                <div class="gov-stat-emoji">@g.Emoji</div>
                <div class="gov-stat-name">@g.NameAr</div>
                <div class="gov-stat-region">@g.Region</div>
                <div class="gov-stat-bar-wrap"><div class="gov-stat-bar" style="width:@pct%"></div></div>
                <div class="gov-stat-nums">
                    <span>@g.BranchCount فرع</span>
                    <span>@g.DistrictCount مركز</span>
                </div>
            </div>
        }
    </div>
</div>
